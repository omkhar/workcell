write_latest_log_pointer() {
  local profile="$1"
  local kind="$2"
  local path="$3"
  local pointer_path=""
  local resolved_pointer_path=""

  [[ -n "${path}" ]] || return 0
  pointer_path="$(profile_latest_log_pointer_path "${profile}" "${kind}")"
  if ! resolved_pointer_path="$(resolve_host_output_candidate "${pointer_path}")"; then
    echo "Workcell blocked latest ${kind} pointer path after launch: ${pointer_path}" >&2
    return 1
  fi
  mkdir -p "$(dirname "${resolved_pointer_path}")"
  umask 077
  printf '%s\n' "${path}" >"${resolved_pointer_path}"
  chmod 0600 "${resolved_pointer_path}" 2>/dev/null || true
}

workspace_absolute_git_dir() {
  local workspace="$1"

  run_workspace_safe_git_command_in_dir "${workspace}" rev-parse --absolute-git-dir
}

default_session_workspace_mode() {
  if [[ "${SESSION_DETACHED}" -eq 1 ]]; then
    printf 'isolated\n'
    return 0
  fi
  printf 'direct\n'
}

effective_session_workspace_mode() {
  if [[ -n "${SESSION_WORKSPACE_MODE}" ]]; then
    printf '%s\n' "${SESSION_WORKSPACE_MODE}"
    return 0
  fi
  default_session_workspace_mode
}

session_workspace_parent_dir() {
  local source_workspace="$1"
  local git_dir=""

  git_dir="$(workspace_absolute_git_dir "${source_workspace}")"
  printf '%s/workcell-sessions\n' "${git_dir}"
}

isolated_session_workspace_path() {
  local source_workspace="$1"
  local session_id="$2"

  printf '%s/%s/repo\n' "$(session_workspace_parent_dir "${source_workspace}")" "${session_id}"
}

session_monitor_state_path() {
  local session_audit_dir="$1"

  printf '%s/session-monitor.env\n' "${session_audit_dir}"
}

session_monitor_ready_path() {
  local session_audit_dir="$1"

  printf '%s/session-monitor.ready\n' "${session_audit_dir}"
}

create_isolated_session_workspace() {
  local source_workspace="$1"
  local session_id="$2"
  local base_ref=""
  local target=""
  local branch_name=""

  validate_isolated_session_workspace_source "${source_workspace}"

  base_ref="$(run_workspace_safe_git_command_in_dir "${source_workspace}" rev-parse --verify HEAD)"
  target="$(isolated_session_workspace_path "${source_workspace}" "${session_id}")"
  if ! target="$(resolve_host_output_candidate "${target}")"; then
    exit 2
  fi
  branch_name="workcell/session-${session_id}"

  [[ ! -e "${target}" ]] || {
    echo "Refusing to reuse an existing isolated session workspace: ${target}" >&2
    exit 2
  }

  mkdir -p "$(dirname "${target}")"
  run_clean_host_command_in_dir "${ROOT_DIR}" "${HOST_GIT_BIN}" clone --quiet --no-hardlinks "${source_workspace}" "${target}"
  run_workspace_safe_git_command_in_dir "${target}" checkout --quiet -B "${branch_name}" "${base_ref}"
  printf '%s\n' "${target}"
}

validate_isolated_session_workspace_source() {
  local source_workspace="$1"

  workspace_is_git_worktree "${source_workspace}" || {
    echo "Workspace is not a git worktree: ${source_workspace}" >&2
    echo "Detached session start with --session-workspace isolated requires a git workspace." >&2
    echo "Next step: rerun with --session-workspace direct if you want to use the current workspace in place." >&2
    exit 2
  }
  if ! workspace_gitdir_is_self_contained "${source_workspace}"; then
    echo "Refusing git workspace with admin state outside the mounted workspace: ${source_workspace}" >&2
    echo "This workspace is a linked worktree: its .git file points to a .git directory outside the mounted path." >&2
    echo "To use this workspace on the safe path, create a standard clone at the same location instead." >&2
    echo "Alternatively, pass --mode breakglass --ack-breakglass=YYYY-MM-DD to proceed with a linked worktree." >&2
    exit 2
  fi
  if workspace_git_has_worktree_changes "${source_workspace}"; then
    echo "session start requires a clean source workspace for isolated session cloning: ${source_workspace}" >&2
    echo "Next step: commit or stash the workspace changes, or rerun with --session-workspace direct to use the current workspace in place." >&2
    exit 2
  fi
}

profile_docker_socket_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  [[ "$(target_provider_for_profile_state "${profile}")" == "colima" ]] || return 1
  printf '%s/%s/docker.sock\n' "${COLIMA_STATE_ROOT}" "${profile}"
}

run_profile_docker_command() {
  local profile="$1"
  local socket_path=""
  local provider=""
  local context_name=""

  shift
  provider="$(target_provider_for_profile_state "${profile}")"
  case "${provider}" in
    colima)
      socket_path="$(profile_docker_socket_path "${profile}")"
      ;;
    docker-desktop)
      context_name="$(target_id_for_profile_state "${profile}")"
      ;;
  esac

  # Delegate the env-prefix decision to the Go translation; on
  # unsupported providers the helper emits the original bash
  # diagnostic to its stderr and exits 1, which we surface here.
  local route_stderr route_output rc trailer
  route_stderr="$(mktemp "${TMPDIR:-/tmp}/workcell-docker-route-stderr.XXXXXX")"
  route_output="$(go_hostutil helper route-profile-docker-command \
    "--provider=${provider}" \
    "--socket-path=${socket_path}" \
    "--context-name=${context_name}" 2>"${route_stderr}")"
  rc=$?
  if ((rc != 0)); then
    trailer="$(tail -n1 "${route_stderr}" 2>/dev/null || true)"
    case "${trailer}" in
      "exit status "[0-9]*)
        rc="${trailer##* }"
        sed -i.bak '$d' "${route_stderr}" 2>/dev/null || true
        rm -f "${route_stderr}.bak"
        ;;
    esac
    cat "${route_stderr}" >&2
    rm -f "${route_stderr}"
    return "${rc}"
  fi
  rm -f "${route_stderr}"

  local -a env_prefix=()
  while IFS= read -r token; do
    [[ -n "${token}" ]] || continue
    env_prefix+=("${token}")
  done <<<"${route_output}"

  run_workcell_docker_client_command "${env_prefix[@]}" "${HOST_DOCKER_BIN}" "$@"
}

profile_docker_transport_available() {
  local profile="$1"
  local provider=""
  local socket_path=""
  local context_name=""

  provider="$(target_provider_for_profile_state "${profile}")"
  case "${provider}" in
    colima)
      socket_path="$(profile_docker_socket_path "${profile}" || true)"
      [[ -n "${socket_path}" ]] && [[ -e "${socket_path}" ]]
      ;;
    docker-desktop)
      if [[ -z "${HOST_DOCKER_BIN:-}" ]]; then
        HOST_DOCKER_BIN="$(resolve_host_tool_optional docker /opt/homebrew/bin/docker /usr/local/bin/docker /Applications/Docker.app/Contents/Resources/bin/docker)" || return 1
        sanitize_host_docker_env
      fi
      context_name="$(target_id_for_profile_state "${profile}")"
      [[ -n "${context_name}" ]] &&
        docker_context_exists "${context_name}" &&
        docker_context_is_healthy "${context_name}"
      ;;
    *)
      return 1
      ;;
  esac
}

append_session_control_audit_record() {
  local profile="$1"
  local session_id="$2"
  local event_name="$3"
  local audit_path=""

  shift 3
  audit_path="${SESSION_META_AUDIT_LOG_PATH:-}"
  if [[ -n "${audit_path}" ]]; then
    append_audit_record_to_path "${audit_path}" \
      "event=${event_name}" \
      "session_id=${session_id}" \
      "$@"
    return 0
  fi
  append_audit_record "${profile}" \
    "event=${event_name}" \
    "session_id=${session_id}" \
    "$@"
}

session_runtime_metadata() {
  local session_id="$1"

  collect_session_lookup_roots || return 1
  go_hostutil helper session-runtime-metadata "${SESSION_LOOKUP_ROOTS[@]}" "${session_id}"
}

load_session_runtime_metadata() {
  local session_id="$1"
  local plan=""

  SESSION_META_PROFILE=""
  SESSION_META_RECORD_PATH=""
  SESSION_META_TARGET_KIND=""
  SESSION_META_TARGET_PROVIDER=""
  SESSION_META_TARGET_ID=""
  SESSION_META_TARGET_ASSURANCE_CLASS=""
  SESSION_META_RUNTIME_API=""
  SESSION_META_WORKSPACE_TRANSPORT=""
  SESSION_META_WORKSPACE=""
  SESSION_META_WORKSPACE_ORIGIN=""
  SESSION_META_WORKTREE_PATH=""
  SESSION_META_GIT_BRANCH=""
  SESSION_META_CONTAINER_NAME=""
  SESSION_META_MONITOR_PID=""
  SESSION_META_STATUS=""
  SESSION_META_LIVE_STATUS=""
  SESSION_META_CURRENT_ASSURANCE=""
  SESSION_META_SESSION_AUDIT_DIR=""
  SESSION_META_AUDIT_LOG_PATH=""
  SESSION_META_DEBUG_LOG_PATH=""
  SESSION_META_FILE_TRACE_LOG_PATH=""
  SESSION_META_TRANSCRIPT_LOG_PATH=""

  plan="$(session_runtime_metadata "${session_id}")"
  shellproto_assign_globals "${plan}" \
    record_path:SESSION_META_RECORD_PATH \
    profile:SESSION_META_PROFILE \
    target_kind:SESSION_META_TARGET_KIND \
    target_provider:SESSION_META_TARGET_PROVIDER \
    target_id:SESSION_META_TARGET_ID \
    target_assurance_class:SESSION_META_TARGET_ASSURANCE_CLASS \
    runtime_api:SESSION_META_RUNTIME_API \
    workspace_transport:SESSION_META_WORKSPACE_TRANSPORT \
    workspace:SESSION_META_WORKSPACE \
    workspace_origin:SESSION_META_WORKSPACE_ORIGIN \
    worktree_path:SESSION_META_WORKTREE_PATH \
    git_branch:SESSION_META_GIT_BRANCH \
    container_name:SESSION_META_CONTAINER_NAME \
    monitor_pid:SESSION_META_MONITOR_PID \
    status:SESSION_META_STATUS \
    live_status:SESSION_META_LIVE_STATUS \
    current_assurance:SESSION_META_CURRENT_ASSURANCE \
    session_audit_dir:SESSION_META_SESSION_AUDIT_DIR \
    audit_log_path:SESSION_META_AUDIT_LOG_PATH \
    debug_log_path:SESSION_META_DEBUG_LOG_PATH \
    file_trace_log_path:SESSION_META_FILE_TRACE_LOG_PATH \
    transcript_log_path:SESSION_META_TRANSCRIPT_LOG_PATH
}

session_meta_target_summary() {
  local value=""
  local -a parts=()

  for value in \
    "${SESSION_META_TARGET_KIND:-}" \
    "${SESSION_META_TARGET_PROVIDER:-}" \
    "${SESSION_META_TARGET_ID:-}"; do
    [[ -n "${value}" ]] || continue
    parts+=("${value}")
  done
  if [[ "${#parts[@]}" -eq 0 ]]; then
    printf '\n'
    return 0
  fi
  (
    IFS='/'
    printf '%s\n' "${parts[*]}"
  )
}

session_meta_display_workspace() {
  if [[ -n "${SESSION_META_WORKSPACE_ORIGIN:-}" ]]; then
    printf '%s\n' "${SESSION_META_WORKSPACE_ORIGIN}"
    return 0
  fi
  printf '%s\n' "${SESSION_META_WORKSPACE:-}"
}

session_meta_display_worktree() {
  if [[ -n "${SESSION_META_WORKTREE_PATH:-}" ]]; then
    printf '%s\n' "${SESSION_META_WORKTREE_PATH}"
    return 0
  fi
  printf '%s\n' "${SESSION_META_WORKSPACE:-}"
}

session_meta_display_git_branch() {
  if [[ -n "${SESSION_META_GIT_BRANCH:-}" ]]; then
    printf '%s\n' "${SESSION_META_GIT_BRANCH}"
    return 0
  fi
  printf 'none\n'
}

ensure_session_meta_git_branch() {
  local fallback_git_branch="${1:-}"

  if [[ -n "${SESSION_META_GIT_BRANCH:-}" ]]; then
    return 0
  fi
  SESSION_META_GIT_BRANCH="${fallback_git_branch:-none}"
}

emit_loaded_session_control_summary() {
  printf 'target_kind=%s\n' "${SESSION_META_TARGET_KIND:-}"
  printf 'target_provider=%s\n' "${SESSION_META_TARGET_PROVIDER:-}"
  printf 'target_id=%s\n' "${SESSION_META_TARGET_ID:-}"
  printf 'target_summary=%s\n' "$(session_meta_target_summary)"
  printf 'target_assurance_class=%s\n' "${SESSION_META_TARGET_ASSURANCE_CLASS:-}"
  printf 'runtime_api=%s\n' "${SESSION_META_RUNTIME_API:-}"
  printf 'workspace_transport=%s\n' "${SESSION_META_WORKSPACE_TRANSPORT:-}"
  printf 'workspace=%s\n' "${SESSION_META_WORKSPACE:-}"
  printf 'display_workspace=%s\n' "$(session_meta_display_workspace)"
  printf 'workspace_origin=%s\n' "${SESSION_META_WORKSPACE_ORIGIN:-}"
  printf 'display_worktree=%s\n' "$(session_meta_display_worktree)"
  printf 'worktree_path=%s\n' "${SESSION_META_WORKTREE_PATH:-}"
  printf 'display_git_branch=%s\n' "$(session_meta_display_git_branch)"
  printf 'git_branch=%s\n' "${SESSION_META_GIT_BRANCH:-}"
  printf 'assurance=%s\n' "${SESSION_META_CURRENT_ASSURANCE:-}"
}

current_target_kind() {
  case "${TARGET_BACKEND}" in
    colima)
      printf 'local_vm\n'
      ;;
    docker-desktop)
      printf 'local_compat\n'
      ;;
    aws-ec2-ssm | gcp-vm)
      printf 'remote_vm\n'
      ;;
  esac
}

target_backend_is_remote_vm_preview() {
  case "$1" in
    aws-ec2-ssm | gcp-vm)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

preview_remote_vm_broker() {
  case "$1" in
    aws-ec2-ssm)
      printf 'aws-ssm-session-manager\n'
      ;;
    gcp-vm)
      printf 'gcp-iap-ssh\n'
      ;;
    *)
      return 1
      ;;
  esac
}

preview_remote_vm_rollout_doc() {
  case "$1" in
    aws-ec2-ssm)
      printf 'docs/aws-ec2-ssm-preview.md\n'
      ;;
    gcp-vm)
      printf 'docs/gcp-vm-preview.md\n'
      ;;
    *)
      return 1
      ;;
  esac
}

preview_remote_vm_rollout_action() {
  case "$1" in
    aws-ec2-ssm)
      printf 'review-aws-preview-rollout\n'
      ;;
    gcp-vm)
      printf 'review-gcp-preview-rollout\n'
      ;;
    *)
      return 1
      ;;
  esac
}

current_target_provider() {
  printf '%s\n' "${TARGET_BACKEND}"
}

current_target_id() {
  case "${TARGET_BACKEND}" in
    colima)
      printf '%s\n' "${COLIMA_PROFILE}"
      ;;
    docker-desktop)
      docker_desktop_context_name
      ;;
    aws-ec2-ssm | gcp-vm)
      printf '%s\n' "${COLIMA_PROFILE}"
      ;;
  esac
}

current_target_assurance_class() {
  case "${TARGET_BACKEND}" in
    colima)
      printf 'strict\n'
      ;;
    docker-desktop)
      printf 'compat\n'
      ;;
    aws-ec2-ssm | gcp-vm)
      printf 'compat\n'
      ;;
  esac
}

current_runtime_api() {
  if target_backend_is_remote_vm_preview "${TARGET_BACKEND}"; then
    printf 'brokered\n'
    return 0
  fi
  printf 'docker\n'
}

current_workspace_transport() {
  if target_backend_is_remote_vm_preview "${TARGET_BACKEND}"; then
    printf 'remote-materialization\n'
    return 0
  fi
  if [[ -n "${SESSION_SOURCE_WORKSPACE:-}" ]] && [[ -n "${WORKSPACE:-}" ]] &&
    [[ "${SESSION_SOURCE_WORKSPACE}" != "${WORKSPACE}" ]]; then
    printf 'isolated-worktree-mount\n'
    return 0
  fi
  printf 'workspace-mount\n'
}

refresh_support_matrix_state() {
  local metadata=""

  metadata="$(go_hostutil helper support-matrix-eval \
    "${WORKCELL_HOST_SUPPORT_MATRIX_PATH}" \
    "$(detected_host_os)" \
    "$(detected_host_arch)" \
    "$(detected_host_distro)" \
    "$(detected_host_distro_version)" \
    "$(current_target_kind)" \
    "$(current_target_provider)" \
    "$(current_target_assurance_class)")"

  SUPPORT_MATRIX_HOST_OS=""
  SUPPORT_MATRIX_HOST_ARCH=""
  SUPPORT_MATRIX_HOST_DISTRO=""
  SUPPORT_MATRIX_HOST_DISTRO_VERSION=""
  SUPPORT_MATRIX_STATUS=""
  SUPPORT_MATRIX_LAUNCH=""
  SUPPORT_MATRIX_EVIDENCE=""
  SUPPORT_MATRIX_VALIDATION_LANE=""
  SUPPORT_MATRIX_REASON=""

  shellproto_assign_globals "${metadata}" \
    host_os:SUPPORT_MATRIX_HOST_OS \
    host_arch:SUPPORT_MATRIX_HOST_ARCH \
    host_distro:SUPPORT_MATRIX_HOST_DISTRO \
    host_distro_version:SUPPORT_MATRIX_HOST_DISTRO_VERSION \
    support_matrix_status:SUPPORT_MATRIX_STATUS \
    support_matrix_launch:SUPPORT_MATRIX_LAUNCH \
    support_matrix_evidence:SUPPORT_MATRIX_EVIDENCE \
    support_matrix_validation_lane:SUPPORT_MATRIX_VALIDATION_LANE \
    support_matrix_reason:SUPPORT_MATRIX_REASON

  [[ -n "${SUPPORT_MATRIX_HOST_OS}" ]] || SUPPORT_MATRIX_HOST_OS="$(detected_host_os)"
  [[ -n "${SUPPORT_MATRIX_HOST_ARCH}" ]] || SUPPORT_MATRIX_HOST_ARCH="$(detected_host_arch)"
  [[ -n "${SUPPORT_MATRIX_HOST_DISTRO}" ]] || SUPPORT_MATRIX_HOST_DISTRO="$(detected_host_distro)"
  [[ -n "${SUPPORT_MATRIX_HOST_DISTRO_VERSION}" ]] || SUPPORT_MATRIX_HOST_DISTRO_VERSION="$(detected_host_distro_version)"
  [[ -n "${SUPPORT_MATRIX_STATUS}" ]] || SUPPORT_MATRIX_STATUS="unsupported"
  [[ -n "${SUPPORT_MATRIX_LAUNCH}" ]] || SUPPORT_MATRIX_LAUNCH="blocked"
  [[ -n "${SUPPORT_MATRIX_EVIDENCE}" ]] || SUPPORT_MATRIX_EVIDENCE="none"
  [[ -n "${SUPPORT_MATRIX_VALIDATION_LANE}" ]] || SUPPORT_MATRIX_VALIDATION_LANE="none"
  [[ -n "${SUPPORT_MATRIX_REASON}" ]] || SUPPORT_MATRIX_REASON="not-in-reviewed-support-matrix"
}

print_support_matrix_state() {
  printf 'host_os=%s\n' "${SUPPORT_MATRIX_HOST_OS}"
  printf 'host_arch=%s\n' "${SUPPORT_MATRIX_HOST_ARCH}"
  printf 'host_distro=%s\n' "${SUPPORT_MATRIX_HOST_DISTRO}"
  printf 'host_distro_version=%s\n' "${SUPPORT_MATRIX_HOST_DISTRO_VERSION}"
  printf 'support_matrix_status=%s\n' "${SUPPORT_MATRIX_STATUS}"
  printf 'support_matrix_launch=%s\n' "${SUPPORT_MATRIX_LAUNCH}"
  printf 'support_matrix_evidence=%s\n' "${SUPPORT_MATRIX_EVIDENCE}"
  printf 'support_matrix_validation_lane=%s\n' "${SUPPORT_MATRIX_VALIDATION_LANE}"
  printf 'support_matrix_reason=%s\n' "${SUPPORT_MATRIX_REASON}"
}

support_matrix_launch_allowed() {
  [[ "${SUPPORT_MATRIX_LAUNCH}" == "allowed" ]]
}

preview_remote_vm_dry_run_allowed() {
  target_backend_is_remote_vm_preview "${TARGET_BACKEND}" &&
    [[ "${DRY_RUN}" -eq 1 ]] &&
    [[ "${SUPPORT_MATRIX_STATUS}" == "preview-only" ]]
}

emit_preview_remote_vm_dry_run() {
  printf 'profile=%s mode=%s agent=%s ui=%s workspace=%s\n' \
    "${COLIMA_PROFILE}" "${MODE}" "${AGENT}" "${UI}" "${WORKSPACE}" >&2
  printf 'target_kind=%s target_provider=%s target_id=%s target_assurance_class=%s runtime_api=%s workspace_transport=%s\n' \
    "$(current_target_kind)" \
    "$(current_target_provider)" \
    "$(current_target_id)" \
    "$(current_target_assurance_class)" \
    "$(current_runtime_api)" \
    "$(current_workspace_transport)" >&2
  printf 'agent_autonomy=%s\n' "${AGENT_AUTONOMY}" >&2
  printf 'cache_profile=%s\n' "${CACHE_PROFILE}" >&2
  printf 'cache_assurance=%s\n' "$(cache_assurance)" >&2
  printf 'autonomy_assurance=%s\n' "$(autonomy_assurance)" >&2
  printf 'observability_assurance=%s\n' "$(observability_assurance)" >&2
  printf 'codex_rules_mutability_configured=%s\n' "${CODEX_RULES_MUTABILITY}" >&2
  printf 'codex_rules_assurance_configured=%s\n' "$(codex_rules_assurance)" >&2
  printf 'codex_rules_mutability_effective_initial=%s\n' "$(codex_rules_effective_mutability_initial)" >&2
  printf 'codex_rules_assurance_effective_initial=%s\n' "$(codex_rules_effective_assurance_initial)" >&2
  printf 'provider_native_sandbox_configured=%s effective=%s reason=%s\n' \
    "$(provider_native_sandbox_configured)" \
    "$(provider_native_sandbox_effective)" \
    "$(provider_native_sandbox_reason)" >&2
  printf 'session_assurance_initial=%s\n' "$(session_assurance_initial)" >&2
  if [[ -n "${INJECTION_POLICY_SHA256}" ]]; then
    printf 'injection_policy_sha256=%s credential_keys=%s ssh_injected=%s\n' \
      "${INJECTION_POLICY_SHA256}" "${INJECTION_CREDENTIAL_KEYS:-none}" "${INJECTION_SSH_ENABLED}" >&2
  fi
  printf 'workspace_control_plane=%s\n' "$(workspace_control_plane_state)" >&2
  printf 'network_policy=%s endpoints=%s\n' "${NETWORK_POLICY}" "${ALLOW_ENDPOINTS}" >&2
  printf 'egress_enforcement=%s\n' "$(egress_enforcement_label)" >&2
  printf 'remote_access_model=brokered remote_broker=%s inbound_public_ssh=blocked live_smoke=certification-only\n' \
    "$(preview_remote_vm_broker "${TARGET_BACKEND}")" >&2
  printf 'remote_workspace_materialization=explicit reviewed_host_copy=1\n' >&2
  printf 'execution_path=remote-preview-broker-plan audit_log=%s rollout_doc=%s\n' \
    "$(profile_audit_log_path "${COLIMA_PROFILE}")" \
    "$(preview_remote_vm_rollout_doc "${TARGET_BACKEND}")" >&2
  printf 'remote-preview-plan target=%s broker=%s target_id=%s launch_gate=certification-only workspace=%s\n' \
    "$(current_target_provider)" \
    "$(preview_remote_vm_broker "${TARGET_BACKEND}")" \
    "$(current_target_id)" \
    "${WORKSPACE}"
}

fail_for_unsupported_launch_target() {
  if support_matrix_launch_allowed || preview_remote_vm_dry_run_allowed; then
    return 0
  fi

  echo "Workcell launch is not supported for ${SUPPORT_MATRIX_HOST_OS}/${SUPPORT_MATRIX_HOST_ARCH}/${SUPPORT_MATRIX_HOST_DISTRO}/${SUPPORT_MATRIX_HOST_DISTRO_VERSION} on target $(current_target_kind)/$(current_target_provider)/$(current_target_assurance_class)." >&2
  if [[ "${SUPPORT_MATRIX_STATUS}" == "validation-host-only" ]] && [[ "${SUPPORT_MATRIX_VALIDATION_LANE}" != "none" ]]; then
    echo "This combination is reserved for the reviewed validation-host lane: ${SUPPORT_MATRIX_VALIDATION_LANE}." >&2
  fi
  if [[ "$(current_target_provider)" == "colima" ]]; then
    echo "Supported launch hosts today remain Apple Silicon macOS for the reviewed Colima strict path." >&2
  elif [[ "$(current_target_provider)" == "aws-ec2-ssm" ]]; then
    echo "The AWS remote VM target is a preview-only brokered path. Repo-required dry-run diagnostics are supported, but live launch remains certification-only and must use audited SSM access without inbound public SSH." >&2
    echo "Use --dry-run to inspect the reviewed broker plan, then follow docs/aws-ec2-ssm-preview.md for the certification path." >&2
  elif [[ "$(current_target_provider)" == "gcp-vm" ]]; then
    echo "The GCP remote VM target is a preview-only brokered path. Repo-required dry-run diagnostics are supported, but live launch remains certification-only and must use audited IAP access without inbound public SSH." >&2
    echo "Use --dry-run to inspect the reviewed broker plan, then follow docs/gcp-vm-preview.md for the certification path." >&2
  else
    echo "The Docker Desktop target remains a lower-assurance compat path and is only supported where the published host matrix allows it." >&2
  fi
  echo "Run workcell --agent ${AGENT} --doctor --workspace ${WORKSPACE} to inspect the support boundary on this host." >&2
  exit 2
}

session_record_matches_attached_workspace_shape() {
  [[ -n "${SESSION_META_WORKSPACE:-}" ]] || return 1
  [[ -n "${SESSION_META_WORKSPACE_ORIGIN:-}" ]] || return 1
  [[ "${SESSION_META_WORKSPACE_ORIGIN}" == "${SESSION_META_WORKSPACE}" ]] || return 1
  [[ -z "${SESSION_META_WORKTREE_PATH:-}" ]] || [[ "${SESSION_META_WORKTREE_PATH}" == "${SESSION_META_WORKSPACE}" ]]
}

session_record_has_legacy_live_detached_shape() {
  case "${SESSION_META_LIVE_STATUS:-${SESSION_META_STATUS:-}}" in
    starting | running | stopping)
      [[ -n "${SESSION_META_PROFILE:-}" ]] && [[ -n "${SESSION_META_CONTAINER_NAME:-}" ]] || return 1
      if session_record_matches_attached_workspace_shape; then
        return 1
      fi
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

session_require_detached_runtime_metadata() {
  local action="$1"
  local session_id="$2"
  local allow_legacy_live="${3:-0}"

  if [[ -n "${SESSION_META_MONITOR_PID:-}" ]]; then
    return 0
  fi
  if [[ "${allow_legacy_live}" -eq 1 ]] && session_record_has_legacy_live_detached_shape; then
    return 0
  fi
  echo "session ${action} only works for detached sessions started with 'workcell session start': ${session_id}" >&2
  echo "Use 'workcell session list' to check the control column; attached records are not stoppable." >&2
  return 1
}

session_monitor_pid_is_live() {
  local expected_state_file=""
  local monitor_command=""

  [[ "${SESSION_META_MONITOR_PID:-}" =~ ^[1-9][0-9]*$ ]] || return 1
  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || return 1
  kill -0 "${SESSION_META_MONITOR_PID}" >/dev/null 2>&1 || return 1
  expected_state_file="$(session_monitor_state_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  monitor_command="$(ps -o command= -p "${SESSION_META_MONITOR_PID}" 2>/dev/null | head -n1 || true)"
  [[ -n "${monitor_command}" ]] || return 1
  case "${monitor_command}" in
    *"${BASH_SOURCE[0]}"*" session monitor --state-file "*"${expected_state_file}"*) return 0 ;;
  esac
  return 1
}

session_container_live_state() {
  local profile="$1"
  local container_name="$2"

  run_profile_docker_command "${profile}" inspect \
    --format '{{if .State.Running}}running{{else}}stopped{{end}}' \
    "${container_name}"
}

session_container_exit_code() {
  local profile="$1"
  local container_name="$2"
  local exit_code=""

  exit_code="$(run_profile_docker_command "${profile}" inspect \
    --format '{{.State.ExitCode}}' \
    "${container_name}" 2>/dev/null || true)"
  exit_code="$(printf '%s\n' "${exit_code}" | tr -d '\r' | tail -n1)"
  [[ "${exit_code}" =~ ^[0-9]+$ ]] || exit_code="1"
  printf '%s\n' "${exit_code}"
}

session_container_state_for_delete() {
  local profile="$1"
  local container_name="$2"
  local inspect_output=""
  local inspect_status=0

  set +e
  inspect_output="$(run_profile_docker_command "${profile}" inspect \
    --format '{{if .State.Running}}running{{else}}stopped{{end}}' \
    "${container_name}" 2>&1)"
  inspect_status="$?"
  set -e
  inspect_output="$(printf '%s\n' "${inspect_output}" | tr -d '\r' | tail -n1)"
  if [[ "${inspect_status}" -eq 0 ]]; then
    case "${inspect_output}" in
      running | stopped)
        printf '%s\n' "${inspect_output}"
        return 0
        ;;
    esac
    return 1
  fi
  case "${inspect_output}" in
    *"No such object"* | *"No such container"*)
      printf 'missing\n'
      return 0
      ;;
  esac
  return 1
}

session_require_live_detached_container() {
  local action="$1"
  local session_id="$2"
  local require_monitor_live="${3:-1}"
  local container_state=""

  session_require_detached_runtime_metadata "${action}" "${session_id}" || return 1
  case "${SESSION_META_LIVE_STATUS:-${SESSION_META_STATUS}}" in
    starting | running) ;;
    *)
      echo "session ${action} requires a detached session that is still running: ${session_id}" >&2
      return 1
      ;;
  esac
  if [[ "${require_monitor_live}" -eq 1 ]] && [[ -n "${SESSION_META_MONITOR_PID:-}" ]] && ! session_monitor_pid_is_live; then
    echo "session ${action} requires a live detached session monitor: ${session_id}" >&2
    return 1
  fi
  if ! container_state="$(session_container_live_state "${SESSION_META_PROFILE}" "${SESSION_META_CONTAINER_NAME}" 2>/dev/null)"; then
    echo "session ${action} could not confirm a live detached session: ${session_id}" >&2
    return 1
  fi
  if [[ "${container_state}" != "running" ]]; then
    echo "session ${action} requires a detached session that is still running: ${session_id}" >&2
    return 1
  fi
}

session_stop_request_marker_path() {
  local audit_dir="$1"

  printf '%s/%s\n' "${audit_dir}" "${SESSION_STOP_REQUEST_MARKER_NAME}"
}

session_record_stop_request_marker() {
  local marker_path=""

  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || {
    echo "Detached session stop requires a session audit directory." >&2
    return 1
  }
  marker_path="$(session_stop_request_marker_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    echo "Workcell blocked detached stop marker path after launch: ${marker_path}" >&2
    return 1
  fi
  mkdir -p "$(dirname "${marker_path}")"
  umask 077
  : >"${marker_path}"
  chmod 0600 "${marker_path}" 2>/dev/null || true
}

session_clear_stop_request_marker() {
  local marker_path=""

  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || return 0
  marker_path="$(session_stop_request_marker_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    echo "Workcell blocked detached stop marker path after launch: ${marker_path}" >&2
    return 1
  fi
  rm -f "${marker_path}"
}

session_stop_request_marker_exists() {
  local marker_path=""

  [[ -n "${SESSION_AUDIT_DIR:-}" ]] || return 1
  marker_path="$(session_stop_request_marker_path "${SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    return 1
  fi
  [[ -f "${marker_path}" ]]
}

session_write_stop_requested_terminal_record() {
  local record_path="$1"
  local exit_status="$2"
  local final_assurance="${SESSION_META_CURRENT_ASSURANCE:-}"

  [[ -n "${final_assurance}" ]] || final_assurance="managed-mutable"
  write_session_record "${record_path}" \
    "status=exited" \
    "live_status=stopped" \
    "observed_at=$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    "finished_at=$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    "exit_status=${exit_status}" \
    "current_assurance=${final_assurance}" \
    "final_assurance=${final_assurance}"
  session_clear_stop_request_marker
}

revalidate_recorded_host_output_path() {
  local recorded_path="$1"
  local resolved_path=""

  [[ -n "${recorded_path}" ]] || {
    echo "Recorded host output path is required." >&2
    return 1
  }
  if ! resolved_path="$(resolve_host_output_candidate "${recorded_path}")"; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  if [[ "${resolved_path}" != "${recorded_path}" ]]; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  printf '%s\n' "${resolved_path}"
}

revalidate_recorded_host_output_directory() {
  local recorded_path="$1"
  local resolved_path=""

  [[ -n "${recorded_path}" ]] || {
    echo "Recorded host output directory is required." >&2
    return 1
  }
  if ! resolved_path="$(resolve_host_output_directory_candidate "${recorded_path}")"; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  if [[ "${resolved_path}" != "${recorded_path}" ]]; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  printf '%s\n' "${resolved_path}"
}

write_session_monitor_env_file() {
  local path="$1"
  local var_name=""
  local -a exported_vars=(
    AGENT
    AGENT_AUTONOMY
    ALLOW_CONTROL_PLANE_VCS
    ALLOW_ENDPOINTS
    AUDIT_TRANSCRIPT_PATH
    BOOTSTRAP_APPLIED
    CACHE_PROFILE
    CODEX_RULES_MUTABILITY
    COLIMA_PROFILE
    COLIMA_STATE_ROOT
    CONTAINER_MUTABILITY
    CONTAINER_NAME
    DEBUG_LOG_PATH
    EXECUTION_PATH
    FILE_TRACE_LOG_PATH
    INJECTION_CREDENTIAL_KEYS
    INJECTION_CREDENTIAL_RESOLUTION_STATES
    INJECTION_POLICY_SHA256
    INJECTION_SECRET_COPY_TARGETS
    INJECTION_SHARED_AUTH_READY_STATES
    INJECTION_SSH_CONFIG_ASSURANCE
    INJECTION_SSH_ENABLED
    LOG_LEVEL
    MODE
    NETWORK_POLICY
    ROOT_DIR
    SESSION_AUDIT_DIR
    SESSION_AUDIT_STATE_FILE
    SESSION_FILE_TRACE_CONTAINER_FILE
    SESSION_ID
    SESSION_META_PROFILE
    SESSION_META_TARGET_KIND
    SESSION_META_TARGET_PROVIDER
    SESSION_META_TARGET_ID
    SESSION_META_TARGET_ASSURANCE_CLASS
    SESSION_RECORD_PATH
    SESSION_RECORD_WRITTEN
    SESSION_RECORD_FINALIZED
    SESSION_MONITOR_READY_PATH
    UI
    WORKCELL_COLIMA_START_TIMEOUT_SECONDS
    WORKCELL_STATE_ROOT
    WORKCELL_TARGET_STATE_ROOT
    XDG_STATE_HOME
    WORKSPACE
  )

  mkdir -p "$(dirname "${path}")"
  umask 077
  : >"${path}"
  chmod 0600 "${path}" 2>/dev/null || true
  for var_name in "${exported_vars[@]}"; do
    printf '%s=%q\n' "${var_name}" "${!var_name-}" >>"${path}"
  done
}

wait_for_session_monitor_ready() {
  local monitor_pid="$1"
  local ready_path="$2"
  local attempt=0

  while [[ "${attempt}" -lt 50 ]]; do
    if [[ -f "${ready_path}" ]] && kill -0 "${monitor_pid}" >/dev/null 2>&1; then
      return 0
    fi
    if ! kill -0 "${monitor_pid}" >/dev/null 2>&1; then
      return 1
    fi
    sleep 0.1
    attempt=$((attempt + 1))
  done
  [[ -f "${ready_path}" ]] && kill -0 "${monitor_pid}" >/dev/null 2>&1
}

session_monitor_wait_status() {
  local wait_status=""

  wait_status="$(run_profile_docker_command "${COLIMA_PROFILE}" wait "${CONTAINER_NAME}" 2>/dev/null || true)"
  wait_status="$(printf '%s\n' "${wait_status}" | tr -d '\r' | tail -n1)"
  if [[ "${wait_status}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${wait_status}"
    return 0
  fi

  wait_status="$(run_profile_docker_command "${COLIMA_PROFILE}" inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}" 2>/dev/null || true)"
  wait_status="$(printf '%s\n' "${wait_status}" | tr -d '\r' | tail -n1)"
  [[ "${wait_status}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${wait_status}"
}

read_latest_log_pointer() {
  local profile="$1"
  local kind="$2"
  local pointer_path=""
  local resolved_pointer_path=""
  local -a candidates=()

  candidates=(
    "$(profile_latest_log_pointer_path "${profile}" "${kind}")"
    "$(legacy_profile_latest_log_pointer_path "${profile}" "${kind}")"
  )
  for pointer_path in "${candidates[@]}"; do
    if ! resolved_pointer_path="$(resolve_host_output_candidate "${pointer_path}")"; then
      echo "Workcell blocked latest ${kind} pointer path after launch: ${pointer_path}" >&2
      return 1
    fi
    [[ -f "${resolved_pointer_path}" ]] || continue
    head -n1 "${resolved_pointer_path}"
    return 0
  done
  return 1
}

cleanup_stale_latest_log_pointers() {
  local state_root="$1"
  local legacy_root="${2:-}"

  go_hostutil helper cleanup-stale-log-pointers "${state_root}"
  if [[ -n "${legacy_root}" ]]; then
    go_hostutil helper cleanup-stale-log-pointers "${legacy_root}"
  fi
}

profile_lock_is_stale() {
  local lock_dir="$1"

  go_hostutil helper profile-lock-is-stale "${lock_dir}"
}

acquire_profile_lock() {
  local profile="$1"
  local lock_dir=""
  local lock_parent=""
  local acquired_state=""
  local stale_state=""
  local attempts=0

  lock_dir="$(profile_lock_dir_path "${profile}")"
  lock_parent="$(dirname "${lock_dir}")"
  mkdir -p "${lock_parent}"

  while true; do
    if ! acquired_state="$(go_hostutil helper acquire-profile-lock "${lock_dir}" "$$")"; then
      echo "Failed to create managed runtime lock for profile ${profile}." >&2
      return 1
    fi
    if [[ "${acquired_state}" == "1" ]]; then
      PROFILE_LOCK_DIR="${lock_dir}"
      return 0
    fi
    if ! stale_state="$(profile_lock_is_stale "${lock_dir}")"; then
      echo "Failed to inspect managed runtime lock state for profile ${profile}." >&2
      return 1
    fi
    if [[ "${stale_state}" == "1" ]]; then
      rm -rf "${lock_dir}"
      continue
    fi
    attempts=$((attempts + 1))
    if [[ "${attempts}" -eq 1 ]]; then
      echo "Waiting for the active Workcell session on profile ${profile} to release the managed runtime lock." >&2
    fi
    sleep 1
  done
}

cleanup_stale_session_audit_dirs() {
  local state_root="$1"
  local legacy_root="${2:-}"

  go_hostutil helper cleanup-stale-session-audit-dirs "${state_root}"
  if [[ -n "${legacy_root}" ]]; then
    go_hostutil helper cleanup-stale-session-audit-dirs "${legacy_root}"
  fi
}

file_is_trailing_suffix_of_file() {
  local suffix_path="$1"
  local file_path="$2"
  local suffix_size=""

  [[ -f "${suffix_path}" ]] || return 1
  [[ -f "${file_path}" ]] || return 1
  suffix_size="$(wc -c <"${suffix_path}" | tr -d '[:space:]')"
  [[ "${suffix_size}" =~ ^[0-9]+$ ]] || return 1
  [[ "${suffix_size}" -gt 0 ]] || return 1
  cmp -s "${suffix_path}" <(tail -c "${suffix_size}" "${file_path}" 2>/dev/null)
}

audit_record_digest() {
  local prev_digest="$1"
  local timestamp="$2"
  shift 2

  go_hostutil helper audit-digest "${prev_digest}" "${timestamp}" "$@"
}

stash_profile_audit_log() {
  local profile="$1"
  local target_audit_log=""
  local legacy_audit_log=""
  local preserved_any=0

  target_audit_log="$(profile_audit_log_path "${profile}")"
  legacy_audit_log="$(legacy_profile_audit_log_path "${profile}")"
  [[ -s "${legacy_audit_log}" ]] && preserved_any=1
  [[ -s "${target_audit_log}" ]] && preserved_any=1
  [[ "${preserved_any}" -eq 1 ]] || return 0

  PROFILE_AUDIT_LOG_STASH="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-log.XXXXXX")"
  : >"${PROFILE_AUDIT_LOG_STASH}"
  if [[ -s "${legacy_audit_log}" ]]; then
    cat "${legacy_audit_log}" >>"${PROFILE_AUDIT_LOG_STASH}"
  fi
  if [[ -s "${target_audit_log}" ]]; then
    cat "${target_audit_log}" >>"${PROFILE_AUDIT_LOG_STASH}"
  fi
  chmod 0600 "${PROFILE_AUDIT_LOG_STASH}" 2>/dev/null || true
}

restore_profile_audit_log() {
  local profile="$1"
  local audit_log=""
  local merged_log=""

  [[ -n "${PROFILE_AUDIT_LOG_STASH}" ]] || return 0
  [[ -f "${PROFILE_AUDIT_LOG_STASH}" ]] || {
    PROFILE_AUDIT_LOG_STASH=""
    return 0
  }

  audit_log="$(profile_audit_log_path "${profile}")"
  mkdir -p "$(dirname "${audit_log}")"
  if [[ -f "${audit_log}" ]] && [[ -s "${audit_log}" ]]; then
    if file_is_trailing_suffix_of_file "${audit_log}" "${PROFILE_AUDIT_LOG_STASH}"; then
      cp "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}"
    else
      merged_log="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-merged.XXXXXX")"
      cat "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}" >"${merged_log}"
      chmod 0600 "${merged_log}" 2>/dev/null || true
      mv "${merged_log}" "${audit_log}"
    fi
  else
    cp "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}"
  fi
  chmod 0600 "${audit_log}" 2>/dev/null || true
  rm -f "${PROFILE_AUDIT_LOG_STASH}"
  PROFILE_AUDIT_LOG_STASH=""
}

read_profile_marker_workspace() {
  local marker_path
  marker_path="$(profile_marker_read_path "$1")" || return 1
  [[ -f "${marker_path}" ]] || return 1
  tr -d '\n' <"${marker_path}"
}

append_audit_record() {
  local profile="$1"
  shift
  local audit_path=""

  audit_path="$(profile_audit_log_path "${profile}")"
  append_audit_record_to_path "${audit_path}" "$@"
}

append_audit_record_to_path() {
  local audit_path="$1"
  shift
  local timestamp
  local prev_digest=""
  local record_digest=""

  mkdir -p "$(dirname "${audit_path}")"
  umask 077
  touch "${audit_path}"
  chmod 0600 "${audit_path}" 2>/dev/null || true
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  if [[ -s "${audit_path}" ]]; then
    prev_digest="$(sed -n 's/.*record_digest=\([^ ]*\).*/\1/p' "${audit_path}" | tail -n1)"
  fi
  record_digest="$(audit_record_digest "${prev_digest}" "${timestamp}" "$@")"
  {
    printf 'timestamp=%q ' "${timestamp}"
    printf '%q ' "$@"
    [[ -n "${prev_digest}" ]] && printf 'prev_digest=%q ' "${prev_digest}"
    printf 'record_digest=%q ' "${record_digest}"
    printf '\n'
  } >>"${audit_path}"
}

maybe_fail_after_profile_refresh_for_tests() {
  if [[ "${TEST_FAIL_AFTER_PROFILE_REFRESH:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -z "${PROFILE_AUDIT_LOG_STASH}" ]]; then
    return 0
  fi
  echo "Workcell test hook: forcing failure after managed profile refresh." >&2
  exit 88
}

announce_strict_auto_prepare() {
  local headline="$1"
  local detail="${2:-}"

  if [[ "${STRICT_AUTO_PREPARE}" -eq 1 ]]; then
    return 0
  fi

  STRICT_AUTO_PREPARE=1
  PREPARE=1
  echo "${headline}" >&2
  if [[ -n "${detail}" ]]; then
    echo "${detail}" >&2
  fi
  echo "Workcell will seed or refresh the prepared runtime image automatically before launching ${AGENT} in strict mode." >&2
  echo "Use --prepare-only if you want to prewarm the image without launching a session." >&2
}

