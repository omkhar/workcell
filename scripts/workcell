ALLOW_NONGIT_WORKSPACE=0
ALLOW_ARBITRARY_COMMAND=0
ACK_BREAKGLASS=0
ACK_ARBITRARY_COMMAND=0
TEST_FAIL_AFTER_PROFILE_REFRESH=0
declare -a AGENT_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      AGENT="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --agent-autonomy)
      AGENT_AUTONOMY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --agent-arg)
      AGENT_ARGS+=("$(raw_option_value_or_die "$1" "${2-}")")
      shift 2
      ;;
    --codex-rules-mutability)
      CODEX_RULES_MUTABILITY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-mutability)
      CONTAINER_MUTABILITY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-cpu)
      CONTAINER_CPU_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-memory)
      CONTAINER_MEMORY_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --injection-policy)
      INJECTION_POLICY="$(raw_option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --no-default-injection-policy)
      USE_DEFAULT_INJECTION_POLICY=0
      shift
      ;;
    --ui)
      UI="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --mode)
      MODE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --workspace)
      WORKSPACE="$(resolve_existing_directory_or_die "$(option_value_or_die "$1" "${2-}")")"
      shift 2
      ;;
    --colima-profile)
      COLIMA_PROFILE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --vm-cpu)
      VM_CPU_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --vm-memory)
      VM_MEMORY_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --vm-disk)
      VM_DISK_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --prepare)
      PREPARE=1
      shift
      ;;
    --repair-profile)
      REPAIR_PROFILE=1
      shift
      ;;
    --test-fail-after-profile-refresh)
      TEST_FAIL_AFTER_PROFILE_REFRESH=1
      shift
      ;;
    --allow-nongit-workspace)
      ALLOW_NONGIT_WORKSPACE=1
      shift
      ;;
    --allow-arbitrary-command)
      ALLOW_ARBITRARY_COMMAND=1
      shift
      ;;
    --ack-breakglass)
      ACK_BREAKGLASS=1
      shift
      ;;
    --ack-arbitrary-command)
      ACK_ARBITRARY_COMMAND=1
      shift
      ;;
    --rebuild)
      REBUILD=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

validate_agent_autonomy_name "${AGENT_AUTONOMY}"
validate_codex_rules_mutability_name "${CODEX_RULES_MUTABILITY}"
declare -a PROVIDER_ARGS=()
if ((${#AGENT_ARGS[@]} > 0)); then
  PROVIDER_ARGS=("${AGENT_ARGS[@]}")
fi
if [[ $# -gt 0 ]]; then
  PROVIDER_ARGS+=("$@")
fi
if ((${#PROVIDER_ARGS[@]} > 0)); then
  set -- "${PROVIDER_ARGS[@]}"
else
  set --
fi

if [[ "${ALLOW_ARBITRARY_COMMAND}" -eq 0 ]] && [[ $# -gt 0 ]] && [[ "$1" != "${AGENT}" ]]; then
  set -- "${AGENT}" "$@"
fi

if [[ -z "${AGENT}" ]]; then
  echo "Option --agent is required." >&2
  usage >&2
  exit 2
fi

case "${AGENT}" in
  codex | claude | gemini) ;;
  *)
    echo "Unsupported agent: ${AGENT}" >&2
    exit 2
    ;;
esac

case "${UI}" in
  cli) ;;
  gui)
    echo "GUI mode is not implemented yet as a preserved-boundary path." >&2
    exit 2
    ;;
  *)
    echo "Unsupported UI mode: ${UI}" >&2
    exit 2
    ;;
esac

if [[ "${REPAIR_PROFILE}" -eq 1 ]] && [[ "${MODE}" == "strict" ]]; then
  PREPARE=1
fi

validate_mode_name "${MODE}"
validate_container_mutability "${CONTAINER_MUTABILITY}"
PROFILE_ENV="$(profile_env_path "${MODE}")"
[[ -f "${PROFILE_ENV}" ]] || {
  echo "Missing runtime profile: ${PROFILE_ENV}" >&2
  exit 1
}

# shellcheck source=/dev/null
source "${PROFILE_ENV}"
if [[ -n "${VM_CPU_OVERRIDE}" ]]; then
  COLIMA_CPU="${VM_CPU_OVERRIDE}"
fi
if [[ -n "${VM_MEMORY_OVERRIDE}" ]]; then
  COLIMA_MEMORY="${VM_MEMORY_OVERRIDE}"
fi
if [[ -n "${VM_DISK_OVERRIDE}" ]]; then
  COLIMA_DISK="${VM_DISK_OVERRIDE}"
fi
if [[ -n "${CONTAINER_MEMORY_OVERRIDE}" ]]; then
  CONTAINER_MEMORY="${CONTAINER_MEMORY_OVERRIDE}"
fi
validate_positive_integer "VM CPU count" "${COLIMA_CPU}"
validate_positive_integer "VM memory size (GiB)" "${COLIMA_MEMORY}"
validate_positive_integer "VM disk size (GiB)" "${COLIMA_DISK}"
validate_container_memory_value "${CONTAINER_MEMORY}"
if [[ -n "${CONTAINER_CPU_OVERRIDE}" ]]; then
  validate_positive_decimal "container CPU limit" "${CONTAINER_CPU_OVERRIDE}"
fi
HOST_GIT_BIN="$(resolve_host_tool git /usr/bin/git /opt/homebrew/bin/git /usr/local/bin/git)"
HOST_DOCKER_BIN="docker"
validate_workspace "${WORKSPACE}" "${ALLOW_NONGIT_WORKSPACE}"
validate_mode_requirements "${MODE}" "${ACK_BREAKGLASS}" "${ALLOW_ARBITRARY_COMMAND}" "${ACK_ARBITRARY_COMMAND}" "${REBUILD}" "${PREPARE}"
cleanup_stale_injection_bundles "$(default_injection_bundle_parent)"
prepare_injection_bundle "${AGENT}" "${MODE}"

if [[ -z "${COLIMA_PROFILE}" ]]; then
  COLIMA_PROFILE="$(derive_profile_name "${WORKSPACE}")"
fi
validate_colima_profile_name "${COLIMA_PROFILE}"

IMAGE_TAG="workcell:local"
PROFILE_DIR="$(profile_dir "${COLIMA_PROFILE}")"
PROFILE_MARKER="$(profile_marker_path "${COLIMA_PROFILE}")"
PROFILE_IMAGE_MARKER="$(profile_image_marker_path "${COLIMA_PROFILE}")"
PROFILE_PREEXISTED=0
PROFILE_MARKER_WORKSPACE=""
BOOTSTRAP_ENDPOINTS="$(bootstrap_endpoints)"
EGRESS_HELPER="${ROOT_DIR}/scripts/colima-egress-allowlist.sh"
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
HOST_USER="$(id -un 2>/dev/null || printf 'agent')"
SOURCE_DATE_EPOCH="$("${HOST_GIT_BIN}" -C "${ROOT_DIR}" log -1 --pretty=%ct 2>/dev/null || printf '0')"
NEEDS_REBUILD=0

if [[ -n "${WORKCELL_EGRESS_HELPER:-}" ]]; then
  echo "WORKCELL_EGRESS_HELPER is reserved for the Workcell test harness." >&2
  exit 2
fi

if [[ -d "${PROFILE_DIR}" ]]; then
  PROFILE_PREEXISTED=1
fi

if [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && [[ ! -f "${PROFILE_MARKER}" ]]; then
  if [[ "${REPAIR_PROFILE}" -eq 1 ]]; then
    delete_unmanaged_profile "${COLIMA_PROFILE}"
    PROFILE_PREEXISTED=0
  else
    echo "Refusing to reuse unmanaged Colima profile: ${COLIMA_PROFILE}" >&2
    echo "Workcell found a profile with the right name but without Workcell ownership metadata." >&2
    echo "That profile might carry broader mounts, credentials, or network state than the reviewed path allows." >&2
    echo "Next step:" >&2
    if [[ "${MODE}" == "strict" ]]; then
      build_recommended_command 1 1 "${MODE}"
    else
      build_recommended_command 0 1 "${MODE}"
    fi
    echo "Manual cleanup, if you prefer to inspect and delete it yourself:" >&2
    printf '  colima delete --profile %q --force\n' "${COLIMA_PROFILE}" >&2
    printf '  rm -rf %q %q\n' "${PROFILE_DIR}" "$(profile_lima_dir "${COLIMA_PROFILE}")" >&2
    exit 2
  fi
fi

if [[ -f "${PROFILE_MARKER}" ]]; then
  PROFILE_MARKER_WORKSPACE="$(read_profile_marker_workspace "${COLIMA_PROFILE}" || true)"
fi

if [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && [[ -z "${PROFILE_MARKER_WORKSPACE}" ]]; then
  echo "Refusing to reuse managed Colima profile without a recorded workspace binding: ${COLIMA_PROFILE}" >&2
  exit 2
fi

if [[ -n "${PROFILE_MARKER_WORKSPACE}" ]] && [[ "${PROFILE_MARKER_WORKSPACE}" != "${WORKSPACE}" ]]; then
  echo "Refusing to reuse Colima profile ${COLIMA_PROFILE} for a different workspace." >&2
  echo "Recorded workspace: ${PROFILE_MARKER_WORKSPACE}" >&2
  echo "Requested workspace: ${WORKSPACE}" >&2
  exit 2
fi

if [[ "${DRY_RUN}" -eq 0 ]] && [[ "${MODE}" == "strict" ]] && [[ "${PREPARE}" -eq 0 ]] && [[ ! -f "${PROFILE_IMAGE_MARKER}" ]]; then
  echo "No reviewed runtime image is recorded for strict mode on profile ${COLIMA_PROFILE}." >&2
  echo "This is expected on the first launch for a workspace or after profile cleanup." >&2
  echo "Next step:" >&2
  build_recommended_command 1 0 "${MODE}"
  echo "That command seeds the reviewed runtime image inside the isolated VM and then launches ${AGENT} in strict mode." >&2
  echo "No VM or container was started." >&2
  exit 2
fi

if [[ "${DRY_RUN}" -eq 0 ]]; then
  HOST_COLIMA_BIN="$(resolve_host_tool colima /opt/homebrew/bin/colima /usr/local/bin/colima)"
  HOST_DOCKER_BIN="$(resolve_host_tool docker /opt/homebrew/bin/docker /usr/local/bin/docker /Applications/Docker.app/Contents/Resources/bin/docker)"
  HOST_RUBY_BIN="$(resolve_host_tool ruby /usr/bin/ruby /opt/homebrew/bin/ruby /usr/local/bin/ruby)"
  sanitize_host_docker_env
  export COLIMA_HOME="${COLIMA_STATE_ROOT}"
fi

ALLOW_ENDPOINTS="$(provider_endpoints "${AGENT}") ${EXTRA_ENDPOINTS}"
if [[ "${CONTAINER_MUTABILITY}" == "ephemeral" ]]; then
  ALLOW_ENDPOINTS="${ALLOW_ENDPOINTS} snapshot.debian.org:80 snapshot.debian.org:443"
fi
prepare_workspace_control_plane_shadow "${WORKSPACE}" "${MODE}"

CONTAINER_NAME="workcell-$(slugify "${AGENT}-${MODE}-$(basename "${WORKSPACE}")")-$(generate_session_suffix)"
DOCKER_RUN_BASE=(
  "${HOST_DOCKER_BIN}"
  run
  --init
  --name "${CONTAINER_NAME}"
  --security-opt no-new-privileges:true
  --cap-drop ALL
  --pids-limit 1024
  --memory "${CONTAINER_MEMORY}"
  --tmpfs "/tmp:nosuid,nodev,noexec,size=1g,mode=1777"
  --tmpfs "/run:nosuid,nodev,size=64m,mode=755"
  --tmpfs "/state:exec,nosuid,nodev,size=1g,mode=1777"
  --workdir /workspace
  -e AGENT_NAME="${AGENT}"
  -e WORKCELL_AGENT_AUTONOMY="${AGENT_AUTONOMY}"
  -e WORKCELL_CODEX_RULES_MUTABILITY="${CODEX_RULES_MUTABILITY}"
  -e WORKCELL_CONTAINER_MUTABILITY="${CONTAINER_MUTABILITY}"
  -e AGENT_UI="${UI}"
  -e CODEX_PROFILE="${MODE}"
  -e WORKCELL_MODE="${MODE}"
  -e HOME=/state/agent-home
  -e CODEX_HOME=/state/agent-home/.codex
  -e WORKCELL_RUNTIME=1
  -e TMPDIR=/state/tmp
  -e WORKSPACE=/workspace
  -e WORKCELL_WORKSPACE_IMPORT_ROOT=/opt/workcell/workspace-control-plane
  -v "${WORKSPACE}:/workspace"
)
if [[ "${CONTAINER_MUTABILITY}" == "readonly" ]]; then
  DOCKER_RUN_BASE+=(
    --read-only
    --user "${HOST_UID}:${HOST_GID}"
    -e USER=agent
    -e LOGNAME=agent
  )
else
  DOCKER_RUN_BASE+=(
    # Mutable sessions still drop the default capability set, but need the
    # minimal handoff capabilities required to re-exec as the mapped runtime
    # user.
    --cap-add SETUID
    --cap-add SETGID
    --user 0:0
    -e WORKCELL_HOST_UID="${HOST_UID}"
    -e WORKCELL_HOST_GID="${HOST_GID}"
    -e WORKCELL_HOST_USER="${HOST_USER}"
  )
fi
if [[ -n "${CONTAINER_CPU_OVERRIDE}" ]]; then
  DOCKER_RUN_BASE+=(--cpus "${CONTAINER_CPU_OVERRIDE}")
fi
if ((${#SHADOW_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${SHADOW_MOUNTS[@]}")
fi
if ((${#WORKSPACE_IMPORT_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${WORKSPACE_IMPORT_MOUNTS[@]}")
fi
if ((${#DIRECT_SOURCE_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${DIRECT_SOURCE_MOUNTS[@]}")
fi
if [[ -n "${INJECTION_BUNDLE_ROOT}" ]]; then
  DOCKER_RUN_BASE+=(
    -e WORKCELL_INJECTION_MANIFEST=/opt/workcell/host-injections/manifest.json
    -v "${INJECTION_BUNDLE_ROOT}:/opt/workcell/host-injections:ro"
  )
fi
if [[ "${DRY_RUN}" -eq 0 ]]; then
  prepare_session_audit_state "${COLIMA_PROFILE}"
fi

EXECUTION_PATH="managed-tier1"
if [[ "${MODE}" == "breakglass" ]]; then
  EXECUTION_PATH="lower-assurance-breakglass"
fi

if [[ "${ALLOW_ARBITRARY_COMMAND}" -eq 1 ]]; then
  if [[ $# -eq 0 ]]; then
    echo "arbitrary command mode requires a command after --." >&2
    exit 2
  fi
  EXECUTION_PATH="lower-assurance-debug-command"
  DOCKER_RUN=(
    "${DOCKER_RUN_BASE[@]}"
    --entrypoint "$1"
    "${IMAGE_TAG}"
  )
  shift
  if [[ $# -gt 0 ]]; then
    DOCKER_RUN+=("$@")
  fi
else
  DOCKER_RUN=(
    "${DOCKER_RUN_BASE[@]}"
    "${IMAGE_TAG}"
  )
  if [[ $# -gt 0 ]]; then
    DOCKER_RUN+=("$@")
  fi
fi

if [[ -t 0 ]] && [[ -t 1 ]]; then
  DOCKER_RUN=("${HOST_DOCKER_BIN}" run --init -it "${DOCKER_RUN[@]:3}")
fi

printf 'profile=%s mode=%s agent=%s ui=%s workspace=%s\n' \
  "${COLIMA_PROFILE}" "${MODE}" "${AGENT}" "${UI}" "${WORKSPACE}" >&2
printf 'agent_autonomy=%s\n' "${AGENT_AUTONOMY}" >&2
printf 'vm_resources=cpu=%s memory_gib=%s disk_gib=%s\n' "${COLIMA_CPU}" "${COLIMA_MEMORY}" "${COLIMA_DISK}" >&2
printf 'container_resources=mutability=%s cpu=%s memory=%s\n' \
  "${CONTAINER_MUTABILITY}" "${CONTAINER_CPU_OVERRIDE:-unmanaged}" "${CONTAINER_MEMORY}" >&2
printf 'container_assurance=%s\n' "$(container_assurance)" >&2
printf 'autonomy_assurance=%s\n' "$(autonomy_assurance)" >&2
printf 'codex_rules_mutability_configured=%s\n' "${CODEX_RULES_MUTABILITY}" >&2
printf 'codex_rules_assurance_configured=%s\n' "$(codex_rules_assurance)" >&2
printf 'codex_rules_mutability_effective_initial=%s\n' "$(codex_rules_effective_mutability_initial)" >&2
printf 'codex_rules_assurance_effective_initial=%s\n' "$(codex_rules_effective_assurance_initial)" >&2
printf 'session_assurance_initial=%s\n' "$(session_assurance_initial)" >&2
printf 'workspace_control_plane=%s\n' "$([[ "${MODE}" == "breakglass" ]] && printf 'unmasked' || printf 'masked')" >&2
printf 'network_policy=%s endpoints=%s\n' "${NETWORK_POLICY}" "${ALLOW_ENDPOINTS}" >&2
printf 'execution_path=%s audit_log=%s\n' "${EXECUTION_PATH}" "$(profile_audit_log_path "${COLIMA_PROFILE}")" >&2

if [[ "${DRY_RUN}" -eq 1 ]]; then
  emit_redacted_command "${DOCKER_RUN[@]}"
  exit 0
fi

if [[ "${PROFILE_PREEXISTED}" -eq 1 ]]; then
  if ! validate_colima_profile_config "${COLIMA_PROFILE}" "${WORKSPACE}" "${COLIMA_CPU}" "${COLIMA_MEMORY}" "${COLIMA_DISK}"; then
    echo "Refreshing managed Colima profile ${COLIMA_PROFILE} to apply the requested reviewed VM resources." >&2
    stash_profile_audit_log "${COLIMA_PROFILE}"
    run_host_colima delete --profile "${COLIMA_PROFILE}" --force >/dev/null 2>&1 || true
    rm -rf "${PROFILE_DIR}"
    PROFILE_PREEXISTED=0
  elif ! validate_colima_runtime_mounts "${COLIMA_PROFILE}" "${WORKSPACE}"; then
    echo "Refreshing managed Colima profile ${COLIMA_PROFILE} to discard stale runtime mounts." >&2
    stash_profile_audit_log "${COLIMA_PROFILE}"
    run_host_colima delete --profile "${COLIMA_PROFILE}" --force >/dev/null 2>&1 || true
    rm -rf "${PROFILE_DIR}"
    PROFILE_PREEXISTED=0
  fi
fi

maybe_fail_after_profile_refresh_for_tests

run_host_colima start \
  --profile "${COLIMA_PROFILE}" \
  --vm-type vz \
  --mount "${WORKSPACE}:w" \
  --mount-type virtiofs \
  --runtime docker \
  --cpu "${COLIMA_CPU}" \
  --memory "${COLIMA_MEMORY}" \
  --disk "${COLIMA_DISK}" >/dev/null
PROFILE_RUNNING=1

validate_colima_profile "${COLIMA_PROFILE}" "${WORKSPACE}"
mkdir -p "${PROFILE_DIR}"
restore_profile_audit_log "${COLIMA_PROFILE}"
printf '%s\n' "${WORKSPACE}" >"${PROFILE_MARKER}"
PROFILE_VALIDATED=1

export DOCKER_HOST="unix://${COLIMA_STATE_ROOT}/${COLIMA_PROFILE}/docker.sock"

restore_runtime_egress() {
  if [[ "${NETWORK_POLICY}" == "allowlist" ]]; then
    "${EGRESS_HELPER}" apply "${COLIMA_PROFILE}" "${ALLOW_ENDPOINTS}"
  else
    "${EGRESS_HELPER}" clear "${COLIMA_PROFILE}"
  fi
}

RECORDED_IMAGE_ID="$(profile_image_marker_value "${COLIMA_PROFILE}" image_id || true)"
CURRENT_IMAGE_ID=""
if [[ "${REBUILD}" -eq 1 ]]; then
  NEEDS_REBUILD=1
else
  CURRENT_IMAGE_ID="$(current_image_id)"
  if [[ -z "${CURRENT_IMAGE_ID}" ]] || [[ -z "${RECORDED_IMAGE_ID}" ]] || [[ "${CURRENT_IMAGE_ID}" != "${RECORDED_IMAGE_ID}" ]]; then
    NEEDS_REBUILD=1
  fi
fi

if [[ "${MODE}" == "strict" ]] && [[ "${NEEDS_REBUILD}" -eq 1 ]] && [[ "${PREPARE}" -eq 0 ]]; then
  restore_runtime_egress
  echo "Strict mode needs a prepared reviewed runtime image for profile ${COLIMA_PROFILE}." >&2
  echo "The profile started successfully, but the runtime image is missing or stale." >&2
  echo "Next step:" >&2
  build_recommended_command 1 0 "${MODE}"
  exit 2
fi

if [[ "${NETWORK_POLICY}" == "allowlist" ]] && [[ "${NEEDS_REBUILD}" -eq 1 ]]; then
  if [[ "${PREPARE}" -eq 1 ]]; then
    echo "prepare=1 seeding the reviewed runtime image before launch." >&2
  fi
  BOOTSTRAP_APPLIED=1
  printf 'bootstrap_policy=allowlist endpoints=%s\n' "${BOOTSTRAP_ENDPOINTS}" >&2
  "${EGRESS_HELPER}" apply "${COLIMA_PROFILE}" "${BOOTSTRAP_ENDPOINTS}"
elif [[ "${NETWORK_POLICY}" != "allowlist" ]]; then
  "${EGRESS_HELPER}" clear "${COLIMA_PROFILE}"
fi

if [[ "${NEEDS_REBUILD}" -eq 1 ]]; then
  BUILD_SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH}"
  BUILD_STATUS=0
  SOURCE_DATE_EPOCH="${BUILD_SOURCE_DATE_EPOCH}" buildx_cmd build \
    --build-arg "SOURCE_DATE_EPOCH=${BUILD_SOURCE_DATE_EPOCH}" \
    --provenance=false \
    --sbom=false \
    --load \
    -t "${IMAGE_TAG}" \
    -f "${ROOT_DIR}/runtime/container/Dockerfile" \
    "${ROOT_DIR}" >/dev/null || BUILD_STATUS=$?
  if [[ "${BUILD_STATUS}" -ne 0 ]]; then
    restore_runtime_egress
    exit "${BUILD_STATUS}"
  fi
  CURRENT_IMAGE_ID="$(current_image_id)"
  if [[ -z "${CURRENT_IMAGE_ID}" ]]; then
    restore_runtime_egress
    echo "Workcell failed to record the reviewed runtime image ID for ${IMAGE_TAG}." >&2
    exit 2
  fi
  write_profile_image_marker "${COLIMA_PROFILE}" "${CURRENT_IMAGE_ID}"
fi

restore_runtime_egress
append_launch_audit_record "${COLIMA_PROFILE}" "${EXECUTION_PATH}"

DOCKER_STATUS=0
"${HOST_DOCKER_BIN}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
"${DOCKER_RUN[@]}" || DOCKER_STATUS=$?
capture_session_audit_state "${CONTAINER_NAME}"
finalize_session_audit "${COLIMA_PROFILE}" "${EXECUTION_PATH}" "${DOCKER_STATUS}"
"${HOST_DOCKER_BIN}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
if [[ "${CONTAINER_MUTABILITY}" == "ephemeral" ]]; then
  echo "Workcell ephemeral runtime ended. Changes not persisted to /workspace or provided from the host control plane were discarded." >&2
fi
exit "${DOCKER_STATUS}"
