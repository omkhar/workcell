generate_session_id() {
  printf '%s-%s\n' "$(date -u '+%Y%m%dT%H%M%SZ')" "$(generate_session_suffix)"
}

profile_lock_dir_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/locks/%s.lock\n' "${COLIMA_STATE_ROOT}" "${profile}"
}

profile_latest_log_pointer_path() {
  local profile="$1"
  local kind="$2"

  validate_colima_profile_name "${profile}"
  case "${kind}" in
    debug | file-trace | transcript) ;;
    *)
      echo "Unsupported latest log pointer kind: ${kind}" >&2
      exit 2
      ;;
  esac
  printf '%s/workcell.latest-%s-log\n' "$(profile_dir "${profile}")" "${kind}"
}

write_latest_log_pointer() {
  local profile="$1"
  local kind="$2"
  local path="$3"
  local pointer_path=""
  local resolved_pointer_path=""

  [[ -n "${path}" ]] || return 0
  pointer_path="$(profile_latest_log_pointer_path "${profile}" "${kind}")"
  if ! resolved_pointer_path="$(resolve_host_output_candidate "${pointer_path}")"; then
    echo "Workcell blocked latest ${kind} pointer path after launch: ${pointer_path}" >&2
    return 1
  fi
  mkdir -p "$(dirname "${resolved_pointer_path}")"
  umask 077
  printf '%s\n' "${path}" >"${resolved_pointer_path}"
  chmod 0600 "${resolved_pointer_path}" 2>/dev/null || true
}

workspace_absolute_git_dir() {
  local workspace="$1"

  run_workspace_safe_git_command_in_dir "${workspace}" rev-parse --absolute-git-dir
}

default_session_workspace_mode() {
  if [[ "${SESSION_DETACHED}" -eq 1 ]]; then
    printf 'isolated\n'
    return 0
  fi
  printf 'direct\n'
}

effective_session_workspace_mode() {
  if [[ -n "${SESSION_WORKSPACE_MODE}" ]]; then
    printf '%s\n' "${SESSION_WORKSPACE_MODE}"
    return 0
  fi
  default_session_workspace_mode
}

session_workspace_parent_dir() {
  local source_workspace="$1"
  local git_dir=""

  git_dir="$(workspace_absolute_git_dir "${source_workspace}")"
  printf '%s/workcell-sessions\n' "${git_dir}"
}

isolated_session_workspace_path() {
  local source_workspace="$1"
  local session_id="$2"

  printf '%s/%s/repo\n' "$(session_workspace_parent_dir "${source_workspace}")" "${session_id}"
}

session_monitor_state_path() {
  local session_audit_dir="$1"

  printf '%s/session-monitor.env\n' "${session_audit_dir}"
}

session_monitor_ready_path() {
  local session_audit_dir="$1"

  printf '%s/session-monitor.ready\n' "${session_audit_dir}"
}

create_isolated_session_workspace() {
  local source_workspace="$1"
  local session_id="$2"
  local base_ref=""
  local target=""
  local branch_name=""

  workspace_is_git_worktree "${source_workspace}" || {
    echo "session start requires a git workspace when --session-workspace isolated is selected: ${source_workspace}" >&2
    exit 2
  }
  if ! workspace_gitdir_is_self_contained "${source_workspace}"; then
    echo "session start requires a self-contained git workspace for isolated session cloning: ${source_workspace}" >&2
    exit 2
  fi
  if workspace_git_has_worktree_changes "${source_workspace}"; then
    echo "session start requires a clean source workspace for isolated session cloning: ${source_workspace}" >&2
    exit 2
  fi

  base_ref="$(run_workspace_safe_git_command_in_dir "${source_workspace}" rev-parse --verify HEAD)"
  target="$(isolated_session_workspace_path "${source_workspace}" "${session_id}")"
  if ! target="$(resolve_host_output_candidate "${target}")"; then
    exit 2
  fi
  branch_name="workcell/session-${session_id}"

  [[ ! -e "${target}" ]] || {
    echo "Refusing to reuse an existing isolated session workspace: ${target}" >&2
    exit 2
  }

  mkdir -p "$(dirname "${target}")"
  run_clean_host_command_in_dir "${ROOT_DIR}" "${HOST_GIT_BIN}" clone --quiet --no-hardlinks "${source_workspace}" "${target}"
  run_workspace_safe_git_command_in_dir "${target}" checkout --quiet -B "${branch_name}" "${base_ref}"
  printf '%s\n' "${target}"
}

profile_docker_socket_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s/docker.sock\n' "${COLIMA_STATE_ROOT}" "${profile}"
}

run_profile_docker_command() {
  local profile="$1"
  local socket_path=""

  shift
  socket_path="$(profile_docker_socket_path "${profile}")"
  run_workcell_docker_client_command env DOCKER_HOST="unix://${socket_path}" "${HOST_DOCKER_BIN}" "$@"
}

append_session_control_audit_record() {
  local profile="$1"
  local session_id="$2"
  local event_name="$3"

  shift 3
  append_audit_record "${profile}" \
    "event=${event_name}" \
    "session_id=${session_id}" \
    "$@"
}

session_runtime_metadata() {
  local session_id="$1"

  go_hostutil launcher session-runtime-metadata "${COLIMA_STATE_ROOT}" "${session_id}"
}

load_session_runtime_metadata() {
  local session_id="$1"
  local line=""
  local key=""
  local value=""

  SESSION_META_PROFILE=""
  SESSION_META_WORKSPACE=""
  SESSION_META_WORKSPACE_ORIGIN=""
  SESSION_META_WORKTREE_PATH=""
  SESSION_META_CONTAINER_NAME=""
  SESSION_META_MONITOR_PID=""
  SESSION_META_STATUS=""
  SESSION_META_LIVE_STATUS=""
  SESSION_META_CURRENT_ASSURANCE=""
  SESSION_META_SESSION_AUDIT_DIR=""
  SESSION_META_AUDIT_LOG_PATH=""
  SESSION_META_DEBUG_LOG_PATH=""
  SESSION_META_FILE_TRACE_LOG_PATH=""
  SESSION_META_TRANSCRIPT_LOG_PATH=""

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "${key}" in
      profile) SESSION_META_PROFILE="${value}" ;;
      workspace) SESSION_META_WORKSPACE="${value}" ;;
      workspace_origin) SESSION_META_WORKSPACE_ORIGIN="${value}" ;;
      worktree_path) SESSION_META_WORKTREE_PATH="${value}" ;;
      container_name) SESSION_META_CONTAINER_NAME="${value}" ;;
      monitor_pid) SESSION_META_MONITOR_PID="${value}" ;;
      status) SESSION_META_STATUS="${value}" ;;
      live_status) SESSION_META_LIVE_STATUS="${value}" ;;
      current_assurance) SESSION_META_CURRENT_ASSURANCE="${value}" ;;
      session_audit_dir) SESSION_META_SESSION_AUDIT_DIR="${value}" ;;
      audit_log_path) SESSION_META_AUDIT_LOG_PATH="${value}" ;;
      debug_log_path) SESSION_META_DEBUG_LOG_PATH="${value}" ;;
      file_trace_log_path) SESSION_META_FILE_TRACE_LOG_PATH="${value}" ;;
      transcript_log_path) SESSION_META_TRANSCRIPT_LOG_PATH="${value}" ;;
    esac
  done < <(session_runtime_metadata "${session_id}")
}

session_record_matches_attached_workspace_shape() {
  [[ -n "${SESSION_META_WORKSPACE:-}" ]] || return 1
  [[ -n "${SESSION_META_WORKSPACE_ORIGIN:-}" ]] || return 1
  [[ "${SESSION_META_WORKSPACE_ORIGIN}" == "${SESSION_META_WORKSPACE}" ]] || return 1
  [[ -z "${SESSION_META_WORKTREE_PATH:-}" ]] || [[ "${SESSION_META_WORKTREE_PATH}" == "${SESSION_META_WORKSPACE}" ]]
}

session_record_has_legacy_live_detached_shape() {
  case "${SESSION_META_LIVE_STATUS:-${SESSION_META_STATUS:-}}" in
    starting | running | stopping)
      [[ -n "${SESSION_META_PROFILE:-}" ]] && [[ -n "${SESSION_META_CONTAINER_NAME:-}" ]] || return 1
      if session_record_matches_attached_workspace_shape; then
        return 1
      fi
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

session_require_detached_runtime_metadata() {
  local action="$1"
  local session_id="$2"
  local allow_legacy_live="${3:-0}"

  if [[ -n "${SESSION_META_MONITOR_PID:-}" ]]; then
    return 0
  fi
  if [[ "${allow_legacy_live}" -eq 1 ]] && session_record_has_legacy_live_detached_shape; then
    return 0
  fi
  echo "session ${action} only works for detached sessions started with 'workcell session start': ${session_id}" >&2
  echo "Use 'workcell session list' to check the control column; attached records are not stoppable." >&2
  return 1
}

session_monitor_pid_is_live() {
  local expected_state_file=""
  local monitor_command=""

  [[ "${SESSION_META_MONITOR_PID:-}" =~ ^[1-9][0-9]*$ ]] || return 1
  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || return 1
  kill -0 "${SESSION_META_MONITOR_PID}" >/dev/null 2>&1 || return 1
  expected_state_file="$(session_monitor_state_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  monitor_command="$(ps -o command= -p "${SESSION_META_MONITOR_PID}" 2>/dev/null | head -n1 || true)"
  [[ -n "${monitor_command}" ]] || return 1
  case "${monitor_command}" in
    *"${BASH_SOURCE[0]}"*" session monitor --state-file "*"${expected_state_file}"*) return 0 ;;
  esac
  return 1
}

session_container_live_state() {
  local profile="$1"
  local container_name="$2"

  run_profile_docker_command "${profile}" inspect \
    --format '{{if .State.Running}}running{{else}}stopped{{end}}' \
    "${container_name}"
}

session_container_exit_code() {
  local profile="$1"
  local container_name="$2"
  local exit_code=""

  exit_code="$(run_profile_docker_command "${profile}" inspect \
    --format '{{.State.ExitCode}}' \
    "${container_name}" 2>/dev/null || true)"
  exit_code="$(printf '%s\n' "${exit_code}" | tr -d '\r' | tail -n1)"
  [[ "${exit_code}" =~ ^[0-9]+$ ]] || exit_code="1"
  printf '%s\n' "${exit_code}"
}

session_container_state_for_delete() {
  local profile="$1"
  local container_name="$2"
  local inspect_output=""
  local inspect_status=0

  set +e
  inspect_output="$(run_profile_docker_command "${profile}" inspect \
    --format '{{if .State.Running}}running{{else}}stopped{{end}}' \
    "${container_name}" 2>&1)"
  inspect_status="$?"
  set -e
  inspect_output="$(printf '%s\n' "${inspect_output}" | tr -d '\r' | tail -n1)"
  if [[ "${inspect_status}" -eq 0 ]]; then
    case "${inspect_output}" in
      running | stopped)
        printf '%s\n' "${inspect_output}"
        return 0
        ;;
    esac
    return 1
  fi
  case "${inspect_output}" in
    *"No such object"* | *"No such container"*)
      printf 'missing\n'
      return 0
      ;;
  esac
  return 1
}

session_require_live_detached_container() {
  local action="$1"
  local session_id="$2"
  local require_monitor_live="${3:-1}"
  local container_state=""

  session_require_detached_runtime_metadata "${action}" "${session_id}" || return 1
  if [[ "${require_monitor_live}" -eq 1 ]] && [[ -n "${SESSION_META_MONITOR_PID:-}" ]] && ! session_monitor_pid_is_live; then
    echo "session ${action} requires a live detached session monitor: ${session_id}" >&2
    return 1
  fi
  case "${SESSION_META_LIVE_STATUS:-${SESSION_META_STATUS}}" in
    starting | running) ;;
    *)
      echo "session ${action} requires a detached session that is still running: ${session_id}" >&2
      return 1
      ;;
  esac
  if ! container_state="$(session_container_live_state "${SESSION_META_PROFILE}" "${SESSION_META_CONTAINER_NAME}" 2>/dev/null)"; then
    echo "session ${action} could not confirm a live detached session: ${session_id}" >&2
    return 1
  fi
  if [[ "${container_state}" != "running" ]]; then
    echo "session ${action} requires a detached session that is still running: ${session_id}" >&2
    return 1
  fi
}

session_stop_request_marker_path() {
  local audit_dir="$1"

  printf '%s/%s\n' "${audit_dir}" "${SESSION_STOP_REQUEST_MARKER_NAME}"
}

session_record_stop_request_marker() {
  local marker_path=""

  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || {
    echo "Detached session stop requires a session audit directory." >&2
    return 1
  }
  marker_path="$(session_stop_request_marker_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    echo "Workcell blocked detached stop marker path after launch: ${marker_path}" >&2
    return 1
  fi
  mkdir -p "$(dirname "${marker_path}")"
  umask 077
  : >"${marker_path}"
  chmod 0600 "${marker_path}" 2>/dev/null || true
}

session_clear_stop_request_marker() {
  local marker_path=""

  [[ -n "${SESSION_META_SESSION_AUDIT_DIR:-}" ]] || return 0
  marker_path="$(session_stop_request_marker_path "${SESSION_META_SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    echo "Workcell blocked detached stop marker path after launch: ${marker_path}" >&2
    return 1
  fi
  rm -f "${marker_path}"
}

session_stop_request_marker_exists() {
  local marker_path=""

  [[ -n "${SESSION_AUDIT_DIR:-}" ]] || return 1
  marker_path="$(session_stop_request_marker_path "${SESSION_AUDIT_DIR}")"
  if ! marker_path="$(resolve_host_output_candidate "${marker_path}")"; then
    return 1
  fi
  [[ -f "${marker_path}" ]]
}

session_write_stop_requested_terminal_record() {
  local record_path="$1"
  local exit_status="$2"
  local final_assurance="${SESSION_META_CURRENT_ASSURANCE:-}"

  [[ -n "${final_assurance}" ]] || final_assurance="managed-mutable"
  write_session_record "${record_path}" \
    "status=exited" \
    "live_status=stopped" \
    "observed_at=$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    "finished_at=$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    "exit_status=${exit_status}" \
    "current_assurance=${final_assurance}" \
    "final_assurance=${final_assurance}"
  session_clear_stop_request_marker
}

revalidate_recorded_host_output_path() {
  local recorded_path="$1"
  local resolved_path=""

  [[ -n "${recorded_path}" ]] || {
    echo "Recorded host output path is required." >&2
    return 1
  }
  if ! resolved_path="$(resolve_host_output_candidate "${recorded_path}")"; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  if [[ "${resolved_path}" != "${recorded_path}" ]]; then
    echo "Workcell blocked host output path after launch: ${recorded_path}" >&2
    return 1
  fi
  printf '%s\n' "${resolved_path}"
}

write_session_monitor_env_file() {
  local path="$1"
  local var_name=""
  local -a exported_vars=(
    AGENT
    AGENT_AUTONOMY
    ALLOW_CONTROL_PLANE_VCS
    ALLOW_ENDPOINTS
    AUDIT_TRANSCRIPT_PATH
    BOOTSTRAP_APPLIED
    CACHE_PROFILE
    CODEX_RULES_MUTABILITY
    COLIMA_PROFILE
    COLIMA_STATE_ROOT
    CONTAINER_MUTABILITY
    CONTAINER_NAME
    DEBUG_LOG_PATH
    EXECUTION_PATH
    FILE_TRACE_LOG_PATH
    INJECTION_CREDENTIAL_KEYS
    INJECTION_CREDENTIAL_RESOLUTION_STATES
    INJECTION_POLICY_SHA256
    INJECTION_SECRET_COPY_TARGETS
    INJECTION_SHARED_AUTH_READY_STATES
    INJECTION_SSH_CONFIG_ASSURANCE
    INJECTION_SSH_ENABLED
    LOG_LEVEL
    MODE
    NETWORK_POLICY
    ROOT_DIR
    SESSION_AUDIT_DIR
    SESSION_AUDIT_STATE_FILE
    SESSION_FILE_TRACE_CONTAINER_FILE
    SESSION_ID
    SESSION_RECORD_PATH
    SESSION_RECORD_WRITTEN
    SESSION_RECORD_FINALIZED
    SESSION_MONITOR_READY_PATH
    UI
    WORKSPACE
  )

  mkdir -p "$(dirname "${path}")"
  umask 077
  : >"${path}"
  chmod 0600 "${path}" 2>/dev/null || true
  for var_name in "${exported_vars[@]}"; do
    printf '%s=%q\n' "${var_name}" "${!var_name-}" >>"${path}"
  done
}

wait_for_session_monitor_ready() {
  local monitor_pid="$1"
  local ready_path="$2"
  local attempt=0

  while [[ "${attempt}" -lt 50 ]]; do
    if [[ -f "${ready_path}" ]] && kill -0 "${monitor_pid}" >/dev/null 2>&1; then
      return 0
    fi
    if ! kill -0 "${monitor_pid}" >/dev/null 2>&1; then
      return 1
    fi
    sleep 0.1
    attempt=$((attempt + 1))
  done
  [[ -f "${ready_path}" ]] && kill -0 "${monitor_pid}" >/dev/null 2>&1
}

session_monitor_wait_status() {
  local wait_status=""

  wait_status="$(run_profile_docker_command "${COLIMA_PROFILE}" wait "${CONTAINER_NAME}" 2>/dev/null || true)"
  wait_status="$(printf '%s\n' "${wait_status}" | tr -d '\r' | tail -n1)"
  if [[ "${wait_status}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${wait_status}"
    return 0
  fi

  wait_status="$(run_profile_docker_command "${COLIMA_PROFILE}" inspect --format '{{.State.ExitCode}}' "${CONTAINER_NAME}" 2>/dev/null || true)"
  wait_status="$(printf '%s\n' "${wait_status}" | tr -d '\r' | tail -n1)"
  [[ "${wait_status}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${wait_status}"
}

read_latest_log_pointer() {
  local profile="$1"
  local kind="$2"
  local pointer_path=""
  local resolved_pointer_path=""

  pointer_path="$(profile_latest_log_pointer_path "${profile}" "${kind}")"
  if ! resolved_pointer_path="$(resolve_host_output_candidate "${pointer_path}")"; then
    echo "Workcell blocked latest ${kind} pointer path after launch: ${pointer_path}" >&2
    return 1
  fi
  [[ -f "${resolved_pointer_path}" ]] || return 1
  head -n1 "${resolved_pointer_path}"
}

cleanup_stale_latest_log_pointers() {
  local colima_root="$1"

  go_hostutil launcher cleanup-stale-log-pointers "${colima_root}"
}

profile_lock_is_stale() {
  local lock_dir="$1"

  go_hostutil launcher profile-lock-is-stale "${lock_dir}"
}

acquire_profile_lock() {
  local profile="$1"
  local lock_dir=""
  local lock_parent=""
  local acquired_state=""
  local stale_state=""
  local attempts=0

  lock_dir="$(profile_lock_dir_path "${profile}")"
  lock_parent="$(dirname "${lock_dir}")"
  mkdir -p "${lock_parent}"

  while true; do
    if ! acquired_state="$(go_hostutil launcher acquire-profile-lock "${lock_dir}" "$$")"; then
      echo "Failed to create managed runtime lock for profile ${profile}." >&2
      return 1
    fi
    if [[ "${acquired_state}" == "1" ]]; then
      PROFILE_LOCK_DIR="${lock_dir}"
      return 0
    fi
    if ! stale_state="$(profile_lock_is_stale "${lock_dir}")"; then
      echo "Failed to inspect managed runtime lock state for profile ${profile}." >&2
      return 1
    fi
    if [[ "${stale_state}" == "1" ]]; then
      rm -rf "${lock_dir}"
      continue
    fi
    attempts=$((attempts + 1))
    if [[ "${attempts}" -eq 1 ]]; then
      echo "Waiting for the active Workcell session on profile ${profile} to release the managed runtime lock." >&2
    fi
    sleep 1
  done
}

cleanup_stale_session_audit_dirs() {
  local colima_root="$1"

  go_hostutil launcher cleanup-stale-session-audit-dirs "${colima_root}"
}

audit_record_digest() {
  local prev_digest="$1"
  local timestamp="$2"
  shift 2

  go_hostutil launcher audit-digest "${prev_digest}" "${timestamp}" "$@"
}

stash_profile_audit_log() {
  local profile="$1"
  local audit_log=""

  audit_log="$(profile_audit_log_path "${profile}")"
  [[ -f "${audit_log}" ]] || return 0

  PROFILE_AUDIT_LOG_STASH="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-log.XXXXXX")"
  cp "${audit_log}" "${PROFILE_AUDIT_LOG_STASH}"
  chmod 0600 "${PROFILE_AUDIT_LOG_STASH}" 2>/dev/null || true
}

restore_profile_audit_log() {
  local profile="$1"
  local audit_log=""
  local merged_log=""

  [[ -n "${PROFILE_AUDIT_LOG_STASH}" ]] || return 0
  [[ -f "${PROFILE_AUDIT_LOG_STASH}" ]] || {
    PROFILE_AUDIT_LOG_STASH=""
    return 0
  }

  audit_log="$(profile_audit_log_path "${profile}")"
  mkdir -p "$(dirname "${audit_log}")"
  if [[ -f "${audit_log}" ]] && [[ -s "${audit_log}" ]]; then
    merged_log="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-merged.XXXXXX")"
    cat "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}" >"${merged_log}"
    chmod 0600 "${merged_log}" 2>/dev/null || true
    mv "${merged_log}" "${audit_log}"
  else
    cp "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}"
  fi
  chmod 0600 "${audit_log}" 2>/dev/null || true
  rm -f "${PROFILE_AUDIT_LOG_STASH}"
  PROFILE_AUDIT_LOG_STASH=""
}

read_profile_marker_workspace() {
  local marker_path
  marker_path="$(profile_marker_path "$1")"
  [[ -f "${marker_path}" ]] || return 1
  tr -d '\n' <"${marker_path}"
}

append_audit_record() {
  local profile="$1"
  shift
  local audit_path
  local timestamp
  local prev_digest=""
  local record_digest=""

  audit_path="$(profile_audit_log_path "${profile}")"
  mkdir -p "$(dirname "${audit_path}")"
  umask 077
  touch "${audit_path}"
  chmod 0600 "${audit_path}" 2>/dev/null || true
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  if [[ -s "${audit_path}" ]]; then
    prev_digest="$(sed -n 's/.*record_digest=\([^ ]*\).*/\1/p' "${audit_path}" | tail -n1)"
  fi
  record_digest="$(audit_record_digest "${prev_digest}" "${timestamp}" "$@")"
  {
    printf 'timestamp=%q ' "${timestamp}"
    printf '%q ' "$@"
    [[ -n "${prev_digest}" ]] && printf 'prev_digest=%q ' "${prev_digest}"
    printf 'record_digest=%q ' "${record_digest}"
    printf '\n'
  } >>"${audit_path}"
}

maybe_fail_after_profile_refresh_for_tests() {
  if [[ "${TEST_FAIL_AFTER_PROFILE_REFRESH:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -z "${PROFILE_AUDIT_LOG_STASH}" ]]; then
    return 0
  fi
  echo "Workcell test hook: forcing failure after managed profile refresh." >&2
  exit 88
}

announce_strict_auto_prepare() {
  local headline="$1"
  local detail="${2:-}"

  if [[ "${STRICT_AUTO_PREPARE}" -eq 1 ]]; then
    return 0
  fi

  STRICT_AUTO_PREPARE=1
  PREPARE=1
  echo "${headline}" >&2
  if [[ -n "${detail}" ]]; then
    echo "${detail}" >&2
  fi
  echo "Workcell will seed or refresh the prepared runtime image automatically before launching ${AGENT} in strict mode." >&2
  echo "Use --prepare-only if you want to prewarm the image without launching a session." >&2
}

container_assurance() {
  workcell_container_assurance "${CONTAINER_MUTABILITY}"
}

autonomy_assurance() {
  workcell_autonomy_assurance "${AGENT_AUTONOMY}"
}

codex_rules_assurance() {
  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_codex_rules_assurance "${CODEX_RULES_MUTABILITY}"
}

codex_rules_effective_mutability_with_session_assurance() {
  local session_assurance="$1"

  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_effective_codex_rules_mutability "${CODEX_RULES_MUTABILITY}" "${AGENT_AUTONOMY}" "${session_assurance}"
}

codex_rules_effective_assurance_with_session_assurance() {
  local session_assurance="$1"

  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_effective_codex_rules_assurance "${CODEX_RULES_MUTABILITY}" "${AGENT_AUTONOMY}" "${session_assurance}"
}

session_assurance_initial() {
  if [[ "${ALLOW_CONTROL_PLANE_VCS}" -eq 1 ]]; then
    printf 'lower-assurance-control-plane-vcs\n'
    return 0
  fi
  if [[ "${CACHE_PROFILE}" == "standard" ]]; then
    printf 'lower-assurance-persistent-cache\n'
    return 0
  fi
  container_assurance
}

workspace_control_plane_state() {
  if [[ "${MODE}" == "breakglass" ]]; then
    printf 'unmasked\n'
    return 0
  fi
  if [[ "${ALLOW_CONTROL_PLANE_VCS}" -eq 1 ]]; then
    printf 'readonly-vcs\n'
    return 0
  fi
  printf 'masked\n'
}

session_assurance_final() {
  local initial_assurance
  local final_assurance

  initial_assurance="$(session_assurance_initial)"
  final_assurance="${initial_assurance}"
  if [[ -n "${SESSION_AUDIT_STATE_FILE}" ]] && [[ -r "${SESSION_AUDIT_STATE_FILE}" ]]; then
    case "$(head -n1 "${SESSION_AUDIT_STATE_FILE}")" in
      lower-assurance-package-mutation)
        final_assurance="lower-assurance-package-mutation"
        ;;
    esac
  fi
  printf '%s\n' "${final_assurance}"
}

codex_rules_effective_mutability_initial() {
  codex_rules_effective_mutability_with_session_assurance "$(session_assurance_initial)"
}

codex_rules_effective_assurance_initial() {
  codex_rules_effective_assurance_with_session_assurance "$(session_assurance_initial)"
}

provider_native_sandbox_configured() {
  case "${AGENT:-}" in
    codex)
      printf 'disabled\n'
      ;;
    claude)
      printf 'deferred\n'
      ;;
    gemini)
      printf 'disabled\n'
      ;;
    *)
      printf 'not-applicable\n'
      ;;
  esac
}

provider_native_sandbox_effective() {
  case "${AGENT:-}" in
    codex)
      provider_native_sandbox_configured
      ;;
    claude | gemini)
      printf 'disabled\n'
      ;;
    *)
      printf 'not-applicable\n'
      ;;
  esac
}

provider_native_sandbox_reason() {
  case "${AGENT:-}" in
    codex)
      printf 'workcell-pinned-off-due-to-bwrap-userns-incompatibility\n'
      ;;
    claude)
      printf 'deferred-until-runtime-prereqs-and-validation\n'
      ;;
    gemini)
      printf 'workcell-pinned-off-until-validated\n'
      ;;
    *)
      printf 'not-applicable\n'
      ;;
  esac
}

