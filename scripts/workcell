if [[ -n "${VM_DISK_OVERRIDE}" ]]; then
  COLIMA_DISK="${VM_DISK_OVERRIDE}"
fi
if [[ -n "${CONTAINER_MEMORY_OVERRIDE}" ]]; then
  CONTAINER_MEMORY="${CONTAINER_MEMORY_OVERRIDE}"
fi
validate_positive_integer "VM CPU count" "${COLIMA_CPU}"
validate_positive_integer "VM memory size (GiB)" "${COLIMA_MEMORY}"
validate_positive_integer "VM disk size (GiB)" "${COLIMA_DISK}"
if [[ -n "${WORKCELL_COLIMA_START_TIMEOUT_SECONDS:-}" ]]; then
  validate_nonnegative_integer "managed Colima start timeout (seconds)" "${WORKCELL_COLIMA_START_TIMEOUT_SECONDS}"
fi
if [[ -n "${WORKCELL_COLIMA_DELETE_TIMEOUT_SECONDS:-}" ]]; then
  validate_nonnegative_integer "managed Colima delete timeout (seconds)" "${WORKCELL_COLIMA_DELETE_TIMEOUT_SECONDS}"
fi
validate_container_memory_value "${CONTAINER_MEMORY}"
