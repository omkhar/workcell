  print_inspect_state \
    "$(profile_image_marker_value "${COLIMA_PROFILE}" image_id || true)" \
    "$(current_profile_image_id "${COLIMA_PROFILE}")"
  exit 0
fi

if [[ "${DOCTOR}" -eq 1 ]]; then
  local_current_image_id="$(current_profile_image_id "${COLIMA_PROFILE}")"
  workspace_state="$(workspace_status "${WORKSPACE}")"
  profile_state="absent"
  if [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && ! profile_marker_exists "${COLIMA_PROFILE}"; then
    if [[ "${TARGET_BACKEND}" == "colima" ]]; then
      profile_state="unmanaged"
    else
      profile_state="metadata-missing"
    fi
  elif [[ "${PROFILE_PREEXISTED}" -eq 1 ]]; then
    profile_state="managed"
  fi
  recorded_image_id="$(profile_image_marker_value "${COLIMA_PROFILE}" image_id || true)"
  prepared_image=0
  if [[ -n "${recorded_image_id}" ]] && [[ -n "${local_current_image_id}" ]] && [[ "${recorded_image_id}" == "${local_current_image_id}" ]]; then
    prepared_image=1
  fi
  print_inspect_state "${recorded_image_id}" "${local_current_image_id}"
  printf 'doctor_missing_host_tools=%s\n' "${HOST_TOOL_MISSING_CSV}"
  printf 'doctor_profile_state=%s\n' "${profile_state}"
  printf 'doctor_workspace_binding=%s\n' "${PROFILE_MARKER_WORKSPACE:-none}"
  printf 'doctor_prepared_image=%s\n' "${prepared_image}"
  if ! support_matrix_launch_allowed; then
    if [[ "${SUPPORT_MATRIX_STATUS}" == "preview-only" ]] && target_backend_is_remote_vm_preview "${TARGET_BACKEND}"; then
      if [[ "${HOST_TOOL_MISSING_CSV}" != "none" ]]; then
        printf 'doctor_recommended_next=install-host-tools\n'
      else
        printf 'doctor_recommended_next=%s\n' "$(preview_remote_vm_rollout_action "${TARGET_BACKEND}")"
      fi
      exit 0
    fi
    printf 'doctor_recommended_next=use-supported-host\n'
  elif [[ "${HOST_TOOL_MISSING_CSV}" != "none" ]]; then
    printf 'doctor_recommended_next=install-host-tools\n'
  elif [[ "${workspace_state}" == "missing" ]] || [[ "${workspace_state}" == "not-directory" ]]; then
    printf 'doctor_recommended_next=fix-workspace\n'
  elif [[ "${profile_state}" == "unmanaged" ]]; then
    printf 'doctor_recommended_next='
    if [[ "${MODE}" == "strict" ]]; then
      build_recommended_command 1 1 "${MODE}"
    else
      build_recommended_command 0 1 "${MODE}"
    fi
  elif [[ "${profile_state}" == "metadata-missing" ]]; then
    printf 'doctor_recommended_next=clear-target-state\n'
  elif [[ "${MODE}" == "strict" ]] && [[ "${prepared_image}" -eq 0 ]]; then
    printf 'doctor_recommended_next='
    build_recommended_command 1 0 "${MODE}"
  else
    printf 'doctor_recommended_next=none\n'
  fi
  exit 0
fi

fail_for_unsupported_launch_target

fail_fast_for_missing_gemini_auth "$@"
fail_fast_for_missing_copilot_auth "$@"

if [[ "${DRY_RUN}" -eq 0 ]]; then
  if [[ "${TARGET_BACKEND}" == "colima" ]]; then
    export COLIMA_HOME="${COLIMA_STATE_ROOT}"
  fi
  acquire_profile_lock "${COLIMA_PROFILE}"
  # Another launch may have created or repaired the profile while we waited.
  refresh_profile_state "${COLIMA_PROFILE}"
fi

if [[ "${TARGET_BACKEND}" == "colima" ]] &&
  [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && ! profile_marker_exists "${COLIMA_PROFILE}"; then
  if [[ "${REPAIR_PROFILE}" -eq 1 ]]; then
    delete_unmanaged_profile "${COLIMA_PROFILE}"
    PROFILE_PREEXISTED=0
  else
    echo "Refusing to reuse unmanaged Colima profile: ${COLIMA_PROFILE}" >&2
    echo "Workcell found a profile with the right name but without Workcell ownership metadata." >&2
    echo "That profile might carry broader mounts, credentials, or network state than the reviewed path allows." >&2
    echo "Next step:" >&2
    if [[ "${MODE}" == "strict" ]]; then
      build_recommended_command 1 1 "${MODE}"
    else
      build_recommended_command 0 1 "${MODE}"
    fi
    echo "Manual cleanup, if you prefer to inspect and delete it yourself:" >&2
    printf '  colima delete --profile %q --force\n' "${COLIMA_PROFILE}" >&2
    printf '  rm -rf %q %q %q && rm -f %q\n' \
      "$(profile_dir "${COLIMA_PROFILE}")" \
      "$(profile_lima_dir "${COLIMA_PROFILE}")" \
      "$(profile_disk_dir "${COLIMA_PROFILE}")" \
      "$(profile_store_path "${COLIMA_PROFILE}")" >&2
    exit 2
  fi
fi

if [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && [[ -z "${PROFILE_MARKER_WORKSPACE}" ]]; then
  if [[ "${TARGET_BACKEND}" == "colima" ]]; then
    echo "Refusing to reuse managed Colima profile without a recorded workspace binding: ${COLIMA_PROFILE}" >&2
  else
    echo "Refusing to reuse ${TARGET_BACKEND} target state without a recorded workspace binding: ${COLIMA_PROFILE}" >&2
    echo "Clear $(profile_target_state_dir "${COLIMA_PROFILE}") and retry so Workcell can recreate the reviewed target state." >&2
  fi
  exit 2
fi

if [[ -n "${PROFILE_MARKER_WORKSPACE}" ]] && [[ "${PROFILE_MARKER_WORKSPACE}" != "${PROFILE_WORKSPACE_ROOT}" ]]; then
  if [[ "${TARGET_BACKEND}" == "colima" ]]; then
    echo "Refusing to reuse Colima profile ${COLIMA_PROFILE} for a different workspace." >&2
  else
    echo "Refusing to reuse ${TARGET_BACKEND} target state ${COLIMA_PROFILE} for a different workspace." >&2
  fi
  echo "Recorded workspace: ${PROFILE_MARKER_WORKSPACE}" >&2
  echo "Requested workspace: ${PROFILE_WORKSPACE_ROOT}" >&2
  exit 2
fi

if [[ "${DRY_RUN}" -eq 0 ]] && [[ "${MODE}" == "strict" ]] && [[ "${PREPARE}" -eq 0 ]] && ! profile_image_marker_exists "${COLIMA_PROFILE}"; then
  announce_strict_auto_prepare \
    "No prepared runtime image is recorded for strict mode on profile ${COLIMA_PROFILE}." \
    "This is expected on the first launch for a workspace or after profile cleanup."
fi

ALLOW_ENDPOINTS="$(dedupe_endpoint_list "$(provider_endpoints "${AGENT}") $(target_broker_endpoints "${TARGET_BACKEND}") $(credential_extra_endpoints) $(provider_auth_recovery_extra_endpoints) ${INJECTION_EXTRA_ENDPOINTS} ${EXTRA_ENDPOINTS:-}")"
if ! target_backend_is_remote_vm_preview "${TARGET_BACKEND}" && [[ "${CONTAINER_MUTABILITY}" == "ephemeral" ]]; then
  ALLOW_ENDPOINTS="$(dedupe_endpoint_list "${ALLOW_ENDPOINTS} snapshot.debian.org:443")"
fi
# A1: subtract deny_endpoints last so deny wins over every allow source; this
# only removes endpoints and never changes NETWORK_POLICY.
if [[ -n "${INJECTION_DENY_ENDPOINTS}" ]]; then
  ALLOW_ENDPOINTS="$(subtract_endpoint_list "${ALLOW_ENDPOINTS}" "${INJECTION_DENY_ENDPOINTS}")"
  # Fatal only for an actual session launch; --prepare-only needs no session egress.
  if [[ -z "${ALLOW_ENDPOINTS}" ]] && [[ "${PREPARE_ONLY}" -ne 1 ]] && [[ "${TARGET_BACKEND}" == "colima" ]] && [[ "${NETWORK_POLICY}" == "allowlist" ]]; then
    fail_empty_egress_after_deny "session"
  fi
fi
if target_backend_is_remote_vm_preview "${TARGET_BACKEND}"; then
  emit_preview_remote_vm_dry_run
  exit 0
fi
if [[ "${DRY_RUN}" -eq 0 ]]; then
  prepare_current_target_docker_client
fi
WORKSPACE_SHADOW_SOURCE="${WORKSPACE}"
if [[ "${SESSION_DETACHED}" -eq 1 ]] && [[ "$(effective_session_workspace_mode)" == "isolated" ]]; then
  [[ -n "${SESSION_ID}" ]] || SESSION_ID="$(generate_session_id)"
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    validate_isolated_session_workspace_source "${SESSION_SOURCE_WORKSPACE}"
    WORKSPACE="$(isolated_session_workspace_path "${SESSION_SOURCE_WORKSPACE}" "${SESSION_ID}")"
    WORKSPACE_SHADOW_SOURCE="${SESSION_SOURCE_WORKSPACE}"
  else
    WORKSPACE="$(create_isolated_session_workspace "${SESSION_SOURCE_WORKSPACE}" "${SESSION_ID}")"
  fi
fi
prepare_workspace_control_plane_shadow "${WORKSPACE_SHADOW_SOURCE}" "${MODE}"
prepare_cache_mounts "${AGENT}" "${CACHE_PROFILE}" "${WORKSPACE}"
prepare_copilot_token_handoff_mount "$@"
build_runtime_host_aliases "${ALLOW_ENDPOINTS}"
if [[ "${DRY_RUN}" -eq 0 ]]; then
  prepare_session_audit_state "${COLIMA_PROFILE}"
fi

CONTAINER_NAME="workcell-$(slugify "${AGENT}-${MODE}-$(basename "${WORKSPACE}")")-$(generate_session_suffix)"
DOCKER_RUN_BASE=(
  "${HOST_DOCKER_BIN}"
  run
)
# Copilot token handoff mounts are consumed and unlinked by the Workcell
# entrypoint before provider exec, so keep that entrypoint as PID 1 for the
# authenticated launch path.
if [[ -z "${COPILOT_TOKEN_HANDOFF_DIR}" ]]; then
  DOCKER_RUN_BASE+=(--init)
fi
DOCKER_RUN_BASE+=(
  --name "${CONTAINER_NAME}"
  --security-opt no-new-privileges:true
  --cap-drop ALL
  --pids-limit 1024
  --memory "${CONTAINER_MEMORY}"
  --tmpfs "/tmp:nosuid,nodev,noexec,size=1g,mode=1777"
  --tmpfs "/run:nosuid,nodev,size=64m,mode=755"
  --tmpfs "/state:exec,nosuid,nodev,size=1g,mode=1777"
  --workdir /workspace
  -e AGENT_NAME="${AGENT}"
  -e WORKCELL_AGENT_AUTONOMY="${AGENT_AUTONOMY}"
  -e WORKCELL_CODEX_RULES_MUTABILITY="${CODEX_RULES_MUTABILITY}"
  -e WORKCELL_ALLOW_ARBITRARY_COMMAND="${ALLOW_ARBITRARY_COMMAND}"
  -e WORKCELL_CACHE_PROFILE="${CACHE_PROFILE}"
  -e WORKCELL_CONTAINER_MUTABILITY="${CONTAINER_MUTABILITY}"
  -e WORKCELL_SESSION_ASSURANCE_INITIAL="$(session_assurance_initial)"
  -e WORKCELL_ALLOW_CONTROL_PLANE_VCS="${ALLOW_CONTROL_PLANE_VCS}"
  -e WORKCELL_ALLOW_ARBITRARY_COMMAND="${ALLOW_ARBITRARY_COMMAND}"
  -e WORKCELL_WORKSPACE_CONTROL_PLANE_STATE="$(workspace_control_plane_state)"
  -e AGENT_UI="${UI}"
  -e CODEX_PROFILE="${MODE}"
  -e WORKCELL_MODE="${MODE}"
  -e HOME=/state/agent-home
  -e CODEX_HOME=/state/agent-home/.codex
  -e COPILOT_HOME=/state/agent-home/.copilot
  -e COPILOT_CACHE_HOME=/state/agent-home/.cache/github-copilot
  -e WORKCELL_RUNTIME=1
  -e WORKCELL_COPILOT_TOKEN_HANDOFF_CONTAINER_DIR="${COPILOT_TOKEN_HANDOFF_CONTAINER_DIR}"
  -e WORKCELL_COPILOT_AUTH_REQUIRED="${COPILOT_AUTH_REQUIRED}"
  -e TMPDIR=/state/tmp
  -e WORKSPACE=/workspace
  -e WORKCELL_WORKSPACE_IMPORT_ROOT=/opt/workcell/workspace-control-plane
  -v "${WORKSPACE}:/workspace"
)
if [[ -n "${SESSION_AUDIT_STATE_FILE}" ]] && [[ -n "${SESSION_AUDIT_CONTAINER_FILE}" ]]; then
  DOCKER_RUN_BASE+=(
    -e WORKCELL_PERSISTED_ASSURANCE_FILE="${SESSION_AUDIT_CONTAINER_FILE}"
  )
fi
if [[ "${CONTAINER_MUTABILITY}" == "readonly" ]]; then
  DOCKER_RUN_BASE+=(
    --read-only
    --tmpfs "/run/workcell:nosuid,nodev,size=4m,mode=755,uid=${HOST_UID},gid=${HOST_GID}"
    --user "${HOST_UID}:${HOST_GID}"
    -e USER=agent
    -e LOGNAME=agent
  )
else
  DOCKER_RUN_BASE+=(
    # Mutable sessions still drop the default capability set, but need the
    # minimal handoff capabilities required to re-exec as the mapped runtime
    # user.
    --cap-add SETUID
    --cap-add SETGID
    --user 0:0
    -e WORKCELL_HOST_UID="${HOST_UID}"
    -e WORKCELL_HOST_GID="${HOST_GID}"
    -e WORKCELL_HOST_USER="${HOST_USER}"
  )
fi
if [[ -n "${CONTAINER_CPU_OVERRIDE}" ]]; then
  DOCKER_RUN_BASE+=(--cpus "${CONTAINER_CPU_OVERRIDE}")
fi
if ((${#SHADOW_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${SHADOW_MOUNTS[@]}")
fi
if ((${#WORKSPACE_IMPORT_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${WORKSPACE_IMPORT_MOUNTS[@]}")
fi
if ((${#RUNTIME_NETWORK_ARGS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${RUNTIME_NETWORK_ARGS[@]}")
fi
if ((${#DIRECT_SOURCE_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${DIRECT_SOURCE_MOUNTS[@]}")
fi
if [[ -n "${COPILOT_TOKEN_HANDOFF_DIR}" ]]; then
  DOCKER_RUN_BASE+=(
    -v "${COPILOT_TOKEN_HANDOFF_DIR}:${COPILOT_TOKEN_HANDOFF_CONTAINER_DIR}:rw"
  )
fi
if ((${#CACHE_MOUNTS[@]} > 0)); then
  DOCKER_RUN_BASE+=("${CACHE_MOUNTS[@]}")
fi
if [[ -n "${INJECTION_BUNDLE_ROOT}" ]]; then
  DOCKER_RUN_BASE+=(
    -e WORKCELL_INJECTION_MANIFEST=/opt/workcell/host-injections/manifest.json
    -v "${INJECTION_BUNDLE_ROOT}:/opt/workcell/host-injections:ro"
  )
fi
if [[ -n "${FILE_TRACE_LOG_PATH}" ]]; then
  DOCKER_RUN_BASE+=(
    -e WORKCELL_FILE_TRACE_PATH="${SESSION_FILE_TRACE_CONTAINER_FILE}"
  )
fi
if [[ "${SESSION_DETACHED}" -eq 1 ]]; then
  DOCKER_RUN_BASE+=(
    -e WORKCELL_DETACHED_STDIN_PATH="${DETACHED_SESSION_STDIN_PATH}"
  )
fi
EXECUTION_PATH="managed-tier1"
if [[ "${MODE}" == "breakglass" ]]; then
  EXECUTION_PATH="lower-assurance-breakglass"
elif [[ "${MODE}" == "development" ]]; then
  EXECUTION_PATH="lower-assurance-development"
elif [[ "${ALLOW_CONTROL_PLANE_VCS}" -eq 1 ]]; then
  EXECUTION_PATH="lower-assurance-control-plane-vcs"
fi

if [[ "${ALLOW_ARBITRARY_COMMAND}" -eq 1 ]]; then
  if [[ $# -eq 0 ]]; then
    echo "arbitrary command mode requires a command after --." >&2
    exit 2
  fi
  EXECUTION_PATH="lower-assurance-debug-command"
  DOCKER_RUN=(
    "${DOCKER_RUN_BASE[@]}"
    "${IMAGE_TAG}"
  )
  DOCKER_RUN+=("$@")
else
  DOCKER_RUN=(
    "${DOCKER_RUN_BASE[@]}"
    "${IMAGE_TAG}"
  )
  if [[ $# -gt 0 ]]; then
    DOCKER_RUN+=("$@")
  fi
fi

DOCKER_RUN_PREFIX_LEN=2
if [[ "${DOCKER_RUN[2]:-}" == "--init" ]]; then
  DOCKER_RUN_PREFIX_LEN=3
fi
DOCKER_RUN_ARGS=("${DOCKER_RUN[@]:${DOCKER_RUN_PREFIX_LEN}}")

if [[ "${SESSION_DETACHED}" -eq 1 ]]; then
  DOCKER_RUN=(
    "${HOST_DOCKER_BIN}" run
  )
  if [[ -z "${COPILOT_TOKEN_HANDOFF_DIR}" ]]; then
    DOCKER_RUN+=(--init)
  fi
  DOCKER_RUN+=(-d -i -t "${DOCKER_RUN_ARGS[@]}")
elif [[ -t 0 ]] && [[ -t 1 ]]; then
  mark_interactive_host_terminal_dirty
  DOCKER_RUN=("${HOST_DOCKER_BIN}" run -it "${DOCKER_RUN_ARGS[@]}")
fi

printf 'profile=%s mode=%s agent=%s ui=%s workspace=%s\n' \
  "${COLIMA_PROFILE}" "${MODE}" "${AGENT}" "${UI}" "${WORKSPACE}" >&2
printf 'target_kind=%s target_provider=%s target_id=%s target_assurance_class=%s runtime_api=%s workspace_transport=%s\n' \
  "$(current_target_kind)" \
  "$(current_target_provider)" \
  "$(current_target_id)" \
  "$(current_target_assurance_class)" \
  "$(current_runtime_api)" \
  "$(current_workspace_transport)" >&2
printf 'agent_autonomy=%s\n' "${AGENT_AUTONOMY}" >&2
printf 'vm_resources=cpu=%s memory_gib=%s disk_gib=%s\n' "${COLIMA_CPU}" "${COLIMA_MEMORY}" "${COLIMA_DISK}" >&2
printf 'container_resources=mutability=%s cpu=%s memory=%s\n' \
  "${CONTAINER_MUTABILITY}" "${CONTAINER_CPU_OVERRIDE:-unmanaged}" "${CONTAINER_MEMORY}" >&2
printf 'cache_profile=%s\n' "${CACHE_PROFILE}" >&2
printf 'cache_assurance=%s\n' "$(cache_assurance)" >&2
printf 'container_assurance=%s\n' "$(container_assurance)" >&2
printf 'autonomy_assurance=%s\n' "$(autonomy_assurance)" >&2
printf 'observability_assurance=%s\n' "$(observability_assurance)" >&2
printf 'log_level=%s debug_log=%s audit_transcript=%s\n' \
  "${LOG_LEVEL}" "${DEBUG_LOG_PATH:-off}" "$([[ -n "${AUDIT_TRANSCRIPT_PATH}" ]] && printf 'full' || printf 'off')" >&2
printf 'file_trace=%s\n' "${FILE_TRACE_LOG_PATH:-off}" >&2
printf 'codex_rules_mutability_configured=%s\n' "${CODEX_RULES_MUTABILITY}" >&2
printf 'codex_rules_assurance_configured=%s\n' "$(codex_rules_assurance)" >&2
printf 'codex_rules_mutability_effective_initial=%s\n' "$(codex_rules_effective_mutability_initial)" >&2
printf 'codex_rules_assurance_effective_initial=%s\n' "$(codex_rules_effective_assurance_initial)" >&2
printf 'provider_native_sandbox_configured=%s effective=%s reason=%s\n' \
  "$(provider_native_sandbox_configured)" \
  "$(provider_native_sandbox_effective)" \
  "$(provider_native_sandbox_reason)" >&2
printf 'session_assurance_initial=%s\n' "$(session_assurance_initial)" >&2
if [[ -n "${INJECTION_POLICY_SHA256}" ]]; then
  printf 'injection_policy_sha256=%s credential_keys=%s ssh_injected=%s\n' \
    "${INJECTION_POLICY_SHA256}" "${INJECTION_CREDENTIAL_KEYS:-none}" "${INJECTION_SSH_ENABLED}" >&2
fi
printf 'workspace_control_plane=%s\n' "$(workspace_control_plane_state)" >&2
printf 'network_policy=%s endpoints=%s\n' "${NETWORK_POLICY}" "${ALLOW_ENDPOINTS}" >&2
printf 'egress_enforcement=%s\n' "$(egress_enforcement_label)" >&2
printf 'execution_path=%s audit_log=%s\n' "${EXECUTION_PATH}" "$(profile_audit_log_path "${COLIMA_PROFILE}")" >&2

if [[ "${DRY_RUN}" -eq 1 ]]; then
  if [[ "${PREPARE_ONLY}" -eq 1 ]]; then
    printf 'prepare_only=1 no_session_launch=1\n'
    exit 0
  fi
  emit_redacted_command "${DOCKER_RUN[@]}"
  exit 0
fi

if [[ "${TARGET_BACKEND}" == "colima" ]] && [[ "${PROFILE_PREEXISTED}" -eq 1 ]]; then
  profile_config_path="$(profile_colima_config_path "${COLIMA_PROFILE}")"
  lima_config_path="${COLIMA_STATE_ROOT}/_lima/colima-${COLIMA_PROFILE}/lima.yaml"
  profile_status=""
  if [[ ! -f "${profile_config_path}" ]] ||
    ! validate_colima_profile_config "${COLIMA_PROFILE}" "${PROFILE_WORKSPACE_ROOT}" "${COLIMA_CPU}" "${COLIMA_MEMORY}" "${COLIMA_DISK}"; then
    refresh_managed_profile "Refreshing managed Colima profile ${COLIMA_PROFILE} to apply the requested reviewed VM resources." || exit 2
  elif [[ ! -f "${lima_config_path}" ]] ||
    ! validate_colima_runtime_mounts "${COLIMA_PROFILE}" "${PROFILE_WORKSPACE_ROOT}"; then
    refresh_managed_profile "Refreshing managed Colima profile ${COLIMA_PROFILE} to discard stale runtime mounts." || exit 2
  else
    profile_status="$(colima_profile_status "${COLIMA_PROFILE}" || true)"
    if [[ "${profile_status}" == "Running" ]] &&
      ! validate_colima_runtime_workspace_view "${COLIMA_PROFILE}" "${PROFILE_WORKSPACE_ROOT}"; then
      refresh_managed_profile "Refreshing managed Colima profile ${COLIMA_PROFILE} because the running VM is not exposing the expected workspace contents." || exit 2
    fi
  fi
fi

if [[ "${MODE}" == "strict" ]] && [[ "${PREPARE}" -eq 0 ]] && ! profile_image_marker_exists "${COLIMA_PROFILE}"; then
  announce_strict_auto_prepare \
    "No prepared runtime image is recorded for strict mode on profile ${COLIMA_PROFILE}." \
    "This is expected on the first launch for a workspace or after profile cleanup."
fi

maybe_fail_after_profile_refresh_for_tests

if [[ "${TARGET_BACKEND}" == "colima" ]]; then
  start_managed_profile
  if ! validate_colima_profile "${COLIMA_PROFILE}" "${PROFILE_WORKSPACE_ROOT}"; then
    if [[ "${PROFILE_PREEXISTED}" -eq 1 ]] && [[ "${PROFILE_WAS_REFRESHED}" -eq 0 ]]; then
      refresh_managed_profile "Refreshing managed Colima profile ${COLIMA_PROFILE} because the started VM did not expose the expected workspace view." || exit 2
      start_managed_profile
      validate_colima_profile "${COLIMA_PROFILE}" "${PROFILE_WORKSPACE_ROOT}" || exit 2
    else
      exit 2
    fi
  fi
fi
record_validated_profile_state

if [[ "${TARGET_BACKEND}" == "colima" ]]; then
  export DOCKER_HOST="unix://${COLIMA_STATE_ROOT}/${COLIMA_PROFILE}/docker.sock"
else
  unset DOCKER_HOST
fi
validate_runtime_security_posture

restore_runtime_egress() {
  if [[ "${TARGET_BACKEND}" == "colima" ]]; then
    if [[ "${NETWORK_POLICY}" == "allowlist" ]]; then
      # An empty ALLOW_ENDPOINTS only reaches here via --prepare-only (a launch
      # aborts at the empty-egress guard). The helper treats an empty list as a
      # deny-all allowlist, so the idle prewarmed VM is left with no egress
      # rather than the broader build-time allowlist (`clear` would mean
      # unrestricted, so it is not used here).
      "${EGRESS_HELPER}" apply "${COLIMA_PROFILE}" "${ALLOW_ENDPOINTS}"
    else
      "${EGRESS_HELPER}" clear "${COLIMA_PROFILE}"
    fi
  fi
}

RECORDED_IMAGE_ID="$(profile_image_marker_value "${COLIMA_PROFILE}" image_id || true)"
RECORDED_SOURCE_DATE_EPOCH="$(profile_image_marker_value "${COLIMA_PROFILE}" source_date_epoch || true)"
EXPECTED_IMAGE_ID="${RECORDED_IMAGE_ID}"
EXPECTED_SOURCE_DATE_EPOCH="${RECORDED_SOURCE_DATE_EPOCH}"
if [[ -z "${EXPECTED_IMAGE_ID}" ]] && [[ -n "${PROFILE_REFRESH_EXPECTED_IMAGE_ID}" ]]; then
  EXPECTED_IMAGE_ID="${PROFILE_REFRESH_EXPECTED_IMAGE_ID}"
  EXPECTED_SOURCE_DATE_EPOCH="${PROFILE_REFRESH_EXPECTED_SOURCE_DATE_EPOCH}"
fi
CURRENT_IMAGE_ID=""
if [[ "${REBUILD}" -eq 1 ]]; then
  NEEDS_REBUILD=1
else
  CURRENT_IMAGE_ID="$(current_image_id)"
  if [[ -n "${EXPECTED_IMAGE_ID}" ]] &&
    { [[ -z "${CURRENT_IMAGE_ID}" ]] || [[ "${CURRENT_IMAGE_ID}" != "${EXPECTED_IMAGE_ID}" ]]; }; then
    if restore_profile_runtime_image_cache "${COLIMA_PROFILE}" "${EXPECTED_IMAGE_ID}" "${EXPECTED_SOURCE_DATE_EPOCH}"; then
      CURRENT_IMAGE_ID="$(current_image_id)"
      RECORDED_IMAGE_ID="${EXPECTED_IMAGE_ID}"
      RECORDED_SOURCE_DATE_EPOCH="${EXPECTED_SOURCE_DATE_EPOCH}"
    fi
  fi
  if [[ -z "${CURRENT_IMAGE_ID}" ]] || [[ -z "${EXPECTED_IMAGE_ID}" ]] || [[ "${CURRENT_IMAGE_ID}" != "${EXPECTED_IMAGE_ID}" ]]; then
    NEEDS_REBUILD=1
  fi
fi

if [[ "${MODE}" == "strict" ]] && [[ "${NEEDS_REBUILD}" -eq 1 ]] && [[ "${PREPARE}" -eq 0 ]]; then
  announce_strict_auto_prepare \
    "Strict mode needs a prepared runtime image for profile ${COLIMA_PROFILE}." \
    "The profile started successfully, but the prepared image marker is missing or stale."
fi

if [[ "${NETWORK_POLICY}" == "allowlist" ]] && [[ "${NEEDS_REBUILD}" -eq 1 ]]; then
  if [[ "${STRICT_AUTO_PREPARE}" -eq 1 ]]; then
    echo "Workcell is preparing the reviewed runtime image automatically for this strict-mode launch." >&2
  elif [[ "${PREPARE}" -eq 1 ]]; then
    echo "prepare=1 seeding the prepared runtime image before launch." >&2
  fi
  BOOTSTRAP_APPLIED=1
  printf 'bootstrap_policy=allowlist endpoints=%s\n' "${BOOTSTRAP_ENDPOINTS}" >&2
  if [[ "${TARGET_BACKEND}" == "colima" ]]; then
    [[ -n "${BOOTSTRAP_ENDPOINTS}" ]] || fail_empty_egress_after_deny "bootstrap"
    "${EGRESS_HELPER}" apply "${COLIMA_PROFILE}" "${BOOTSTRAP_ENDPOINTS}"
  fi
elif [[ "${NETWORK_POLICY}" != "allowlist" ]] && [[ "${TARGET_BACKEND}" == "colima" ]]; then
  "${EGRESS_HELPER}" clear "${COLIMA_PROFILE}"
fi

if [[ "${NEEDS_REBUILD}" -eq 1 ]]; then
  BUILD_SOURCE_DATE_EPOCH="${SOURCE_DATE_EPOCH}"
  BUILD_STATUS=0
  run_runtime_image_build_with_retries "${BUILD_SOURCE_DATE_EPOCH}" || BUILD_STATUS=$?
  if [[ "${BUILD_STATUS}" -ne 0 ]]; then
    restore_runtime_egress
    exit "${BUILD_STATUS}"
  fi
  CURRENT_IMAGE_ID="$(current_image_id)"
  if [[ -z "${CURRENT_IMAGE_ID}" ]]; then
    restore_runtime_egress
    echo "Workcell failed to record the prepared runtime image ID for ${IMAGE_TAG}." >&2
    exit 2
  fi
  write_profile_image_marker "${COLIMA_PROFILE}" "${CURRENT_IMAGE_ID}"
  maybe_cache_profile_runtime_image "${COLIMA_PROFILE}" "${CURRENT_IMAGE_ID}"
elif [[ -n "${CURRENT_IMAGE_ID}" ]] && [[ -n "${EXPECTED_IMAGE_ID}" ]] && [[ "${CURRENT_IMAGE_ID}" == "${EXPECTED_IMAGE_ID}" ]]; then
  maybe_cache_profile_runtime_image "${COLIMA_PROFILE}" "${CURRENT_IMAGE_ID}"
fi

restore_runtime_egress
if [[ "${PREPARE_ONLY}" -eq 1 ]]; then
  echo "Prepared runtime image recorded for profile ${COLIMA_PROFILE}. No session launched because --prepare-only was requested." >&2
  exit 0
fi
write_session_record_initial "${COLIMA_PROFILE}" "${EXECUTION_PATH}"
append_launch_audit_record "${COLIMA_PROFILE}" "${EXECUTION_PATH}"

# Lower-assurance paths must be visible at session entry, not implied or
# only retroactively labeled.  Mutable container mutability runs the
# workload with SETUID/SETGID capability surface and user 0:0 (see the
# --cap-add SETUID/--cap-add SETGID block in DOCKER_RUN_BASE composition
# below).  --container-mutability readonly is the high-assurance lane;
# any other choice gets a banner on stderr so an operator reading the
# launch surface sees the elevated cap envelope before any agent
# command runs.
if [[ "${CONTAINER_MUTABILITY}" != "readonly" ]]; then
  cat <<NOTE >&2
Workcell notice: this session uses --container-mutability=${CONTAINER_MUTABILITY}.
The runtime container holds SETUID/SETGID capabilities and runs the
in-container entrypoint as UID 0.  Package-manager and SETUID surfaces
are explicitly allowed.  This is a lower-assurance path than
--container-mutability=readonly; treat in-session control-plane
integrity accordingly.
NOTE
fi

DOCKER_STATUS=0
run_workcell_docker_client_command "${HOST_DOCKER_BIN}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
if [[ "${SESSION_DETACHED}" -eq 1 ]]; then
  detached_status="running"
  detached_live_status="running"
  session_git_branch="$(run_workspace_safe_git_command_in_dir "${WORKSPACE}" branch --show-current 2>/dev/null || true)"
  if [[ -n "${AUDIT_TRANSCRIPT_PATH}" ]]; then
    echo "Detached session start does not support --audit-transcript." >&2
    exit 2
  fi
  "${DOCKER_RUN[@]}" >/dev/null
  wait_for_copilot_token_handoff_consumed
  start_detached_session_monitor
  load_session_runtime_metadata "${SESSION_ID}"
  detached_status="${SESSION_META_STATUS:-running}"
  detached_live_status="${SESSION_META_LIVE_STATUS:-running}"
  DETACHED_SESSION_ACTIVE=1
  ensure_session_meta_git_branch "${session_git_branch}"
  printf 'session_id=%s\n' "${SESSION_ID}"
  printf 'status=%s\n' "${detached_status}"
  printf 'live_status=%s\n' "${detached_live_status}"
  printf 'control_mode=detached\n'
  printf 'workspace=%s\n' "${WORKSPACE}"
  printf 'workspace_origin=%s\n' "${SESSION_SOURCE_WORKSPACE}"
  printf 'workspace_root=%s\n' "${PROFILE_WORKSPACE_ROOT}"
  printf 'worktree_path=%s\n' "${WORKSPACE}"
  emit_loaded_session_control_summary
  printf 'monitor_pid=%s\n' "${SESSION_MONITOR_PID}"
  printf 'audit_log_path=%s\n' "$(profile_audit_log_path "${COLIMA_PROFILE}")"
  printf 'debug_log_path=%s\n' "${DEBUG_LOG_PATH:-none}"
  printf 'file_trace_log_path=%s\n' "${FILE_TRACE_LOG_PATH:-none}"
  printf 'transcript_log_path=%s\n' "${AUDIT_TRANSCRIPT_PATH:-none}"
  exit 0
elif [[ -n "${AUDIT_TRANSCRIPT_PATH}" ]]; then
  if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
    echo "Full transcript capture requires an interactive terminal." >&2
    exit 2
  fi
  echo "Workcell warning: full host-persisted terminal transcript capture is enabled for this session: ${AUDIT_TRANSCRIPT_PATH}" >&2
  "${ROOT_DIR}/scripts/lib/pty_transcript" --log "${AUDIT_TRANSCRIPT_PATH}" -- "${DOCKER_RUN[@]}" || DOCKER_STATUS=$?
else
  "${DOCKER_RUN[@]}" || DOCKER_STATUS=$?
fi
restore_interactive_host_terminal
capture_session_audit_state "${CONTAINER_NAME}"
capture_session_file_trace "${CONTAINER_NAME}"
finalize_session_audit "${COLIMA_PROFILE}" "${EXECUTION_PATH}" "${DOCKER_STATUS}"
run_workcell_docker_client_command "${HOST_DOCKER_BIN}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
if [[ "${FINAL_SESSION_ASSURANCE:-}" == "lower-assurance-package-mutation" ]]; then
  echo "Workcell warning: this session ended lower-assurance because package-manager mutations ran as root inside the container." >&2
fi
if [[ "${CONTAINER_MUTABILITY}" == "ephemeral" ]]; then
  if [[ "${CACHE_PROFILE}" == "standard" ]]; then
    echo "Workcell ephemeral runtime ended. Changes not persisted to /workspace or provided from the host control plane were discarded, but the opt-in persistent cache plane was retained." >&2
  else
    echo "Workcell ephemeral runtime ended. Changes not persisted to /workspace or provided from the host control plane were discarded." >&2
  fi
fi
exit "${DOCKER_STATUS}"
