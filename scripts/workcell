profile_marker_read_path() {
  local profile="$1"
  local marker_path=""
  local legacy_path=""

  marker_path="$(profile_marker_path "${profile}")"
  if [[ -f "${marker_path}" ]]; then
    printf '%s\n' "${marker_path}"
    return 0
  fi

  if [[ "$(target_provider_for_profile_state "${profile}")" == "colima" ]]; then
    legacy_path="$(legacy_profile_marker_path "${profile}")"
    if [[ -f "${legacy_path}" ]]; then
      printf '%s\n' "${legacy_path}"
      return 0
    fi
  fi

  return 1
}

profile_image_marker_read_path() {
  local profile="$1"
  local marker_path=""
  local legacy_path=""

  marker_path="$(profile_image_marker_path "${profile}")"
  if [[ -f "${marker_path}" ]]; then
    printf '%s\n' "${marker_path}"
    return 0
  fi

  if [[ "$(target_provider_for_profile_state "${profile}")" == "colima" ]]; then
    legacy_path="$(legacy_profile_image_marker_path "${profile}")"
    if [[ -f "${legacy_path}" ]]; then
      printf '%s\n' "${legacy_path}"
      return 0
    fi
  fi

  return 1
}

profile_marker_exists() {
  profile_marker_read_path "$1" >/dev/null 2>&1
}

profile_image_marker_exists() {
  profile_image_marker_read_path "$1" >/dev/null 2>&1
}

profile_runtime_image_cache_dir() {
  printf '%s/runtime-image-cache/%s/%s\n' \
    "${WORKCELL_STATE_ROOT}" \
    "$(current_target_kind)" \
    "$(current_target_provider)"
}

profile_runtime_image_cache_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s.tar\n' "$(profile_runtime_image_cache_dir)" "${profile}"
}

profile_runtime_image_cache_metadata_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s.env\n' "$(profile_runtime_image_cache_dir)" "${profile}"
}

workcell_nonnegative_integer_or_default() {
  local value="$1"
  local default_value="$2"

  if [[ "${value}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${value}"
  else
    printf '%s\n' "${default_value}"
  fi
}

workcell_path_mtime_epoch() {
  local path="$1"
  local stat_output=""

  if stat_output="$(stat -f '%m' "${path}" 2>/dev/null)" && [[ "${stat_output}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${stat_output}"
    return 0
  fi
  if stat_output="$(stat -c '%Y' "${path}" 2>/dev/null)" && [[ "${stat_output}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${stat_output}"
    return 0
  fi
  printf '0\n'
}

workcell_path_size_bytes() {
  local path="$1"
  local stat_output=""

  if stat_output="$(stat -f '%z' "${path}" 2>/dev/null)" && [[ "${stat_output}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${stat_output}"
    return 0
  fi
  if stat_output="$(stat -c '%s' "${path}" 2>/dev/null)" && [[ "${stat_output}" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "${stat_output}"
    return 0
  fi
  printf '0\n'
}

workcell_path_is_stale_minutes() {
  local path="$1"
  local stale_minutes="$2"
  local now_epoch=""
  local path_epoch=""
  local max_age_seconds=0

  stale_minutes="$(workcell_nonnegative_integer_or_default "${stale_minutes}" 60)"
  if [[ "${stale_minutes}" -eq 0 ]]; then
    return 0
  fi
  now_epoch="$(date +%s)"
  path_epoch="$(workcell_path_mtime_epoch "${path}")"
  [[ "${path_epoch}" =~ ^[0-9]+$ ]] || return 1
  max_age_seconds=$((stale_minutes * 60))
  [[ $((now_epoch - path_epoch)) -ge "${max_age_seconds}" ]]
}

make_workcell_tree_user_writable() {
  local target_path="$1"

  [[ -e "${target_path}" || -L "${target_path}" ]] || return 0
  if [[ -L "${target_path}" ]]; then
    chmod -h u+w "${target_path}" 2>/dev/null || chmod u+w "${target_path}" 2>/dev/null || true
    return 0
  fi

  if command -v chflags >/dev/null 2>&1; then
    chflags -R nouchg,noschg "${target_path}" 2>/dev/null || true
  fi
  find -P "${target_path}" -type d -exec chmod u+rwx {} + 2>/dev/null || true
  find -P "${target_path}" -type f -exec chmod u+rw {} + 2>/dev/null || true
  chmod u+rwx "${target_path}" 2>/dev/null || true
}

runtime_image_cache_max_bytes() {
  workcell_nonnegative_integer_or_default "${WORKCELL_RUNTIME_IMAGE_CACHE_MAX_BYTES:-2147483648}" 2147483648
}

runtime_image_cache_keep_recent() {
  workcell_nonnegative_integer_or_default "${WORKCELL_RUNTIME_IMAGE_CACHE_KEEP_RECENT:-1}" 1
}

runtime_image_cache_stale_minutes() {
  workcell_nonnegative_integer_or_default "${WORKCELL_RUNTIME_IMAGE_CACHE_STALE_MINUTES:-60}" 60
}

cleanup_runtime_image_cache_orphans() {
  local cache_dir="$1"
  local stale_minutes="$2"
  local path=""
  local pair_path=""

  [[ -d "${cache_dir}" ]] || return 0
  while IFS= read -r -d '' path; do
    pair_path="${path%.tar}.env"
    if [[ ! -f "${pair_path}" ]] && workcell_path_is_stale_minutes "${path}" "${stale_minutes}"; then
      rm -f "${path}"
    fi
  done < <(find "${cache_dir}" -maxdepth 1 -type f -name '*.tar' -print0 2>/dev/null)

  while IFS= read -r -d '' path; do
    pair_path="${path%.env}.tar"
    if [[ ! -f "${pair_path}" ]] && workcell_path_is_stale_minutes "${path}" "${stale_minutes}"; then
      rm -f "${path}"
    fi
  done < <(find "${cache_dir}" -maxdepth 1 -type f -name '*.env' -print0 2>/dev/null)
}

prune_runtime_image_cache_dir() {
  local cache_dir="$1"
  local max_bytes="${2:-}"
  local keep_recent="${3:-}"
  local stale_minutes="${4:-}"
  local path=""
  local size=""
  local mtime=""
  local total_bytes=0
  local index=0
  local entry=""
  local -a entries=()
  local -a sorted_entries=()

  [[ -d "${cache_dir}" ]] || return 0
  max_bytes="$(workcell_nonnegative_integer_or_default "${max_bytes:-$(runtime_image_cache_max_bytes)}" "$(runtime_image_cache_max_bytes)")"
  keep_recent="$(workcell_nonnegative_integer_or_default "${keep_recent:-$(runtime_image_cache_keep_recent)}" "$(runtime_image_cache_keep_recent)")"
  stale_minutes="$(workcell_nonnegative_integer_or_default "${stale_minutes:-$(runtime_image_cache_stale_minutes)}" "$(runtime_image_cache_stale_minutes)")"

  cleanup_runtime_image_cache_orphans "${cache_dir}" "${stale_minutes}"

  while IFS= read -r -d '' path; do
    size="$(workcell_path_size_bytes "${path}")"
    mtime="$(workcell_path_mtime_epoch "${path}")"
    [[ "${size}" =~ ^[0-9]+$ ]] || size=0
    [[ "${mtime}" =~ ^[0-9]+$ ]] || mtime=0
    entries+=("${mtime}|${size}|${path}")
    total_bytes=$((total_bytes + size))
  done < <(find "${cache_dir}" -maxdepth 1 -type f -name '*.tar' -print0 2>/dev/null)

  ((${#entries[@]} > 0)) || return 0
  while IFS= read -r entry; do
    sorted_entries+=("${entry}")
  done < <(printf '%s\n' "${entries[@]}" | sort -t '|' -k1,1nr)
  for entry in "${sorted_entries[@]}"; do
    index=$((index + 1))
    entry="${entry#*|}"
    size="${entry%%|*}"
    path="${entry#*|}"
    if [[ "${index}" -le "${keep_recent}" ]]; then
      continue
    fi
    if [[ "${total_bytes}" -le "${max_bytes}" ]]; then
      break
    fi
    rm -f "${path}" "${path%.tar}.env"
    total_bytes=$((total_bytes - size))
  done
}

prune_runtime_image_caches() {
  local cache_root="${WORKCELL_STATE_ROOT}/runtime-image-cache"
  local cache_dir=""
  local max_bytes=""
  local keep_recent=""
  local stale_minutes=""

  [[ -d "${cache_root}" ]] || return 0
  max_bytes="$(runtime_image_cache_max_bytes)"
  keep_recent="$(runtime_image_cache_keep_recent)"
  stale_minutes="$(runtime_image_cache_stale_minutes)"
  while IFS= read -r -d '' cache_dir; do
    prune_runtime_image_cache_dir "${cache_dir}" "${max_bytes}" "${keep_recent}" "${stale_minutes}"
  done < <(find "${cache_root}" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
}

refresh_profile_state() {
  local profile="$1"

  PROFILE_PREEXISTED=0
  PROFILE_MARKER_WORKSPACE=""

  if profile_metadata_dir_has_substantive_state "${profile}"; then
    PROFILE_PREEXISTED=1
  elif [[ "$(current_target_provider)" == "colima" ]] && [[ -d "$(profile_dir "${profile}")" ]]; then
    PROFILE_PREEXISTED=1
  fi

  if profile_marker_read_path "${profile}" >/dev/null; then
    PROFILE_MARKER_WORKSPACE="$(read_profile_marker_workspace "${profile}" || true)"
  fi
}

profile_metadata_dir_has_substantive_state() {
  local profile="$1"
  local metadata_dir=""
  local path=""
  local base=""

  metadata_dir="$(profile_metadata_dir "${profile}")"
  [[ -d "${metadata_dir}" ]] || return 1

  for path in "${metadata_dir}"/* "${metadata_dir}"/.*; do
    [[ -e "${path}" ]] || continue
    base="$(basename "${path}")"
    case "${base}" in
      . | ..)
        continue
        ;;
      workcell.audit.log | workcell.latest-debug-log | workcell.latest-file-trace-log | workcell.latest-transcript-log | session-audit.*)
        continue
        ;;
      *)
        return 0
        ;;
    esac
  done

  return 1
}

profile_image_marker_value() {
  local profile="$1"
  local key="$2"
  local marker_path=""

  [[ "${key}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || return 1
  marker_path="$(profile_image_marker_read_path "${profile}")" || return 1
  [[ -f "${marker_path}" ]] || return 1
  sed -n "s/^${key}=//p" "${marker_path}" | head -n1
}

profile_runtime_image_cache_value() {
  local profile="$1"
  local key="$2"
  local metadata_path=""

  [[ "${key}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || return 1
  metadata_path="$(profile_runtime_image_cache_metadata_path "${profile}")"
  [[ -f "${metadata_path}" ]] || return 1
  sed -n "s/^${key}=//p" "${metadata_path}" | head -n1
}

