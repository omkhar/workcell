#!/usr/bin/env -S -i PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/sbin:/usr/local/sbin:/usr/sbin:/sbin:/Applications/Docker.app/Contents/Resources/bin BASH_ENV= ENV= /bin/bash
# shellcheck shell=bash
set -euo pipefail

readonly TRUSTED_HOST_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/sbin:/usr/local/sbin:/usr/sbin:/sbin:/Applications/Docker.app/Contents/Resources/bin"
export PATH="${TRUSTED_HOST_PATH}"
scrub_host_process_env() {
  local env_name

  unset BASH_ENV ENV
  unset WORKCELL_TEST_FAIL_AFTER_PROFILE_REFRESH
  unset PYTHONPATH PYTHONHOME PYTHONSAFEPATH PYTHONSTARTUP
  unset RUBYOPT RUBYLIB GEM_HOME GEM_PATH
  unset PERL5OPT PERL5LIB PERLLIB PERL_MB_OPT PERL_MM_OPT
  unset LD_PRELOAD LD_LIBRARY_PATH LD_AUDIT LD_DEBUG LD_DEBUG_OUTPUT LD_BIND_NOW LD_ASSUME_KERNEL

  for env_name in $(compgen -v); do
    case "${env_name}" in
      DYLD_*)
        unset "${env_name}"
        ;;
    esac
  done
}

scrub_host_process_env

resolve_self_path() {
  local source_path="${BASH_SOURCE[0]}"
  local source_dir=""
  local link_target=""

  if [[ "${source_path}" != */* ]]; then
    source_path="$(command -v -- "${source_path}")"
  fi

  while [[ -L "${source_path}" ]]; do
    source_dir="$(cd -P "$(dirname "${source_path}")" && pwd)"
    link_target="$(readlink "${source_path}")"
    if [[ "${link_target}" == /* ]]; then
      source_path="${link_target}"
    else
      source_path="${source_dir}/${link_target}"
    fi
  done

  printf '%s\n' "${source_path}"
}

ROOT_DIR="$(cd -P "$(dirname "$(resolve_self_path)")/.." && pwd)"
# shellcheck source=/dev/null
source "${ROOT_DIR}/runtime/container/assurance.sh"
# shellcheck source=/dev/null
source "${ROOT_DIR}/scripts/lib/trusted-docker-client.sh"
resolve_fixed_host_tool() {
  local name="$1"
  shift
  local candidate

  for candidate in "$@"; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  echo "Missing trusted host tool: ${name}" >&2
  exit 1
}

HOST_PYTHON3_BIN="$(resolve_fixed_host_tool python3 /usr/bin/python3 /opt/homebrew/bin/python3 /usr/local/bin/python3)"
REAL_HOME="$(
  env -i PATH="${TRUSTED_HOST_PATH}" "${HOST_PYTHON3_BIN}" - <<'PY'
import os
import pwd
print(pwd.getpwuid(os.getuid()).pw_dir)
PY
)"
HOST_GIT_BIN=""
HOST_COLIMA_BIN=""
HOST_DOCKER_BIN=""
HOST_RUBY_BIN=""
COLIMA_STATE_ROOT="${REAL_HOME}/.colima"
# shellcheck disable=SC2034
WORKCELL_DOCKER_SANDBOX_ROOT=""
PROFILE_PREEXISTED=0
PROFILE_RUNNING=0
PROFILE_VALIDATED=0
COLIMA_PROFILE=""
BOOTSTRAP_APPLIED=0
SESSION_AUDIT_DIR=""
SESSION_AUDIT_STATE_FILE=""
SESSION_AUDIT_EVENT_FILE=""

usage() {
  cat <<'EOF'
Usage: workcell [options] [-- provider-args...]

Options:
  --agent codex|claude|gemini   Provider to run (required)
  --agent-autonomy yolo|prompt  Provider approval posture (default: yolo)
  --agent-arg VALUE             Additional provider argv to append (repeatable)
  --codex-rules-mutability readonly|session
                                Codex execpolicy session mutability (default: readonly)
  --container-mutability ephemeral|readonly
                                Runtime rootfs posture (default: ephemeral)
  --container-cpu COUNT         Inner container CPU limit (default: unmanaged)
  --container-memory SIZE       Inner container memory limit (default: profile value)
  --injection-policy PATH       Host-side injection policy to stage into each session
  --no-default-injection-policy Ignore ~/.config/workcell/injection-policy.toml for this launch
  --ui cli|gui                  Surface to launch (default: cli)
  --mode strict|build|breakglass
                                Runtime profile (default: strict)
  --prepare                     Seed or refresh the reviewed runtime image before launch
  --repair-profile              Delete a conflicting unmanaged Colima profile before launch
                                (implies --prepare on strict)
  --ack-breakglass              Required with --mode breakglass
  --ack-arbitrary-command       Required with --allow-arbitrary-command
  --workspace PATH              Workspace to mount (default: current directory)
  --allow-nongit-workspace      Allow a non-git workspace only when it contains an explicit agent marker
  --allow-arbitrary-command     Launch the runtime image with a direct container entrypoint after --
  --colima-profile NAME         Override derived Colima profile name
  --vm-cpu COUNT                Colima VM CPU count (default: profile value)
  --vm-memory GIB               Colima VM memory in GiB (default: profile value)
  --vm-disk GIB                 Colima VM disk in GiB (default: profile value)
  --rebuild                     Rebuild the runtime image before launch
  --dry-run                     Print the selected runtime command and exit
  -h, --help                    Show this help text

Workflows:
  First run:
    workcell --prepare --agent codex --workspace /path/to/repo
    workcell --prepare --agent claude --workspace /path/to/repo
    workcell --prepare --agent gemini --workspace /path/to/repo
  Normal run:
    workcell --agent codex --workspace /path/to/repo
    workcell --agent claude --workspace /path/to/repo
    workcell --agent gemini --workspace /path/to/repo
  Repair a conflicting unmanaged profile:
    workcell --repair-profile --agent codex --workspace /path/to/repo
    workcell --repair-profile --agent claude --workspace /path/to/repo
    workcell --repair-profile --agent gemini --workspace /path/to/repo

Workcell launches the selected provider directly inside the bounded runtime.
There is no separate container attach/connect step after launch.
EOF
}

slugify() {
  echo "$1" |
    tr '[:upper:]' '[:lower:]' |
    tr -cs 'a-z0-9' '-' |
    sed -E 's/^-+//; s/-+$//; s/-+/-/g'
}

generate_session_suffix() {
  env -i PATH="${TRUSTED_HOST_PATH}" "${HOST_PYTHON3_BIN}" - <<'PY'
import secrets

print(secrets.token_hex(4))
PY
}

lower_ascii() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

option_value_or_die() {
  local option_name="$1"
  local option_value="${2-}"

  if [[ -z "${option_value}" ]] || [[ "${option_value}" == --* ]]; then
    echo "Option ${option_name} requires a value." >&2
    usage >&2
    exit 2
  fi

  printf '%s\n' "${option_value}"
}

raw_option_value_or_die() {
  local option_name="$1"
  local option_value="${2-}"

  if [[ -z "${option_value}" ]]; then
    echo "Option ${option_name} requires a value." >&2
    usage >&2
    exit 2
  fi

  printf '%s\n' "${option_value}"
}

validate_agent_autonomy_name() {
  case "$1" in
    yolo | prompt) ;;
    *)
      echo "Unsupported agent autonomy mode: $1" >&2
      echo "Use --agent-autonomy yolo or --agent-autonomy prompt." >&2
      exit 2
      ;;
  esac
}

validate_codex_rules_mutability_name() {
  case "$1" in
    readonly | session) ;;
    *)
      echo "Unsupported Codex rules mutability: $1" >&2
      echo "Use --codex-rules-mutability readonly or --codex-rules-mutability session." >&2
      exit 2
      ;;
  esac
}

validate_colima_profile_name() {
  local profile="$1"

  if [[ ! "${profile}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]]; then
    echo "Invalid Colima profile name: ${profile}" >&2
    echo "Use only letters, numbers, '.', '_', or '-' and do not include path separators." >&2
    exit 2
  fi

  case "${profile}" in
    . | ..)
      echo "Invalid Colima profile name: ${profile}" >&2
      exit 2
      ;;
  esac
}

profile_dir() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s\n' "${COLIMA_STATE_ROOT}" "${profile}"
}

profile_lima_dir() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/_lima/colima-%s\n' "${COLIMA_STATE_ROOT}" "${profile}"
}

run_host_colima() {
  COLIMA_HOME="${COLIMA_STATE_ROOT}" "${HOST_COLIMA_BIN}" "$@"
}

sanitize_host_docker_env() {
  unset DOCKER_CONTEXT
  unset DOCKER_HOST
  unset DOCKER_TLS
  unset DOCKER_TLS_VERIFY
  unset DOCKER_CERT_PATH
  unset DOCKER_CLI_PLUGIN_EXTRA_DIRS
  unset BUILDKIT_HOST
  unset DOCKER_CONFIG
  setup_workcell_trusted_docker_client
}

CONTROL_PLANE_SHADOW_ROOT=""
INJECTION_BUNDLE_ROOT=""
DIRECT_MOUNT_SPEC_PATH=""
PROFILE_AUDIT_LOG_STASH=""
PRESERVE_FAILED_PROFILE_STATE=0
declare -a SHADOW_MOUNTS=()
declare -a SHADOW_DEST_PATHS=()
declare -a DIRECT_SOURCE_MOUNTS=()
declare -a WORKSPACE_IMPORT_MOUNTS=()

# shellcheck disable=SC2317,SC2329
cleanup() {
  if [[ -n "${CONTROL_PLANE_SHADOW_ROOT}" ]] && [[ -e "${CONTROL_PLANE_SHADOW_ROOT}" ]]; then
    chmod -R u+w "${CONTROL_PLANE_SHADOW_ROOT}" 2>/dev/null || true
    rm -rf "${CONTROL_PLANE_SHADOW_ROOT}"
  fi

  if [[ -n "${INJECTION_BUNDLE_ROOT}" ]] && [[ -e "${INJECTION_BUNDLE_ROOT}" ]]; then
    chmod -R u+w "${INJECTION_BUNDLE_ROOT}" 2>/dev/null || true
    rm -rf "${INJECTION_BUNDLE_ROOT}"
  fi

  if [[ -n "${DIRECT_MOUNT_SPEC_PATH}" ]] && [[ -e "${DIRECT_MOUNT_SPEC_PATH}" ]]; then
    chmod u+w "${DIRECT_MOUNT_SPEC_PATH}" 2>/dev/null || true
    rm -f "${DIRECT_MOUNT_SPEC_PATH}"
  fi

  if [[ -n "${PROFILE_AUDIT_LOG_STASH}" ]] && [[ -e "${PROFILE_AUDIT_LOG_STASH}" ]]; then
    if [[ -n "${COLIMA_PROFILE:-}" ]]; then
      restore_profile_audit_log "${COLIMA_PROFILE}" || true
      PRESERVE_FAILED_PROFILE_STATE=1
    fi
  fi

  if [[ -n "${PROFILE_AUDIT_LOG_STASH}" ]] && [[ -e "${PROFILE_AUDIT_LOG_STASH}" ]]; then
    chmod u+w "${PROFILE_AUDIT_LOG_STASH}" 2>/dev/null || true
    rm -f "${PROFILE_AUDIT_LOG_STASH}"
  fi

  if [[ -n "${SESSION_AUDIT_DIR}" ]] && [[ -e "${SESSION_AUDIT_DIR}" ]]; then
    chmod -R u+w "${SESSION_AUDIT_DIR}" 2>/dev/null || true
    rm -rf "${SESSION_AUDIT_DIR}"
  fi

  if [[ -n "${CONTAINER_NAME:-}" ]] && [[ -n "${HOST_DOCKER_BIN:-}" ]]; then
    "${HOST_DOCKER_BIN}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
  fi

  cleanup_workcell_trusted_docker_client
  if [[ "${PROFILE_RUNNING}" -eq 1 ]] &&
    [[ -n "${COLIMA_PROFILE}" ]] &&
    [[ -n "${HOST_COLIMA_BIN}" ]]; then
    if [[ "${PROFILE_VALIDATED}" -eq 0 ]] && [[ "${PROFILE_PREEXISTED}" -eq 0 ]]; then
      if [[ "${PRESERVE_FAILED_PROFILE_STATE}" -eq 1 ]]; then
        run_host_colima stop --profile "${COLIMA_PROFILE}" >/dev/null 2>&1 || true
      else
        run_host_colima delete --profile "${COLIMA_PROFILE}" --force >/dev/null 2>&1 || true
      fi
    else
      run_host_colima stop --profile "${COLIMA_PROFILE}" >/dev/null 2>&1 || true
    fi
  fi
}

trap cleanup EXIT

profile_marker_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/workcell.managed\n' "$(profile_dir "${profile}")"
}

profile_image_marker_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/workcell.image-ready\n' "$(profile_dir "${profile}")"
}

profile_image_marker_value() {
  local profile="$1"
  local key="$2"
  local marker_path=""

  marker_path="$(profile_image_marker_path "${profile}")"
  [[ -f "${marker_path}" ]] || return 1
  sed -n "s/^${key}=//p" "${marker_path}" | head -n1
}

profile_audit_log_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/workcell.audit.log\n' "$(profile_dir "${profile}")"
}

stash_profile_audit_log() {
  local profile="$1"
  local audit_log=""

  audit_log="$(profile_audit_log_path "${profile}")"
  [[ -f "${audit_log}" ]] || return 0

  PROFILE_AUDIT_LOG_STASH="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-log.XXXXXX")"
  cp "${audit_log}" "${PROFILE_AUDIT_LOG_STASH}"
  chmod 0600 "${PROFILE_AUDIT_LOG_STASH}" 2>/dev/null || true
}

restore_profile_audit_log() {
  local profile="$1"
  local audit_log=""
  local merged_log=""

  [[ -n "${PROFILE_AUDIT_LOG_STASH}" ]] || return 0
  [[ -f "${PROFILE_AUDIT_LOG_STASH}" ]] || {
    PROFILE_AUDIT_LOG_STASH=""
    return 0
  }

  audit_log="$(profile_audit_log_path "${profile}")"
  mkdir -p "$(dirname "${audit_log}")"
  if [[ -f "${audit_log}" ]] && [[ -s "${audit_log}" ]]; then
    merged_log="$(mktemp "${TMPDIR:-/tmp}/workcell-audit-merged.XXXXXX")"
    cat "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}" >"${merged_log}"
    chmod 0600 "${merged_log}" 2>/dev/null || true
    mv "${merged_log}" "${audit_log}"
  else
    cp "${PROFILE_AUDIT_LOG_STASH}" "${audit_log}"
  fi
  chmod 0600 "${audit_log}" 2>/dev/null || true
  rm -f "${PROFILE_AUDIT_LOG_STASH}"
  PROFILE_AUDIT_LOG_STASH=""
}

read_profile_marker_workspace() {
  local marker_path
  marker_path="$(profile_marker_path "$1")"
  [[ -f "${marker_path}" ]] || return 1
  tr -d '\n' <"${marker_path}"
}

append_audit_record() {
  local profile="$1"
  shift
  local audit_path
  local timestamp

  audit_path="$(profile_audit_log_path "${profile}")"
  mkdir -p "$(dirname "${audit_path}")"
  umask 077
  touch "${audit_path}"
  chmod 0600 "${audit_path}" 2>/dev/null || true
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  {
    printf 'timestamp=%q ' "${timestamp}"
    printf '%q ' "$@"
    printf '\n'
  } >>"${audit_path}"
}

maybe_fail_after_profile_refresh_for_tests() {
  if [[ "${TEST_FAIL_AFTER_PROFILE_REFRESH:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -z "${PROFILE_AUDIT_LOG_STASH}" ]]; then
    return 0
  fi
  echo "Workcell test hook: forcing failure after managed profile refresh." >&2
  exit 88
}

container_assurance() {
  workcell_container_assurance "${CONTAINER_MUTABILITY}"
}

autonomy_assurance() {
  workcell_autonomy_assurance "${AGENT_AUTONOMY}"
}

codex_rules_assurance() {
  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_codex_rules_assurance "${CODEX_RULES_MUTABILITY}"
}

codex_rules_effective_mutability_with_session_assurance() {
  local session_assurance="$1"

  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_effective_codex_rules_mutability "${CODEX_RULES_MUTABILITY}" "${AGENT_AUTONOMY}" "${session_assurance}"
}

codex_rules_effective_assurance_with_session_assurance() {
  local session_assurance="$1"

  if [[ "${AGENT}" != "codex" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  workcell_effective_codex_rules_assurance "${CODEX_RULES_MUTABILITY}" "${AGENT_AUTONOMY}" "${session_assurance}"
}

session_assurance_initial() {
  container_assurance
}

session_assurance_final() {
  local initial_assurance
  local final_assurance

  initial_assurance="$(session_assurance_initial)"
  final_assurance="${initial_assurance}"
  if [[ -n "${SESSION_AUDIT_EVENT_FILE}" ]] && [[ -r "${SESSION_AUDIT_EVENT_FILE}" ]] &&
    grep -q '^WORKCELL_EVENT package-mutation assurance=lower-assurance-package-mutation$' "${SESSION_AUDIT_EVENT_FILE}"; then
    printf '%s\n' "lower-assurance-package-mutation"
    return 0
  fi
  if [[ -n "${SESSION_AUDIT_STATE_FILE}" ]] && [[ -r "${SESSION_AUDIT_STATE_FILE}" ]]; then
    case "$(head -n1 "${SESSION_AUDIT_STATE_FILE}")" in
      lower-assurance-package-mutation)
        final_assurance="lower-assurance-package-mutation"
        ;;
    esac
  fi
  printf '%s\n' "${final_assurance}"
}

codex_rules_effective_mutability_initial() {
  codex_rules_effective_mutability_with_session_assurance "$(session_assurance_initial)"
}

codex_rules_effective_assurance_initial() {
  codex_rules_effective_assurance_with_session_assurance "$(session_assurance_initial)"
}

append_launch_audit_record() {
  local profile="$1"
  local execution_path="$2"

  append_audit_record "${profile}" \
    "event=launch" \
    "profile=${profile}" \
    "mode=${MODE}" \
    "agent=${AGENT}" \
    "agent_autonomy=${AGENT_AUTONOMY}" \
    "autonomy_assurance=$(autonomy_assurance)" \
    "codex_rules_mutability_configured=${CODEX_RULES_MUTABILITY}" \
    "codex_rules_assurance_configured=$(codex_rules_assurance)" \
    "codex_rules_mutability_effective_initial=$(codex_rules_effective_mutability_initial)" \
    "codex_rules_assurance_effective_initial=$(codex_rules_effective_assurance_initial)" \
    "ui=${UI}" \
    "network_policy=${NETWORK_POLICY}" \
    "execution_path=${execution_path}" \
    "workspace=${WORKSPACE}" \
    "endpoints=${ALLOW_ENDPOINTS}" \
    "bootstrap_applied=${BOOTSTRAP_APPLIED}" \
    "bootstrap_endpoints=$([[ "${BOOTSTRAP_APPLIED}" -eq 1 ]] && printf '%s' "${BOOTSTRAP_ENDPOINTS}" || printf '')" \
    "container_assurance=$(container_assurance)" \
    "session_assurance_initial=$(session_assurance_initial)"
}

append_assurance_change_audit_record() {
  local profile="$1"
  local final_assurance="$2"

  append_audit_record "${profile}" \
    "event=assurance-change" \
    "profile=${profile}" \
    "mode=${MODE}" \
    "agent=${AGENT}" \
    "workspace=${WORKSPACE}" \
    "reason=package-mutation" \
    "codex_rules_mutability_effective_final=$(codex_rules_effective_mutability_with_session_assurance "${final_assurance}")" \
    "codex_rules_assurance_effective_final=$(codex_rules_effective_assurance_with_session_assurance "${final_assurance}")" \
    "session_assurance_final=${final_assurance}"
}

append_exit_audit_record() {
  local profile="$1"
  local execution_path="$2"
  local exit_status="$3"
  local final_assurance="$4"
  local downgraded="$5"

  append_audit_record "${profile}" \
    "event=exit" \
    "profile=${profile}" \
    "mode=${MODE}" \
    "agent=${AGENT}" \
    "workspace=${WORKSPACE}" \
    "execution_path=${execution_path}" \
    "exit_status=${exit_status}" \
    "container_assurance=$(container_assurance)" \
    "autonomy_assurance=$(autonomy_assurance)" \
    "codex_rules_mutability_configured=${CODEX_RULES_MUTABILITY}" \
    "codex_rules_assurance_configured=$(codex_rules_assurance)" \
    "codex_rules_mutability_effective_final=$(codex_rules_effective_mutability_with_session_assurance "${final_assurance}")" \
    "codex_rules_assurance_effective_final=$(codex_rules_effective_assurance_with_session_assurance "${final_assurance}")" \
    "session_assurance_initial=$(session_assurance_initial)" \
    "session_assurance_final=${final_assurance}" \
    "package_mutation_downgraded=${downgraded}"
}

prepare_session_audit_state() {
  local profile="$1"

  mkdir -p "$(profile_dir "${profile}")"
  SESSION_AUDIT_DIR="$(mktemp -d "$(profile_dir "${profile}")/session-audit.XXXXXX")"
  chmod 0700 "${SESSION_AUDIT_DIR}" 2>/dev/null || true
  SESSION_AUDIT_STATE_FILE="${SESSION_AUDIT_DIR}/session-assurance"
  SESSION_AUDIT_EVENT_FILE="${SESSION_AUDIT_DIR}/events.log"
}

capture_session_audit_state() {
  local container_name="$1"

  [[ -n "${SESSION_AUDIT_STATE_FILE}" ]] || return 0
  mkdir -p "$(dirname "${SESSION_AUDIT_STATE_FILE}")"
  if ! "${HOST_DOCKER_BIN}" cp "${container_name}:/run/workcell/session-assurance" "${SESSION_AUDIT_STATE_FILE}" >/dev/null 2>&1; then
    :
  fi
  chmod 0600 "${SESSION_AUDIT_STATE_FILE}" 2>/dev/null || true
  if [[ -n "${SESSION_AUDIT_EVENT_FILE}" ]]; then
    mkdir -p "$(dirname "${SESSION_AUDIT_EVENT_FILE}")"
    "${HOST_DOCKER_BIN}" logs "${container_name}" >"${SESSION_AUDIT_EVENT_FILE}" 2>&1 || true
    chmod 0600 "${SESSION_AUDIT_EVENT_FILE}" 2>/dev/null || true
  fi
}

finalize_session_audit() {
  local profile="$1"
  local execution_path="$2"
  local exit_status="$3"
  local final_assurance
  local downgraded=0

  final_assurance="$(session_assurance_final)"
  if [[ "${final_assurance}" == "lower-assurance-package-mutation" ]]; then
    downgraded=1
    append_assurance_change_audit_record "${profile}" "${final_assurance}"
  fi
  append_exit_audit_record "${profile}" "${execution_path}" "${exit_status}" "${final_assurance}" "${downgraded}"
}

write_profile_image_marker() {
  local profile="$1"
  local image_id="$2"
  local marker_path

  marker_path="$(profile_image_marker_path "${profile}")"
  mkdir -p "$(dirname "${marker_path}")"
  umask 077
  printf 'image_tag=%s\nimage_id=%s\nsource_date_epoch=%s\n' "workcell:local" "${image_id}" "${SOURCE_DATE_EPOCH}" >"${marker_path}"
  chmod 0600 "${marker_path}" 2>/dev/null || true
}

current_image_id() {
  "${HOST_DOCKER_BIN}" image inspect "${IMAGE_TAG}" --format '{{.Id}}' 2>/dev/null || true
}

emit_command() {
  local -a cmd=("$@")

  printf '  '
  printf '%q ' "${cmd[@]}"
  printf '\n'
}

emit_redacted_command() {
  local token=""
  local redacted=""

  for token in "$@"; do
    case "${token}" in
      *:/opt/workcell/host-inputs/* | *:/opt/workcell/host-injections:ro)
        redacted="<redacted-host-path>:${token#*:}"
        ;;
      *)
        redacted="${token}"
        ;;
    esac
    printf '%q ' "${redacted}"
  done
  printf '\n'
}

resolve_host_path() {
  env -i PATH="${TRUSTED_HOST_PATH}" "${HOST_PYTHON3_BIN}" - "$1" <<'PY'
import os
import sys

print(os.path.realpath(os.path.expanduser(sys.argv[1])))
PY
}

resolve_existing_directory_or_die() {
  local raw_path="$1"
  local resolved_path=""

  resolved_path="$(resolve_host_path "${raw_path}")"
  if [[ ! -e "${resolved_path}" ]]; then
    echo "Workspace path does not exist: ${raw_path}" >&2
    echo "Resolve it to an existing directory, then rerun with --workspace ${resolved_path}" >&2
    exit 2
  fi
  if [[ ! -d "${resolved_path}" ]]; then
    echo "Workspace path is not a directory: ${resolved_path}" >&2
    exit 2
  fi

  printf '%s\n' "${resolved_path}"
}

default_injection_policy_path() {
  printf '%s/.config/workcell/injection-policy.toml\n' "${REAL_HOME}"
}

default_injection_bundle_parent() {
  resolve_host_path "${XDG_STATE_HOME:-${REAL_HOME}/.local/state}/workcell/tmp"
}

cleanup_stale_injection_bundles() {
  local bundle_parent="$1"

  run_clean_host_command "${HOST_PYTHON3_BIN}" - "${bundle_parent}" <<'PY'
import os
import json
import shutil
import subprocess
import sys
import time
from pathlib import Path

root = Path(sys.argv[1]).expanduser()
if not root.exists():
    raise SystemExit(0)

cutoff = time.time() - (12 * 60 * 60)
uid = os.getuid()

def process_start(pid):
    try:
        return subprocess.check_output(
            ["ps", "-o", "lstart=", "-p", str(pid)],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip() or None
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None

def sidecar_path(bundle_dir: Path) -> Path:
    return bundle_dir.parent / f"{bundle_dir.name}.mounts.json"

for candidate in root.iterdir():
    if not candidate.name.startswith("workcell-injections."):
        continue
    try:
        stat = candidate.lstat()
    except FileNotFoundError:
        continue
    if stat.st_uid != uid:
        continue
    if not candidate.is_dir() or candidate.is_symlink():
        continue
    owner_meta_path = candidate / "owner.json"
    owner_pid = None
    owner_started = None
    if owner_meta_path.is_file():
        try:
            owner_meta = json.loads(owner_meta_path.read_text(encoding="utf-8"))
        except (OSError, ValueError, json.JSONDecodeError):
            owner_meta = {}
        owner_pid = owner_meta.get("pid")
        owner_started = owner_meta.get("started")
    if isinstance(owner_pid, int):
        current_start = process_start(owner_pid)
        if current_start is not None and current_start == owner_started:
            continue
    elif stat.st_mtime > cutoff:
        continue
    shutil.rmtree(candidate, ignore_errors=False)
    try:
        sidecar = sidecar_path(candidate)
        if sidecar.is_file():
            sidecar.unlink()
    except FileNotFoundError:
        pass

for candidate in root.iterdir():
    if not candidate.name.startswith("workcell-injections.") or not candidate.name.endswith(".mounts.json"):
        continue
    try:
        stat = candidate.lstat()
    except FileNotFoundError:
        continue
    if stat.st_uid != uid or not candidate.is_file() or candidate.is_symlink():
        continue
    if (root / candidate.name.removesuffix(".mounts.json")).exists():
        continue
    candidate.unlink()
PY
}

prepare_injection_direct_mounts() {
  local mount_spec_path="$1"
  local host_source=""
  local mount_path=""

  DIRECT_SOURCE_MOUNTS=()
  [[ -f "${mount_spec_path}" ]] || return 0

  while IFS=$'\t' read -r host_source mount_path; do
    [[ -n "${host_source}" ]] || continue

    if [[ "${host_source}" != /* ]] || [[ ! -e "${host_source}" ]] ||
      { [[ ! -f "${host_source}" ]] && [[ ! -d "${host_source}" ]]; }; then
      echo "Direct input source is missing, not absolute, or not a regular file/directory: ${host_source}" >&2
      exit 2
    fi

    case "${mount_path}" in
      /opt/workcell/host-inputs/*) ;;
      *)
        echo "Direct input mount path is outside the managed host-input root: ${mount_path}" >&2
        exit 2
        ;;
    esac

    DIRECT_SOURCE_MOUNTS+=(-v "${host_source}:${mount_path}:ro")
  done < <(
    run_clean_host_command "${HOST_PYTHON3_BIN}" - "${mount_spec_path}" <<'PY'
import json
import sys
from pathlib import Path

entries = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
for entry in entries:
    source = entry["source"]
    mount_path = entry["mount_path"]
    print(f"{source}\t{mount_path}")
PY
  )
}

prepare_injection_bundle() {
  local agent="$1"
  local mode="$2"
  local policy_path="${INJECTION_POLICY}"
  local bundle_parent=""
  local default_policy_path=""
  local manifest_path=""

  if [[ -z "${policy_path}" ]] && [[ "${USE_DEFAULT_INJECTION_POLICY}" -eq 1 ]]; then
    default_policy_path="$(default_injection_policy_path)"
    if [[ -f "${default_policy_path}" ]]; then
      policy_path="${default_policy_path}"
    fi
  fi

  if [[ -z "${policy_path}" ]]; then
    return 0
  fi

  policy_path="$(resolve_host_path "${policy_path}")"
  if [[ ! -f "${policy_path}" ]]; then
    echo "Injection policy file does not exist: ${policy_path}" >&2
    exit 2
  fi

  bundle_parent="$(default_injection_bundle_parent)"
  mkdir -p "${bundle_parent}"
  chmod 0700 "${bundle_parent}" 2>/dev/null || true
  cleanup_stale_injection_bundles "${bundle_parent}"
  INJECTION_BUNDLE_ROOT="$(mktemp -d "${bundle_parent%/}/workcell-injections.XXXXXX")"
  INJECTION_BUNDLE_ROOT="$(resolve_host_path "${INJECTION_BUNDLE_ROOT}")"
  chmod 0700 "${INJECTION_BUNDLE_ROOT}"
  run_clean_host_command "${HOST_PYTHON3_BIN}" - "${INJECTION_BUNDLE_ROOT}/owner.json" "$$" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

started = subprocess.check_output(
    ["ps", "-o", "lstart=", "-p", sys.argv[2]],
    text=True,
    stderr=subprocess.DEVNULL,
).strip()
owner_path = Path(sys.argv[1])
owner_path.write_text(
    json.dumps({"pid": int(sys.argv[2]), "started": started}, sort_keys=True) + "\n",
    encoding="utf-8",
)
owner_path.chmod(0o600)
PY

  manifest_path="$(run_clean_host_command \
    "${HOST_PYTHON3_BIN}" \
    "${ROOT_DIR}/scripts/lib/render_injection_bundle.py" \
    --policy "${policy_path}" \
    --agent "${agent}" \
    --mode "${mode}" \
    --output-root "${INJECTION_BUNDLE_ROOT}")"
  manifest_path="${manifest_path//$'\n'/}"

  if [[ "${manifest_path}" != "${INJECTION_BUNDLE_ROOT}/manifest.json" ]]; then
    echo "Unexpected injection manifest path from renderer: ${manifest_path}" >&2
    exit 2
  fi

  if [[ ! -f "${manifest_path}" ]]; then
    echo "Injection manifest was not rendered: ${manifest_path}" >&2
    exit 2
  fi

  DIRECT_MOUNT_SPEC_PATH="${INJECTION_BUNDLE_ROOT}.mounts.json"
  DIRECT_MOUNT_SPEC_PATH="$(resolve_host_path "${DIRECT_MOUNT_SPEC_PATH}")"
  run_clean_host_command \
    "${HOST_PYTHON3_BIN}" \
    "${ROOT_DIR}/scripts/lib/extract_direct_mounts.py" \
    --manifest "${manifest_path}" \
    --mount-spec "${DIRECT_MOUNT_SPEC_PATH}" >/dev/null
  prepare_injection_direct_mounts "${DIRECT_MOUNT_SPEC_PATH}"
}

build_recommended_command() {
  local include_prepare="$1"
  local include_repair="$2"
  local target_mode="${3}"
  local -a cmd=("workcell")

  if [[ "${include_repair}" -eq 1 ]] && [[ "${target_mode}" == "strict" ]]; then
    include_prepare=0
  fi
  [[ "${include_prepare}" -eq 1 ]] && cmd+=(--prepare)
  [[ "${include_repair}" -eq 1 ]] && cmd+=(--repair-profile)
  cmd+=(--agent "${AGENT}")
  [[ "${AGENT_AUTONOMY}" != "yolo" ]] && cmd+=(--agent-autonomy "${AGENT_AUTONOMY}")
  [[ "${CONTAINER_MUTABILITY}" != "ephemeral" ]] && cmd+=(--container-mutability "${CONTAINER_MUTABILITY}")
  [[ -n "${CONTAINER_CPU_OVERRIDE}" ]] && cmd+=(--container-cpu "${CONTAINER_CPU_OVERRIDE}")
  [[ -n "${CONTAINER_MEMORY_OVERRIDE}" ]] && cmd+=(--container-memory "${CONTAINER_MEMORY_OVERRIDE}")
  [[ "${USE_DEFAULT_INJECTION_POLICY}" -eq 0 ]] && cmd+=(--no-default-injection-policy)
  [[ -n "${INJECTION_POLICY}" ]] && cmd+=(--injection-policy "${INJECTION_POLICY}")
  [[ "${UI}" != "cli" ]] && cmd+=(--ui "${UI}")
  cmd+=(--mode "${target_mode}" --workspace "${WORKSPACE}")
  [[ "${ALLOW_NONGIT_WORKSPACE}" -eq 1 ]] && cmd+=(--allow-nongit-workspace)
  [[ -n "${COLIMA_PROFILE}" ]] && cmd+=(--colima-profile "${COLIMA_PROFILE}")
  [[ -n "${VM_CPU_OVERRIDE}" ]] && cmd+=(--vm-cpu "${VM_CPU_OVERRIDE}")
  [[ -n "${VM_MEMORY_OVERRIDE}" ]] && cmd+=(--vm-memory "${VM_MEMORY_OVERRIDE}")
  [[ -n "${VM_DISK_OVERRIDE}" ]] && cmd+=(--vm-disk "${VM_DISK_OVERRIDE}")
  if ((${#AGENT_ARGS[@]} > 0)); then
    local agent_arg
    for agent_arg in "${AGENT_ARGS[@]}"; do
      cmd+=(--agent-arg "${agent_arg}")
    done
  fi
  if [[ "${ALLOW_ARBITRARY_COMMAND}" -eq 1 ]]; then
    cmd+=(--allow-arbitrary-command --ack-arbitrary-command)
  fi
  if [[ "${ACK_BREAKGLASS}" -eq 1 ]]; then
    cmd+=(--ack-breakglass)
  fi
  if [[ "${REBUILD}" -eq 1 ]]; then
    cmd+=(--rebuild)
  fi
  if ((${#PROVIDER_ARGS[@]} > 0)); then
    cmd+=(-- "${PROVIDER_ARGS[@]}")
  fi

  emit_command "${cmd[@]}"
}

delete_unmanaged_profile() {
  local profile="$1"
  local state_dir
  local lima_dir

  state_dir="$(profile_dir "${profile}")"
  lima_dir="$(profile_lima_dir "${profile}")"

  echo "Repairing conflicting unmanaged Colima profile: ${profile}" >&2
  echo "Workcell will delete the profile state and recreate it with reviewed mounts and policy." >&2

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    printf 'repair_action=delete_unmanaged_profile profile=%s dry_run=1\n' "${profile}" >&2
    return 0
  fi

  HOST_COLIMA_BIN="${HOST_COLIMA_BIN:-$(resolve_host_tool colima /opt/homebrew/bin/colima /usr/local/bin/colima)}"
  export COLIMA_HOME="${COLIMA_STATE_ROOT}"
  run_host_colima delete --profile "${profile}" --force >/dev/null 2>&1 || true
  rm -rf "${state_dir}" "${lima_dir}"

  if [[ -e "${state_dir}" ]] || [[ -e "${lima_dir}" ]]; then
    echo "Failed to remove conflicting Colima profile state for ${profile}." >&2
    exit 2
  fi
}

workspace_has_markers() {
  local path="$1"
  [[ -n "${HOST_GIT_BIN}" ]] || return 1
  "${HOST_GIT_BIN}" -C "${path}" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

workspace_has_agent_markers() {
  local path="$1"
  [[ -f "${path}/AGENTS.md" ]] ||
    [[ -f "${path}/CLAUDE.md" ]] ||
    [[ -f "${path}/GEMINI.md" ]]
}

workspace_gitdir_is_self_contained() {
  local path="$1"
  local git_dir
  local git_top_level

  [[ -n "${HOST_GIT_BIN}" ]] || return 1
  git_dir="$("${HOST_GIT_BIN}" -C "${path}" rev-parse --absolute-git-dir 2>/dev/null || true)"
  [[ -n "${git_dir}" ]] || return 1
  git_top_level="$("${HOST_GIT_BIN}" -C "${path}" rev-parse --show-toplevel 2>/dev/null || true)"
  [[ "${git_top_level}" == "${path}" ]] || return 1

  case "${git_dir}" in
    "${path}/.git" | "${path}/.git/"*)
      return 0
      ;;
  esac

  return 1
}

workspace_is_sensitive() {
  local path="$1"
  local path_lower
  local real_home_lower
  local pattern
  local sensitive_roots=(
    "${REAL_HOME}/.ssh"
    "${REAL_HOME}/.aws"
    "${REAL_HOME}/.azure"
    "${REAL_HOME}/.config"
    "${REAL_HOME}/.docker"
    "${REAL_HOME}/.npm"
    "${REAL_HOME}/.gem"
    "${REAL_HOME}/.gnupg"
    "${REAL_HOME}/.kube"
    "${REAL_HOME}/.config/gh"
    "${REAL_HOME}/Library/Keychains"
    "${REAL_HOME}/Library/Application Support"
    "${REAL_HOME}/Library/Containers"
    "${REAL_HOME}/Library/Group Containers"
  )
  real_home_lower="$(lower_ascii "${REAL_HOME}")"
  local sensitive_patterns=(
    "${real_home_lower}/library/application support/google/chrome*"
    "${real_home_lower}/library/application support/google/chrome beta*"
    "${real_home_lower}/library/application support/chromium*"
    "${real_home_lower}/library/application support/bravesoftware/brave-browser*"
    "${real_home_lower}/library/application support/microsoft edge*"
    "${real_home_lower}/library/application support/firefox*"
    "${real_home_lower}/library/application support/arc/user data*"
    "${real_home_lower}/library/application support/com.operasoftware.opera*"
    "${real_home_lower}/library/safari*"
    "${real_home_lower}/library/containers/com.apple.safari*"
    "${real_home_lower}/library/application support/*metamask*"
    "${real_home_lower}/library/application support/*phantom*"
    "${real_home_lower}/library/application support/*solflare*"
    "${real_home_lower}/library/application support/*electrum*"
    "${real_home_lower}/library/application support/*exodus*"
  )
  local root

  path_lower="$(lower_ascii "${path}")"

  for root in "${sensitive_roots[@]}"; do
    if [[ "${path}" == "${root}" ]] || [[ "${path}" == "${root}/"* ]]; then
      return 0
    fi
  done

  for pattern in "${sensitive_patterns[@]}"; do
    # shellcheck disable=SC2053
    if [[ "${path_lower}" == ${pattern} ]]; then
      return 0
    fi
  done

  return 1
}

validate_workspace() {
  local path="$1"
  local allow_nongit="$2"

  if [[ "${path}" == "/" ]] || [[ "${path}" == "${REAL_HOME}" ]]; then
    echo "Refusing broad workspace mount: ${path}" >&2
    exit 2
  fi

  if workspace_is_sensitive "${path}"; then
    echo "Refusing sensitive workspace mount: ${path}" >&2
    exit 2
  fi

  if workspace_has_markers "${path}"; then
    if ! workspace_gitdir_is_self_contained "${path}"; then
      echo "Refusing git workspace with admin state outside the mounted workspace: ${path}" >&2
      echo "Use a standard checkout on the safe path; linked worktrees require breakglass or a different clone." >&2
      exit 2
    fi
    return
  fi

  if [[ "${allow_nongit}" -eq 1 ]] && workspace_has_agent_markers "${path}"; then
    return
  fi

  if [[ "${allow_nongit}" -eq 0 ]]; then
    echo "Workspace is not a git worktree: ${path}" >&2
    echo "Use --allow-nongit-workspace only when you intentionally want a marker-based workspace." >&2
  else
    echo "Non-git workspace lacks an explicit agent marker file: ${path}" >&2
    echo "Create AGENTS.md, CLAUDE.md, or GEMINI.md before using --allow-nongit-workspace." >&2
  fi
  exit 2
}

run_clean_host_command() {
  local home="${REAL_HOME:-/}"

  env -i \
    PATH="${TRUSTED_HOST_PATH}" \
    HOME="${home}" \
    LC_ALL=C \
    LANG=C \
    "$@"
}

validate_mode_requirements() {
  local mode="$1"
  local ack_breakglass="$2"
  local allow_arbitrary_command="$3"
  local ack_arbitrary_command="$4"
  local rebuild="$5"
  local prepare="$6"

  if [[ "${mode}" == "breakglass" ]] && [[ "${ack_breakglass}" -eq 0 ]]; then
    echo "breakglass mode requires --ack-breakglass." >&2
    echo "Use it only when you intentionally want to disable the normal Workcell policy boundary." >&2
    exit 2
  fi

  if [[ "${allow_arbitrary_command}" -eq 1 ]] && [[ "${ack_arbitrary_command}" -eq 0 ]]; then
    echo "arbitrary command mode requires --ack-arbitrary-command." >&2
    echo "Use it only for lower-assurance boundary debugging when you intentionally want to bypass provider command mediation." >&2
    exit 2
  fi

  if [[ "${mode}" == "strict" ]] && [[ "${rebuild}" -eq 1 ]] && [[ "${prepare}" -eq 0 ]]; then
    echo "strict mode does not rebuild or cold-bootstrap the runtime image." >&2
    echo "Rerun with --prepare when you intentionally want Workcell to seed the reviewed image before strict launch." >&2
    exit 2
  fi
}

validate_mode_name() {
  case "$1" in
    strict | build | breakglass) ;;
    *)
      echo "Unsupported mode: $1" >&2
      exit 2
      ;;
  esac
}

validate_container_mutability() {
  case "$1" in
    ephemeral | readonly) ;;
    *)
      echo "Unsupported container mutability: $1" >&2
      exit 2
      ;;
  esac
}

validate_positive_integer() {
  local label="$1"
  local value="$2"

  [[ "${value}" =~ ^[1-9][0-9]*$ ]] || {
    echo "Unsupported ${label}: ${value}" >&2
    exit 2
  }
}

validate_positive_decimal() {
  local label="$1"
  local value="$2"

  [[ "${value}" =~ ^[0-9]+([.][0-9]+)?$ ]] || {
    echo "Unsupported ${label}: ${value}" >&2
    exit 2
  }
}

validate_container_memory_value() {
  local value="$1"

  [[ "${value}" =~ ^[0-9]+([kKmMgGtTpP][iI]?[bB]?)?$ ]] || {
    echo "Unsupported container memory limit: ${value}" >&2
    exit 2
  }
}

profile_env_path() {
  case "$1" in
    strict)
      printf '%s/runtime/profiles/strict.env\n' "${ROOT_DIR}"
      ;;
    build)
      printf '%s/runtime/profiles/build.env\n' "${ROOT_DIR}"
      ;;
    breakglass)
      printf '%s/runtime/profiles/breakglass.env\n' "${ROOT_DIR}"
      ;;
    *)
      echo "Unsupported mode: $1" >&2
      exit 2
      ;;
  esac
}

derive_profile_name() {
  local workspace="$1"
  local slug hash
  slug="$(slugify "$(basename "${workspace}")" | cut -c1-10)"
  [[ -n "${slug}" ]] || slug="workspace"
  hash="$(
    run_clean_host_command "${HOST_PYTHON3_BIN}" - "${workspace}" <<'PY'
import hashlib
import sys

print(hashlib.sha256(sys.argv[1].encode("utf-8")).hexdigest()[:8])
PY
  )"
  printf 'workcell-%s-%s\n' "${slug}" "${hash}"
}

validate_colima_runtime_mounts() {
  local profile="$1"
  local workspace="$2"
  local lima_path="${COLIMA_STATE_ROOT}/_lima/colima-${profile}/lima.yaml"

  [[ -f "${lima_path}" ]] || {
    echo "Missing Lima config for profile ${profile}: ${lima_path}" >&2
    exit 2
  }

  run_clean_host_command "${HOST_RUBY_BIN}" -rpsych -rpathname -e '
    lima = Psych.safe_load(File.read(ARGV[0]), permitted_classes: [], permitted_symbols: [], aliases: false) || {}
    expected = ARGV[1].sub(%r{/$}, "")
    profile = ARGV[2]
    home = File.expand_path(ENV.fetch("HOME"))
    sandbox_home = ARGV[3].to_s.empty? ? nil : File.expand_path(ARGV[3])

    def canonicalize(path)
      expanded = File.expand_path(path)
      Pathname.new(expanded).exist? ? Pathname.new(expanded).realpath.to_s : Pathname.new(expanded).cleanpath.to_s
    end

    expected = canonicalize(expected)
    cache_roots = [canonicalize(File.join(home, "Library", "Caches", "colima"))]
    if sandbox_home
      cache_roots << canonicalize(File.join(sandbox_home, "Library", "Caches", "colima"))
    end
    lima_mounts = lima["mounts"] || []
    writable_mounts = lima_mounts.select { |mount| mount["writable"] == true }

    unless writable_mounts.length == 1 && canonicalize(writable_mounts.first["location"].sub(%r{/$}, "")) == expected
      warn "Colima profile #{profile} must mount only #{expected} as writable."
      exit 2
    end

    bad_mount = lima_mounts.find do |mount|
      location = canonicalize(mount["location"].sub(%r{/$}, ""))
      mount_point = mount["mountPoint"] || mount["mount_point"]
      writable = mount["writable"] == true
      if mount_point
        mount_point = canonicalize(mount_point.sub(%r{/$}, ""))
        next true unless mount_point == location
      end
      next false if !writable && cache_roots.any? { |root| location == root || location.start_with?(root + "/") }

      location == "~" || location == home || (writable && location != expected) || (!writable && location != expected)
    end

    if bad_mount
      warn "Colima profile #{profile} has an unexpected host mount: #{bad_mount["location"]}"
      exit 2
    end
  ' "${lima_path}" "${workspace}" "${profile}" "${WORKCELL_DOCKER_HOME:-}"
}

validate_colima_profile_config() {
  local profile="$1"
  local workspace="$2"
  local expected_cpu="$3"
  local expected_memory="$4"
  local expected_disk="$5"
  local config_path="${COLIMA_STATE_ROOT}/${profile}/colima.yaml"

  [[ -f "${config_path}" ]] || {
    echo "Missing Colima config for profile ${profile}: ${config_path}" >&2
    exit 2
  }

  run_clean_host_command "${HOST_RUBY_BIN}" -rpsych -e '
    config = Psych.safe_load(File.read(ARGV[0]), permitted_classes: [], permitted_symbols: [], aliases: false) || {}
    vm_type = config["vmType"] || config[:vmType] || config["vm_type"] || config[:vm_type]
    mount_type = config["mountType"] || config[:mountType] || config["mount_type"] || config[:mount_type]
    runtime = config["runtime"] || config[:runtime]
    expected = ARGV[1].sub(%r{/$}, "")
    expected_cpu = ARGV[2]
    expected_memory = ARGV[3]
    expected_disk = ARGV[4]
    cpu = config["cpu"] || config[:cpu]
    memory = config["memory"] || config[:memory]
    disk = config["disk"] || config[:disk]
    mounts = config["mounts"] || config[:mounts] || []
    runtime_name =
      case runtime
      when Hash
        runtime["name"] || runtime[:name]
      else
        runtime
      end

    expected = File.expand_path(expected)

    abort("Colima profile must not forward the SSH agent.") if config["forwardAgent"] == true || config[:forwardAgent] == true
    abort("Unexpected configured Colima mounts: #{mounts.inspect}") unless mounts.length == 1

    mount = mounts.first || {}
    location = File.expand_path((mount["location"] || mount[:location] || "").sub(%r{/$}, ""))
    writable = mount["writable"] == true || mount[:writable] == true
    abort("Colima profile must mount only #{expected} as writable in colima.yaml.") unless writable && location == expected

    abort("Unexpected Colima vmType for managed profile: #{vm_type.inspect}") unless vm_type == "vz"
    abort("Unexpected Colima mountType for managed profile: #{mount_type.inspect}") unless mount_type == "virtiofs"
    abort("Unexpected Colima runtime for managed profile: #{runtime_name.inspect}") unless runtime_name == "docker"
    abort("Unexpected Colima CPU count for managed profile: #{cpu.inspect}") unless cpu.to_s == expected_cpu
    abort("Unexpected Colima memory size for managed profile: #{memory.inspect}") unless memory.to_s == expected_memory
    abort("Unexpected Colima disk size for managed profile: #{disk.inspect}") unless disk.to_s == expected_disk
  ' "${config_path}" "${workspace}" "${expected_cpu}" "${expected_memory}" "${expected_disk}"
}

validate_colima_profile() {
  local profile="$1"
  local workspace="$2"
  local status

  status="$(run_host_colima status --profile "${profile}" 2>&1)"
  echo "${status}" | grep -q "Virtualization.Framework" || {
    echo "Colima profile ${profile} is not using Virtualization.Framework." >&2
    exit 2
  }
  echo "${status}" | grep -q "mountType: virtiofs" || {
    echo "Colima profile ${profile} is not using virtiofs." >&2
    exit 2
  }
  echo "${status}" | grep -q "runtime: docker" || {
    echo "Colima profile ${profile} is not using Docker runtime." >&2
    exit 2
  }

  validate_colima_profile_config "${profile}" "${workspace}" "${COLIMA_CPU}" "${COLIMA_MEMORY}" "${COLIMA_DISK}"
  validate_colima_runtime_mounts "${profile}" "${workspace}"
}

is_trusted_host_tool_path() {
  local candidate="$1"
  local trusted_prefixes=(
    /usr/bin
    /bin
    /usr/sbin
    /sbin
    /usr/local/bin
    /usr/local/Cellar
    /opt/homebrew/bin
    /opt/homebrew/Cellar
    /Applications/Docker.app/Contents/Resources/bin
  )
  local prefix

  [[ "${candidate}" = /* ]] || return 1

  case "${candidate}" in
    "${ROOT_DIR}"/* | "${WORKSPACE}"/*)
      return 1
      ;;
  esac

  for prefix in "${trusted_prefixes[@]}"; do
    case "${candidate}" in
      "${prefix}" | "${prefix}"/*)
        return 0
        ;;
    esac
  done

  return 1
}

canonicalize_host_tool_path() {
  local candidate="$1"
  if [[ -z "${HOST_PYTHON3_BIN}" ]]; then
    printf '%s\n' "${candidate}"
    return 0
  fi

  run_clean_host_command "${HOST_PYTHON3_BIN}" - "${candidate}" <<'PY'
import os
import sys

print(os.path.realpath(sys.argv[1]))
PY
}

resolve_host_tool() {
  local name="$1"
  shift
  local candidate
  local canonical_candidate

  for candidate in "$@"; do
    canonical_candidate="$(canonicalize_host_tool_path "${candidate}")"
    if [[ -x "${candidate}" ]] &&
      is_trusted_host_tool_path "${candidate}" &&
      is_trusted_host_tool_path "${canonical_candidate}"; then
      printf '%s\n' "${canonical_candidate}"
      return 0
    fi
  done

  candidate="$(type -P "${name}" || true)"
  canonical_candidate="$(canonicalize_host_tool_path "${candidate}")"
  if [[ -n "${candidate}" ]] &&
    is_trusted_host_tool_path "${candidate}" &&
    is_trusted_host_tool_path "${canonical_candidate}"; then
    printf '%s\n' "${canonical_candidate}"
    return 0
  fi

  echo "Missing trusted host tool: ${name}" >&2
  exit 1
}

if [[ "${1:-}" == "--self-docker-probe" ]]; then
  sanitize_host_docker_env
  buildx_cmd version >/dev/null
  echo "workcell-docker-probe-ok"
  exit 0
fi

provider_endpoints() {
  case "$1" in
    codex)
      echo "api.openai.com:443 auth.openai.com:443 chatgpt.com:443"
      ;;
    claude)
      echo "api.anthropic.com:443 claude.ai:443 console.anthropic.com:443"
      ;;
    gemini)
      echo "generativelanguage.googleapis.com:443 ai.google.dev:443"
      ;;
    *)
      return 1
      ;;
  esac
}

git_alias_value_is_blocked() {
  local alias_body="$1"
  local alias_body_lower normalized token saw_commit

  alias_body_lower="$(lower_ascii "${alias_body}")"
  normalized="$(printf '%s' "${alias_body_lower}" | tr "\t\r\n'\"" '     ')"

  if [[ "${alias_body_lower}" == '!'* ]]; then
    return 0
  fi

  if [[ "${alias_body_lower}" == *"--no-verify"* ]] ||
    [[ "${alias_body_lower}" == *"--exec-path"* ]] ||
    [[ "${alias_body_lower}" == *"--git-dir"* ]] ||
    [[ "${alias_body_lower}" == *"--work-tree"* ]] ||
    [[ "${alias_body_lower}" == *"git_exec_path="* ]] ||
    [[ "${alias_body_lower}" == *"git_dir="* ]] ||
    [[ "${alias_body_lower}" == *"git_work_tree="* ]] ||
    [[ "${alias_body_lower}" == *"git_common_dir="* ]] ||
    [[ "${alias_body_lower}" == *"core.hookspath"* ]] ||
    [[ "${alias_body_lower}" == *"include.path"* ]] ||
    [[ "${alias_body_lower}" == *"includeif."* ]]; then
    return 0
  fi

  saw_commit=0
  for token in ${normalized}; do
    if [[ "${token}" == "commit" ]]; then
      saw_commit=1
      continue
    fi
    if [[ "${saw_commit}" -eq 1 ]] && git_commit_short_arg_is_no_verify "${token}"; then
      return 0
    fi
  done

  return 1
}

git_commit_short_arg_is_no_verify() {
  local arg="$1"
  local bundle char i

  [[ "${arg}" == -?* ]] || return 1
  [[ "${arg}" == --* ]] && return 1

  bundle="${arg#-}"
  for ((i = 0; i < ${#bundle}; i++)); do
    char="${bundle:i:1}"
    case "${char}" in
      n)
        return 0
        ;;
      m | F | C | c | t | u | S)
        return 1
        ;;
    esac
  done

  return 1
}

sanitize_shadowed_git_config() {
  local config_path="$1"
  local key value

  [[ -f "${config_path}" ]] || return 0

  while IFS= read -r key; do
    case "$(lower_ascii "${key}")" in
      core.hookspath | core.worktree | include.path | includeif.*.path)
        "${HOST_GIT_BIN}" config --file "${config_path}" --unset-all "${key}" >/dev/null 2>&1 || true
        ;;
      alias.*)
        while IFS= read -r value; do
          if git_alias_value_is_blocked "${value}"; then
            "${HOST_GIT_BIN}" config --file "${config_path}" --unset-all "${key}" >/dev/null 2>&1 || true
            break
          fi
        done < <("${HOST_GIT_BIN}" config --file "${config_path}" --get-all "${key}" 2>/dev/null || true)
        ;;
    esac
  done < <("${HOST_GIT_BIN}" config --file "${config_path}" --name-only --get-regexp '.*' 2>/dev/null || true)
}

lock_tree_readonly() {
  local path="$1"

  [[ -d "${path}" ]] || return 0

  find "${path}" -type d -exec chmod 0555 {} +
  find "${path}" -type f -exec chmod 0444 {} +
}

shadow_dest_is_registered() {
  local destination="$1"
  local existing

  if ((${#SHADOW_DEST_PATHS[@]} == 0)); then
    return 1
  fi

  for existing in "${SHADOW_DEST_PATHS[@]}"; do
    [[ "${existing}" == "${destination}" ]] && return 0
  done
  return 1
}

shadow_dest_has_ancestor() {
  local destination="$1"
  local existing

  if ((${#SHADOW_DEST_PATHS[@]} == 0)); then
    return 1
  fi

  for existing in "${SHADOW_DEST_PATHS[@]}"; do
    case "${destination}" in
      "${existing}" | "${existing}"/*)
        return 0
        ;;
    esac
  done

  return 1
}

register_shadow_mount() {
  local source="$1"
  local destination="$2"

  if shadow_dest_is_registered "${destination}"; then
    return 0
  fi
  if shadow_dest_has_ancestor "${destination}"; then
    return 0
  fi

  SHADOW_MOUNTS+=(-v "${source}:${destination}:ro")
  SHADOW_DEST_PATHS+=("${destination}")
}

register_workspace_import_root_mount() {
  local source="${CONTROL_PLANE_SHADOW_ROOT}/imports"
  local destination="/opt/workcell/workspace-control-plane"

  [[ -d "${source}" ]] || return 0
  if ! find "${source}" -type f -print -quit | grep -q .; then
    return 0
  fi

  WORKSPACE_IMPORT_MOUNTS+=(-v "${source}:${destination}:ro")
}

add_shadow_file_mount() {
  local relative_path="$1"
  local source="${CONTROL_PLANE_SHADOW_ROOT}/files/${relative_path}"
  local destination="/workspace/${relative_path}"
  local placeholder_message="# Workcell masks workspace control files inside the boundary."

  mkdir -p "$(dirname "${source}")"
  printf '%s\n' "${placeholder_message}" >"${source}"
  chmod 0444 "${source}"
  register_shadow_mount "${source}" "${destination}"
}

add_shadow_dir_mount() {
  local relative_path="$1"
  local source="${CONTROL_PLANE_SHADOW_ROOT}/dirs/${relative_path}"
  local destination="/workspace/${relative_path}"

  mkdir -p "${source}"
  chmod 0555 "${source}"
  register_shadow_mount "${source}" "${destination}"
}

copy_tree_without_symlinks() {
  local source_root="$1"
  local destination_root="$2"
  local path=""
  local relative_path=""
  local destination_path=""

  [[ -d "${source_root}" ]] || return 0

  while IFS= read -r -d '' path; do
    relative_path="${path#"${source_root}/"}"
    destination_path="${destination_root}/${relative_path}"
    if [[ -d "${path}" ]]; then
      mkdir -p "${destination_path}"
    else
      mkdir -p "$(dirname "${destination_path}")"
      cp -p "${path}" "${destination_path}"
    fi
  done < <(
    find "${source_root}" -mindepth 1 \
      \( -type d -o -type f \) -print0 | LC_ALL=C sort -z
  )
}

add_workspace_import_file() {
  local workspace="$1"
  local relative_path="$2"
  local source="${CONTROL_PLANE_SHADOW_ROOT}/imports/${relative_path}"
  local doc_path=""

  while IFS= read -r -d '' doc_path; do
    echo "Workcell refuses symlinked workspace control files: ${doc_path}" >&2
    echo "Replace the symlink with a regular file under the workspace root." >&2
    exit 2
  done < <(
    find "${workspace}" \
      \( -name .git -type d -prune \) -o \
      \( -type l -name "${relative_path}" \) -print0 | LC_ALL=C sort -z
  )

  doc_path="${workspace}/${relative_path}"
  [[ -f "${doc_path}" ]] || return 0

  mkdir -p "$(dirname "${source}")"
  {
    printf '<!-- Workcell imported workspace %s -->\n\n' "${relative_path}"
    cat "${doc_path}"
    printf '\n'
  } >"${source}"
  chmod 0444 "${source}"
}

add_shadow_git_hooks_mount() {
  local workspace="$1"
  local relative_path="$2"
  local source="${CONTROL_PLANE_SHADOW_ROOT}/git/${relative_path}"
  local destination="/workspace/${relative_path}"
  local source_path="${workspace}/${relative_path}"

  mkdir -p "${source}"
  if [[ -d "${source_path}" && ! -L "${source_path}" ]]; then
    copy_tree_without_symlinks "${source_path}" "${source}"
  fi
  lock_tree_readonly "${source}"
  register_shadow_mount "${source}" "${destination}"
}

add_shadow_git_config_mount() {
  local workspace="$1"
  local relative_path="$2"
  local source="${CONTROL_PLANE_SHADOW_ROOT}/git/${relative_path}"
  local destination="/workspace/${relative_path}"
  local source_path="${workspace}/${relative_path}"

  mkdir -p "$(dirname "${source}")"
  if [[ -f "${source_path}" && ! -L "${source_path}" ]]; then
    cp "${source_path}" "${source}"
    sanitize_shadowed_git_config "${source}"
  else
    : >"${source}"
  fi
  chmod 0444 "${source}"
  register_shadow_mount "${source}" "${destination}"
}

add_shadow_git_path_if_present() {
  local workspace="$1"
  local relative_path="$2"
  local path="${workspace}/${relative_path}"

  [[ -e "${path}" ]] || return 0
  if [[ -d "${path}" ]]; then
    add_shadow_git_hooks_mount "${workspace}" "${relative_path}"
  else
    add_shadow_git_config_mount "${workspace}" "${relative_path}"
  fi
}

prepare_workspace_control_plane_shadow() {
  local workspace="$1"
  local mode="$2"
  local shadow_parent="${REAL_HOME}/Library/Caches/colima/workcell-shadow"
  local rel path git_dir git_rel

  SHADOW_MOUNTS=()
  SHADOW_DEST_PATHS=()
  WORKSPACE_IMPORT_MOUNTS=()
  [[ "${mode}" == "breakglass" ]] && return 0

  if [[ -n "${WORKCELL_DOCKER_HOME:-}" ]]; then
    shadow_parent="${WORKCELL_DOCKER_HOME}/Library/Caches/colima/workcell-shadow"
  fi

  mkdir -p "${shadow_parent}"
  CONTROL_PLANE_SHADOW_ROOT="$(mktemp -d "${shadow_parent}/shadow.XXXXXX")"

  while IFS= read -r -d '' git_dir; do
    git_rel="${git_dir#"${workspace}/"}"
    for rel in "${git_rel}/hooks" "${git_rel}/config" "${git_rel}/config.worktree"; do
      add_shadow_git_path_if_present "${workspace}" "${rel}"
    done
    if [[ -e "${workspace}/${git_rel}/worktrees" ]]; then
      add_shadow_dir_mount "${git_rel}/worktrees"
    fi
    if [[ -d "${workspace}/${git_rel}/modules" ]]; then
      while IFS= read -r -d '' path; do
        rel="${path#"${workspace}/"}"
        add_shadow_git_path_if_present "${workspace}" "${rel}"
      done < <(
        find "${workspace}/${git_rel}/modules" \
          \( \
          \( \( -type d -o -type l \) -name hooks \) -o \
          \( \( -type f -o -type l \) \( -name config -o -name config.worktree \) \) \
          \) \
          -print0
      )
      while IFS= read -r -d '' path; do
        rel="${path#"${workspace}/"}"
        add_shadow_dir_mount "${rel}"
      done < <(
        find "${workspace}/${git_rel}/modules" \
          \( \( -type d -o -type l \) -name worktrees \) -print0
      )
    fi
  done < <(
    find "${workspace}" -type d -name .git -prune -print0
  )

  while IFS= read -r -d '' path; do
    rel="${path#"${workspace}/"}"
    add_shadow_dir_mount "${rel}"
  done < <(
    find "${workspace}" \
      \( -name .git -type d -prune \) -o \
      \( \( -type d -o -type l \) \( -name .codex -o -name .claude -o -name .gemini -o -name .vscode -o -name .idea -o -name .cursor -o -name .zed \) \) -print0
  )

  for rel in AGENTS.md CLAUDE.md GEMINI.md .mcp.json; do
    if [[ -f "${workspace}/${rel}" ]] || [[ -L "${workspace}/${rel}" ]]; then
      add_shadow_file_mount "${rel}"
    fi
  done

  add_workspace_import_file "${workspace}" "AGENTS.md"
  add_workspace_import_file "${workspace}" "CLAUDE.md"
  add_workspace_import_file "${workspace}" "GEMINI.md"
  register_workspace_import_root_mount
}

bootstrap_endpoints() {
  echo "auth.docker.io:443 docker.io:443 index.docker.io:443 registry-1.docker.io:443 production.cloudflare.docker.com:443 github.com:443 objects.githubusercontent.com:443 release-assets.githubusercontent.com:443 registry.npmjs.org:443 snapshot.debian.org:80 snapshot.debian.org:443"
}

AGENT=""
AGENT_AUTONOMY="yolo"
