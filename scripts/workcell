  for ((i = 0; i < ${#WORKSPACE_IMPORT_MOUNTS[@]}; i += 2)); do
    printf 'workspace_import_mount=%s\n' "${WORKSPACE_IMPORT_MOUNTS[i+1]}"
  done
  exit 0
fi

