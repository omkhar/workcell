while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      AGENT="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --target)
      TARGET_BACKEND="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --target-id)
      TARGET_ID_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --agent-autonomy)
      AGENT_AUTONOMY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --cache-profile)
      CACHE_PROFILE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --agent-arg)
      AGENT_ARGS+=("$(raw_option_value_or_die "$1" "${2-}")")
      shift 2
      ;;
    --codex-rules-mutability)
      CODEX_RULES_MUTABILITY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-mutability)
      CONTAINER_MUTABILITY="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-cpu)
      CONTAINER_CPU_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --container-memory)
      CONTAINER_MEMORY_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --injection-policy)
      INJECTION_POLICY="$(raw_option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --no-default-injection-policy)
      USE_DEFAULT_INJECTION_POLICY=0
      shift
      ;;
    --log-level)
      LOG_LEVEL="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --no-spinner)
      NO_SPINNER=1
      shift
      ;;
    --debug-log)
      DEBUG_LOG_PATH="$(raw_option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --file-trace-log)
      FILE_TRACE_LOG_PATH="$(raw_option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --audit-transcript)
      AUDIT_TRANSCRIPT_PATH="$(raw_option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --ui)
      UI="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --mode)
      MODE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --workspace)
      WORKSPACE="$(resolve_host_path "$(option_value_or_die "$1" "${2-}")")"
      shift 2
      ;;
    --session-workspace)
      SESSION_WORKSPACE_MODE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --colima-profile)
      COLIMA_PROFILE="$(option_value_or_die "$1" "${2-}")"
      COLIMA_PROFILE_EXPLICIT=1
      shift 2
      ;;
    --vm-cpu)
      VM_CPU_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --vm-memory)
      VM_MEMORY_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --vm-disk)
      VM_DISK_OVERRIDE="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --prepare)
      PREPARE=1
      shift
      ;;
    --prepare-only)
      PREPARE=1
      PREPARE_ONLY=1
      shift
      ;;
    --repair-profile)
      REPAIR_PROFILE=1
      shift
      ;;
    --doctor)
      DOCTOR=1
      shift
      ;;
    --inspect)
      INSPECT=1
      shift
      ;;
    --logs)
      LOGS_KIND="$(option_value_or_die "$1" "${2-}")"
      shift 2
      ;;
    --auth-status)
      AUTH_STATUS=1
      shift
      ;;
    --gc)
      GC=1
      shift
      ;;
    --test-fail-after-profile-refresh)
      TEST_FAIL_AFTER_PROFILE_REFRESH=1
      shift
      ;;
    --allow-nongit-workspace)
      ALLOW_NONGIT_WORKSPACE=1
      shift
      ;;
    --allow-control-plane-vcs)
      ALLOW_CONTROL_PLANE_VCS=1
      shift
      ;;
    --allow-arbitrary-command)
      ALLOW_ARBITRARY_COMMAND=1
      shift
      ;;
    --ack-breakglass)
      ACK_BREAKGLASS=1
      shift
      ;;
    --ack-breakglass=*)
      ACK_BREAKGLASS=1
      ACK_BREAKGLASS_TOKEN="${1#*=}"
      shift
      ;;
    --ack-control-plane-vcs)
      ACK_CONTROL_PLANE_VCS=1
      shift
      ;;
    --ack-arbitrary-command)
      ACK_ARBITRARY_COMMAND=1
      shift
      ;;
    --ack-arbitrary-command=*)
      ACK_ARBITRARY_COMMAND=1
      ACK_ARBITRARY_COMMAND_TOKEN="${1#*=}"
      shift
      ;;
    --rebuild)
      REBUILD=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

validate_target_backend_name "${TARGET_BACKEND}"
validate_agent_autonomy_name "${AGENT_AUTONOMY}"
