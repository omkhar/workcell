  printf '%s/runtime-image-cache\n' "${COLIMA_STATE_ROOT}"
}

profile_runtime_image_cache_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s.tar\n' "$(profile_runtime_image_cache_dir)" "${profile}"
}

profile_runtime_image_cache_metadata_path() {
  local profile="$1"

  validate_colima_profile_name "${profile}"
  printf '%s/%s.env\n' "$(profile_runtime_image_cache_dir)" "${profile}"
}

refresh_profile_state() {
  local profile="$1"

  PROFILE_PREEXISTED=0
  PROFILE_MARKER_WORKSPACE=""

  if [[ -d "$(profile_dir "${profile}")" ]]; then
    PROFILE_PREEXISTED=1
  fi

  if [[ -f "$(profile_marker_path "${profile}")" ]]; then
    PROFILE_MARKER_WORKSPACE="$(read_profile_marker_workspace "${profile}" || true)"
  fi
}

profile_image_marker_value() {
  local profile="$1"
  local key="$2"
  local marker_path=""

  [[ "${key}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || return 1
  marker_path="$(profile_image_marker_path "${profile}")"
  [[ -f "${marker_path}" ]] || return 1
  sed -n "s/^${key}=//p" "${marker_path}" | head -n1
}

profile_runtime_image_cache_value() {
  local profile="$1"
  local key="$2"
  local metadata_path=""

  [[ "${key}" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || return 1
  metadata_path="$(profile_runtime_image_cache_metadata_path "${profile}")"
  [[ -f "${metadata_path}" ]] || return 1
  sed -n "s/^${key}=//p" "${metadata_path}" | head -n1
}

