#!/bin/bash -p
readonly TRUSTED_HOST_PATH="/Applications/Codex.app/Contents/Resources:/opt/homebrew/bin:/usr/local/bin:/usr/local/go/bin:/usr/bin:/bin:/opt/homebrew/sbin:/usr/local/sbin:/usr/sbin:/sbin:/Applications/Docker.app/Contents/Resources/bin"
if [[ "${WORKCELL_PRECOMMIT_SANITIZED_ENTRYPOINT:-0}" != "1" ]]; then
  exec /usr/bin/env -i \
    PATH="${TRUSTED_HOST_PATH}" \
    HOME="${HOME:-/tmp}" \
    TMPDIR="${TMPDIR:-/tmp}" \
    WORKCELL_SKIP_UPSTREAM_REFRESH_PRECOMMIT="${WORKCELL_SKIP_UPSTREAM_REFRESH_PRECOMMIT:-}" \
    WORKCELL_SKIP_PROVIDER_BUMP_PRECOMMIT="${WORKCELL_SKIP_PROVIDER_BUMP_PRECOMMIT:-}" \
    WORKCELL_PRECOMMIT_SANITIZED_ENTRYPOINT=1 \
    /bin/bash -p "$0" "$@"
fi
set -euo pipefail
export PATH="${TRUSTED_HOST_PATH}"

if [[ "${WORKCELL_SKIP_UPSTREAM_REFRESH_PRECOMMIT:-${WORKCELL_SKIP_PROVIDER_BUMP_PRECOMMIT:-0}}" == "1" ]]; then
  exit 0
fi

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${HOOK_DIR}/.." && pwd)"

if output="$("${ROOT_DIR}/scripts/update-upstream-pins.sh" --check 2>&1)"; then
  exit 0
else
  status=$?
fi

printf '%s\n' "${output}" >&2
if [[ "${status}" -eq 1 ]]; then
  echo "Pinned upstream updates are available." >&2
  echo "Run ./scripts/update-upstream-pins.sh --apply from a clean worktree or trigger the upstream-refresh workflow before committing unrelated changes." >&2
else
  echo "Pinned upstream pre-commit check failed." >&2
  echo "Set WORKCELL_SKIP_UPSTREAM_REFRESH_PRECOMMIT=1 only if you intentionally need to bypass the hook." >&2
fi
exit "${status}"
